        "i3": { "type": "ingredient", "settings": { "name": "Coco Glucoside", "role": "The clean, the gentle kind", "story": "Sugar + coconut, full stop. Lifts dirt without stripping the skin barrier. Mild enough for daily use on every body zone we say yes to.", "image_caption": "coco glucoside · macro" } }
