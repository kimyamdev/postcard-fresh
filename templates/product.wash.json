        "i1": { "type": "ingredient", "settings": { "name": "Tuberose Absolute", "role": "The bloom in the dark", "story": "Hand-picked at midnight in southern France when the flower opens. We use 2.4kg of petals per kg of absolute — the reason your skin smells like a garden after.", "image_caption": "tuberose absolute · macro" } },
