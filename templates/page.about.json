{
  "sections": {
    "about_hero": { "type": "postcard-about-hero", "settings": {} },
    "about_story": {
      "type": "postcard-about-story",
      "blocks": {
        "p1": { "type": "paragraph", "settings": { "text": "<p>Hildra had eczema as a kid, acne as a teenager, then it all came back in her twenties. Pharmacy creams worked until they didn't. Expensive serums worked once. The cycle repeated.</p>" }},
        "p2": { "type": "paragraph", "settings": { "text": "<p>So she started making things in her kitchen. Simple shampoo bars. A face oil with three ingredients. A deodorant that didn't smell like an airport. Her skin agreed. Friends asked. The cookie jar in the kitchen filled, then sold out.</p>" }},
        "p3": { "type": "paragraph", "settings": { "text": "<p>Postcard was born in 2019 — first as a refillery in Everton Park, then as a brand built around a question: <em>what if self-care was simpler, kinder, and a little bit playful?</em></p>" }}
      },
      "block_order": ["p1","p2","p3"],
      "settings": {}
    },
    "about_beliefs": {
      "type": "postcard-about-beliefs",
      "blocks": {
        "b1": { "type": "belief", "settings": { "color": "#E8C36A", "postmark_html": "SIMPLICITY", "heading": "Simplicity", "body": "Fewer steps. Fewer ingredients. More impact." }},
        "b2": { "type": "belief", "settings": { "color": "#9CC4D6", "postmark_html": "SUSTAINABLE", "heading": "Sustainable, not preachy", "body": "Refillable. Recyclable. Optimistic." }},
        "b3": { "type": "belief", "settings": { "color": "#E8B796", "postmark_html": "SENSORIAL", "heading": "Sensorial transport", "body": "Every product is a destination." }},
        "b4": { "type": "belief", "settings": { "color": "#C7A8D6", "postmark_html": "MADE", "heading": "Made by humans", "body": "Mixed, poured, packed in Singapore." }},
        "b5": { "type": "belief", "settings": { "color": "#FFB233", "postmark_html": "PERSONAL", "heading": "Personal & playful", "body": "Custom blends, postcards in the post." }}
      },
      "block_order": ["b1","b2","b3","b4","b5"],
      "settings": {}
    },
