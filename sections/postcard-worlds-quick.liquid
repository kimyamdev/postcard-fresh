{%- liquid
  assign worlds_all = shop.metaobjects.world.values
  assign visible_count = section.settings.visible_count | default: 7
  assign total_count = 0
  for w in worlds_all
    if w.tier.value == 'World'
      assign total_count = total_count | plus: 1
    endif
  endfor
  assign more_count = total_count | minus: visible_count
  if more_count < 0
    assign more_count = 0
  endif
-%}
<section class="pc-worlds-quick">
  <div class="container">
    <div class="pc-worlds-quick__head">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <div class="eyebrow">{{ section.settings.eyebrow }}</div>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="h-display pc-worlds-quick__title">{{ section.settings.title }}</h2>
        {%- endif -%}
      </div>
      {%- if section.settings.see_all_text != blank -%}
        {%- assign see_all_text = section.settings.see_all_text | replace: '[count]', total_count -%}
        <a class="tlink" href="{{ section.settings.see_all_url | default: '/pages/worlds' }}">{{ see_all_text }}</a>
      {%- endif -%}
    </div>
    <div class="pc-worlds-quick__grid">
      {%- assign emitted = 0 -%}
      {%- for w in worlds_all -%}
        {%- if emitted >= visible_count -%}{%- break -%}{%- endif -%}
        {%- if w.tier.value != 'World' -%}{%- continue -%}{%- endif -%}
        {%- assign slug = w.slug.value | default: w.handle -%}
        {%- assign accent = w.accent_color.value | default: '#E8C36A' -%}
        {%- assign family = w.family.value -%}
        <a class="pc-worlds-quick__cell" href="/pages/{{ slug }}">
          {% render 'stamp', name: w.name.value, family: family, color: accent, size: 'md' %}
        </a>
        {%- assign emitted = emitted | plus: 1 -%}
      {%- endfor -%}
      {%- if more_count > 0 and section.settings.more_text != blank -%}
        {%- assign more_text = section.settings.more_text | replace: '[count]', more_count -%}
        <a class="pc-worlds-quick__more" href="{{ section.settings.more_url | default: '/pages/worlds' }}">{{ more_text }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Postcard Worlds Quick",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Six destinations" },
    { "type": "text", "id": "title",   "label": "Title",   "default": "Pick a world." },
    { "type": "header", "content": "Grid" },
    { "type": "range", "id": "visible_count", "label": "Worlds to show", "min": 3, "max": 12, "step": 1, "default": 7, "info": "Reads from your World metaobjects in admin order." },
    { "type": "header", "content": "See all link" },
    { "type": "text", "id": "see_all_text", "label": "Text", "default": "See all [count] worlds →", "info": "[count] is replaced with total world count" },
    { "type": "url",  "id": "see_all_url",  "label": "Link" },
    { "type": "header", "content": "+more tile (overflow)" },
    { "type": "text", "id": "more_text", "label": "Text", "default": "+[count] more<br>worlds →", "info": "[count] is replaced with overflow count" },
    { "type": "url",  "id": "more_url",  "label": "Link" }
  ],
  "presets": [{ "name": "Postcard Worlds Quick" }]
}
{% endschema %}
