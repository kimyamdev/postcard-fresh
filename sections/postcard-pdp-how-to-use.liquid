<section class="section section--tight pc-hu">
  <div class="container">
    <h2 class="h-display pc-hu__title">How to use.</h2>
    <div class="pc-hu__grid">
      {%- for block in section.blocks -%}
        <div class="pc-hu__step" {{ block.shopify_attributes }}>
          <span class="postmark pc-hu__pm"><div>{{ forloop.index }}</div></span>
          <div class="h-display pc-hu__step-h">{{ block.settings.heading }}</div>
          <p class="pc-hu__step-p">{{ block.settings.body }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How to use",
  "settings": [],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "textarea", "id": "body", "label": "Body" }
      ]
    }
  ],
  "presets": [
    {
      "name": "How to use",
      "blocks": [
        { "type": "step", "settings": { "heading": "One full pump", "body": "That's ~2.5ml. Stop there. More foam, less product." } },
        { "type": "step", "settings": { "heading": "Lather, then linger", "body": "Massage into wet skin for 20 seconds. The scent develops as it warms." } },
        { "type": "step", "settings": { "heading": "Rinse, leave the smell", "body": "Skin will smell for hours. That's the wash, not your fragrance — wear something complementary." } }
      ]
    }
  ]
}
{% endschema %}
