{{ 'postcard-components.css' | asset_url | stylesheet_tag }}

<div class="pc-announce">
  {{ section.settings.announcement_html }}
</div>

<header class="pc-header" x-data="{
    shopOpen: false, shopT: null,
    worldsOpen: false, worldsT: null,
    openShop()    { clearTimeout(this.shopT);   this.shopOpen = true; },
    closeShop()   { clearTimeout(this.shopT);   this.shopT   = setTimeout(() => this.shopOpen   = false, 200); },
    openWorlds()  { clearTimeout(this.worldsT); this.worldsOpen = true; },
    closeWorlds() { clearTimeout(this.worldsT); this.worldsT = setTimeout(() => this.worldsOpen = false, 200); }
  }">
  <button class="pc-mobile-hamburger" type="button" aria-label="Open menu"
    @click="window.dispatchEvent(new CustomEvent('pc-mobile-nav:open'))">
    <span></span><span></span><span></span>
  </button>
  <a href="{{ routes.root_url }}" class="pc-logo">
    POSTCARD<span class="pc-logo__sg">&middot; SG</span>
  </a>

  <nav class="pc-nav">
    <span class="pc-nav__trigger" @mouseenter="openShop()" @mouseleave="closeShop()">
      <button class="pc-nav__link" type="button" @focus="openShop()" @blur="closeShop()">Shop &#9662;</button>
      <div class="pc-megamenu pc-megamenu--shop" x-show="shopOpen" x-cloak @mouseenter="openShop()" @mouseleave="closeShop()">
        <div>
          <div class="eyebrow pc-megamenu__col-title">By need</div>
          <a class="pc-megamenu__item" href="/collections/body">Body</a>
          <a class="pc-megamenu__item" href="/collections/hair">Hair</a>
          <a class="pc-megamenu__item" href="/collections/face">Face</a>
          <a class="pc-megamenu__item" href="/collections/deodorants">Deodorants</a>
          <a class="pc-megamenu__item" href="/collections/home-fragrance">Home Fragrance</a>
          <a class="pc-megamenu__item" href="/collections/lip-and-hand">Lip &amp; Hand</a>
          <a class="pc-megamenu__item" href="/collections/pet">Pet</a>
          <a class="pc-megamenu__item" href="/collections/kids">Kids</a>
          <a class="pc-megamenu__item" href="/collections/gifts">Gifts</a>
          <a class="pc-megamenu__item" href="/collections/accessories">Accessories</a>
        </div>
        <div>
          <div class="eyebrow pc-megamenu__col-title">Bestsellers</div>
          <a class="pc-megamenu__item" href="/products/hotel-lobby-anywhere-fragrance">Hotel Lobby Anywhere Fragrance</a>
          <a class="pc-megamenu__item" href="/pages/pick-and-mix">Pick &amp; Mix</a>
          <a class="pc-megamenu__item" href="/collections/discovery-sets">Discovery sets</a>
          <a class="pc-megamenu__item" href="/products/hotel-lobby-travel-box">Hotel Lobby Travel Box</a>
        </div>
        <div>
          <div class="eyebrow pc-megamenu__col-title">New &amp; limited</div>
          <a class="pc-megamenu__item" href="/collections/postcard-x-sojao">POSTCARD x SOJAO</a>
          <a class="pc-megamenu__item" href="/collections/postcard-x-esse">POSTCARD x ESSE</a>
          <a class="pc-megamenu__item" href="/collections/postcard-x-anya-active">POSTCARD x Anya Active</a>
          <a class="pc-megamenu__item" href="/collections/seasonal">Seasonal</a>
        </div>
        <div>
          <div class="eyebrow pc-megamenu__col-title">Custom</div>
          <a class="pc-megamenu__item" href="/pages/pick-and-mix">Pick &amp; Mix</a>
          <a class="pc-megamenu__item" href="/pages/custom-hand-and-body-wash">Custom Hand &amp; Body Wash</a>
          <a class="pc-megamenu__item" href="/pages/custom-shampoo">Custom Shampoo</a>
          <a class="pc-megamenu__item" href="/pages/custom-conditioner">Custom Conditioner</a>
        </div>
      </div>
    </span>

    <span class="pc-nav__trigger" @mouseenter="openWorlds()" @mouseleave="closeWorlds()">
      <button class="pc-nav__link" type="button" @focus="openWorlds()" @blur="closeWorlds()">Worlds &#9662;</button>
      <div class="pc-megamenu pc-megamenu--worlds" x-show="worldsOpen" x-cloak @mouseenter="openWorlds()" @mouseleave="closeWorlds()">
        <div class="pc-worlds-grid">
          <a class="pc-world-row" href="/pages/hotel-lobby">
            <div class="pc-world-row__chip" style="background: #E8C36A;">HL</div>
            <div>
              <div class="pc-world-row__name">Hotel Lobby</div>
              <div class="pc-world-row__family">Hesperidic Gourmand</div>
            </div>
          </a>
          <a class="pc-world-row" href="/pages/moon-bloom">
            <div class="pc-world-row__chip" style="background: #5C6688;">MB</div>
            <div>
              <div class="pc-world-row__name">Moon Bloom</div>
              <div class="pc-world-row__family">White Floral</div>
            </div>
          </a>
          <a class="pc-world-row" href="/pages/coconut-beach">
            <div class="pc-world-row__chip" style="background: #E8B796;">CB</div>
            <div>
              <div class="pc-world-row__name">Coconut Beach</div>
              <div class="pc-world-row__family">Tropical Fruity Gourmand</div>
            </div>
          </a>
          <a class="pc-world-row" href="/pages/wild-flowers">
            <div class="pc-world-row__chip" style="background: #C7A8D6;">WF</div>
            <div>
              <div class="pc-world-row__name">Wild Flowers</div>
              <div class="pc-world-row__family">Aromatic Foug&egrave;re</div>
            </div>
          </a>
          <a class="pc-world-row" href="/pages/bath-house">
            <div class="pc-world-row__chip" style="background: #B07A4E;">BH</div>
            <div>
              <div class="pc-world-row__name">Bath House</div>
              <div class="pc-world-row__family">Woody Oriental</div>
            </div>
          </a>
          <a class="pc-world-row" href="/pages/woodland-retreat">
            <div class="pc-world-row__chip" style="background: #6E7F58;">WR</div>
            <div>
              <div class="pc-world-row__name">Woodland Retreat</div>
              <div class="pc-world-row__family">Aromatic Herbal</div>
            </div>
          </a>
          <a class="pc-world-row" href="/pages/icy-peaks">
            <div class="pc-world-row__chip" style="background: #9CC4D6;">IP</div>
            <div>
              <div class="pc-world-row__name">Icy Peaks</div>
              <div class="pc-world-row__family">Fresh Aromatic</div>
            </div>
          </a>
        </div>
        <a class="tlink" href="/pages/worlds" style="display: inline-block; margin-top: 18px;">See all 22 worlds &rarr;</a>
      </div>
    </span>

    <a class="pc-nav__link" href="/pages/refill"{% if request.path contains '/pages/refill' %} aria-current="page"{% endif %}>Refill</a>
    <a class="pc-nav__link" href="/pages/subscriptions"{% if request.path contains '/pages/subscriptions' %} aria-current="page"{% endif %}>Subscribe</a>
    <a class="pc-nav__link" href="/pages/membership"{% if request.path contains '/pages/membership' %} aria-current="page"{% endif %}>Members</a>
    <a class="pc-nav__link" href="/pages/about"{% if request.path contains '/pages/about' %} aria-current="page"{% endif %}>About</a>
    <a class="pc-nav__link" href="/pages/corporate"{% if request.path contains '/pages/corporate' %} aria-current="page"{% endif %}>Corporate</a>
  </nav>

  <div class="pc-utility">
    <a class="pc-utility__link" href="{{ routes.search_url }}">Search</a>
    <a class="pc-utility__link" href="{{ routes.account_url }}">Account</a>
    <a class="pc-bag" id="cart-icon-bubble" href="{{ routes.cart_url }}">Bag &middot; <span data-pc-cart-count>{{ cart.item_count }}</span></a>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "html",
      "id": "announcement_html",
      "label": "Announcement bar HTML",
      "default": "Free SG shipping over $80 &middot; Refill at our Orchard flagship &middot; <span class=\"pc-announce__accent\">Postcards in your inbox &rarr;</span>"
    }
  ]
}
{% endschema %}
