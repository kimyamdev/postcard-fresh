{{ 'postcard-components.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign show_shop = section.settings.show_shop
  assign show_worlds = section.settings.show_worlds
  assign worlds_limit = section.settings.worlds_limit | default: 7

  assign all_worlds = shop.metaobjects.world.values
  assign worlds_total = all_worlds.size

  assign see_all_text = section.settings.worlds_see_all_text | default: 'See all [count] worlds →'
  assign see_all_text = see_all_text | replace: '[count]', worlds_total

  assign has_shop_items = false
  for b in section.blocks
    if b.type == 'shop_item'
      assign has_shop_items = true
      break
    endif
  endfor
-%}

<div class="pc-announce">
  {{ section.settings.announcement_html }}
</div>

<header class="pc-header" x-data="{
    shopOpen: false, shopT: null,
    worldsOpen: false, worldsT: null,
    openShop()    { clearTimeout(this.shopT);   this.shopOpen = true; },
    closeShop()   { clearTimeout(this.shopT);   this.shopT   = setTimeout(() => this.shopOpen   = false, 200); },
    openWorlds()  { clearTimeout(this.worldsT); this.worldsOpen = true; },
    closeWorlds() { clearTimeout(this.worldsT); this.worldsT = setTimeout(() => this.worldsOpen = false, 200); }
  }">
  <button class="pc-mobile-hamburger" type="button" aria-label="Open menu"
    @click="window.dispatchEvent(new CustomEvent('pc-mobile-nav:open'))">
    <span></span><span></span><span></span>
  </button>
  <a href="{{ routes.root_url }}" class="pc-logo">
    POSTCARD<span class="pc-logo__sg">&middot; SG</span>
  </a>

  <nav class="pc-nav">
    {%- if show_shop and has_shop_items -%}
      <span class="pc-nav__trigger" @mouseenter="openShop()" @mouseleave="closeShop()">
        <button class="pc-nav__link" type="button" @focus="openShop()" @blur="closeShop()">{{ section.settings.shop_label | default: 'Shop' }} &#9662;</button>
        <div class="pc-megamenu pc-megamenu--shop" x-show="shopOpen" x-cloak @mouseenter="openShop()" @mouseleave="closeShop()">
          {%- for col_num in (1..4) -%}
            {%- assign col_title = '' -%}
            {%- case col_num -%}
              {%- when 1 -%}{%- assign col_title = section.settings.shop_col1_title -%}
              {%- when 2 -%}{%- assign col_title = section.settings.shop_col2_title -%}
              {%- when 3 -%}{%- assign col_title = section.settings.shop_col3_title -%}
              {%- when 4 -%}{%- assign col_title = section.settings.shop_col4_title -%}
            {%- endcase -%}
            {%- assign col_has_items = false -%}
            {%- for b in section.blocks -%}
              {%- if b.type == 'shop_item' and b.settings.column == col_num -%}
                {%- assign col_has_items = true -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if col_has_items or col_title != blank -%}
              <div>
                {%- if col_title != blank -%}
                  <div class="eyebrow pc-megamenu__col-title">{{ col_title }}</div>
                {%- endif -%}
                {%- for b in section.blocks -%}
                  {%- if b.type == 'shop_item' and b.settings.column == col_num -%}
                    <a class="pc-megamenu__item" href="{{ b.settings.url }}" {{ b.shopify_attributes }}>{{ b.settings.text }}</a>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </span>
    {%- endif -%}

    {%- if show_worlds and worlds_total > 0 -%}
      <span class="pc-nav__trigger" @mouseenter="openWorlds()" @mouseleave="closeWorlds()">
        <button class="pc-nav__link" type="button" @focus="openWorlds()" @blur="closeWorlds()">{{ section.settings.worlds_label | default: 'Worlds' }} &#9662;</button>
        <div class="pc-megamenu pc-megamenu--worlds" x-show="worldsOpen" x-cloak @mouseenter="openWorlds()" @mouseleave="closeWorlds()">
          <div class="pc-worlds-grid">
            {%- for w in all_worlds limit: worlds_limit -%}
              {%- assign w_slug = w.slug.value | default: w.handle -%}
              {%- assign w_color = w.accent_color.value | default: '#E8C36A' -%}
              {%- assign w_name = w.name.value -%}
              {%- assign w_family = w.family.value -%}
              {%- assign words = w_name | split: ' ' -%}
              {%- assign initials = '' -%}
              {%- for word in words limit: 2 -%}
                {%- assign first_letter = word | slice: 0, 1 | upcase -%}
                {%- assign initials = initials | append: first_letter -%}
              {%- endfor -%}
              <a class="pc-world-row" href="/pages/{{ w_slug }}">
                <div class="pc-world-row__chip" style="background: {{ w_color }};">{{ initials }}</div>
                <div>
                  <div class="pc-world-row__name">{{ w_name }}</div>
                  {%- if w_family != blank -%}
                    <div class="pc-world-row__family">{{ w_family }}</div>
                  {%- endif -%}
                </div>
              </a>
            {%- endfor -%}
          </div>
          {%- if section.settings.worlds_see_all_url != blank -%}
            <a class="tlink" href="{{ section.settings.worlds_see_all_url }}" style="display: inline-block; margin-top: 18px;">{{ see_all_text }}</a>
          {%- endif -%}
        </div>
      </span>
    {%- endif -%}

    {%- for b in section.blocks -%}
      {%- if b.type == 'nav_link' -%}
        {%- assign is_current = false -%}
        {%- if b.settings.url != blank and request.path == b.settings.url -%}
          {%- assign is_current = true -%}
        {%- endif -%}
        <a class="pc-nav__link" href="{{ b.settings.url }}"{% if is_current %} aria-current="page"{% endif %} {{ b.shopify_attributes }}>{{ b.settings.text }}</a>
      {%- endif -%}
    {%- endfor -%}
  </nav>

  <div class="pc-utility">
    {%- if section.settings.show_search -%}
      <a class="pc-utility__link" href="{{ routes.search_url }}">{{ section.settings.search_label | default: 'Search' }}</a>
    {%- endif -%}
    {%- if section.settings.show_account -%}
      <a class="pc-utility__link" href="{{ routes.account_url }}">{{ section.settings.account_label | default: 'Account' }}</a>
    {%- endif -%}
    <a class="pc-bag" id="cart-icon-bubble" href="{{ routes.cart_url }}">{{ section.settings.bag_label | default: 'Bag' }} &middot; <span data-pc-cart-count>{{ cart.item_count }}</span></a>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "html", "id": "announcement_html", "label": "Announcement bar HTML", "default": "Free SG shipping over $80 &middot; Refill at our Orchard flagship &middot; <span class=\"pc-announce__accent\">Postcards in your inbox &rarr;</span>" },

    { "type": "header", "content": "Shop dropdown" },
    { "type": "checkbox", "id": "show_shop", "label": "Show Shop dropdown", "default": true, "info": "Hidden automatically when there are no Shop link blocks." },
    { "type": "text", "id": "shop_label", "label": "Trigger label", "default": "Shop" },
    { "type": "text", "id": "shop_col1_title", "label": "Column 1 title", "default": "By need" },
    { "type": "text", "id": "shop_col2_title", "label": "Column 2 title", "default": "Bestsellers" },
    { "type": "text", "id": "shop_col3_title", "label": "Column 3 title", "default": "New & limited" },
    { "type": "text", "id": "shop_col4_title", "label": "Column 4 title", "default": "Custom" },

    { "type": "header", "content": "Worlds dropdown" },
    { "type": "checkbox", "id": "show_worlds", "label": "Show Worlds dropdown", "default": true, "info": "Auto-sourced from World metaobject entries." },
    { "type": "text", "id": "worlds_label", "label": "Trigger label", "default": "Worlds" },
    { "type": "range", "id": "worlds_limit", "label": "Worlds to show", "min": 4, "max": 12, "step": 1, "default": 7 },
    { "type": "text", "id": "worlds_see_all_text", "label": "See-all link text", "default": "See all [count] worlds →", "info": "[count] is replaced with total worlds." },
    { "type": "url",  "id": "worlds_see_all_url",  "label": "See-all link URL" },

    { "type": "header", "content": "Utility row" },
    { "type": "checkbox", "id": "show_search",  "label": "Show Search link",  "default": true },
    { "type": "text",     "id": "search_label", "label": "Search label", "default": "Search" },
    { "type": "checkbox", "id": "show_account", "label": "Show Account link", "default": true },
    { "type": "text",     "id": "account_label","label": "Account label","default": "Account" },
    { "type": "text",     "id": "bag_label",    "label": "Bag label",    "default": "Bag" }
  ],
  "blocks": [
    {
      "type": "shop_item",
      "name": "Shop dropdown link",
      "settings": [
        { "type": "range", "id": "column", "label": "Column", "min": 1, "max": 4, "step": 1, "default": 1 },
        { "type": "text",  "id": "text",   "label": "Text" },
        { "type": "url",   "id": "url",    "label": "Link" }
      ]
    },
    {
      "type": "nav_link",
      "name": "Top-level nav link",
      "settings": [
        { "type": "text", "id": "text", "label": "Text" },
        { "type": "url",  "id": "url",  "label": "Link" }
      ]
    }
  ],
  "max_blocks": 50,
  "default": {
    "settings": {},
    "blocks": [
      { "type": "shop_item", "settings": { "column": 1, "text": "Body", "url": "/collections/body" } },
      { "type": "shop_item", "settings": { "column": 1, "text": "Hair", "url": "/collections/hair" } },
      { "type": "shop_item", "settings": { "column": 1, "text": "Face", "url": "/collections/face" } },
      { "type": "shop_item", "settings": { "column": 1, "text": "Deodorants", "url": "/collections/deodorants" } },
      { "type": "shop_item", "settings": { "column": 1, "text": "Home Fragrance", "url": "/collections/home-fragrance" } },
      { "type": "shop_item", "settings": { "column": 1, "text": "Lip & Hand", "url": "/collections/lip-and-hand" } },
      { "type": "shop_item", "settings": { "column": 1, "text": "Pet", "url": "/collections/pet" } },
      { "type": "shop_item", "settings": { "column": 1, "text": "Kids", "url": "/collections/kids" } },
      { "type": "shop_item", "settings": { "column": 1, "text": "Gifts", "url": "/collections/gifts" } },
      { "type": "shop_item", "settings": { "column": 1, "text": "Accessories", "url": "/collections/accessories" } },

      { "type": "shop_item", "settings": { "column": 2, "text": "Hotel Lobby Anywhere Fragrance", "url": "/products/hotel-lobby-anywhere-fragrance" } },
      { "type": "shop_item", "settings": { "column": 2, "text": "Pick & Mix", "url": "/pages/pick-and-mix" } },
      { "type": "shop_item", "settings": { "column": 2, "text": "Discovery sets", "url": "/collections/discovery-sets" } },
      { "type": "shop_item", "settings": { "column": 2, "text": "Hotel Lobby Travel Box", "url": "/products/hotel-lobby-travel-box" } },

      { "type": "shop_item", "settings": { "column": 3, "text": "POSTCARD x SOJAO", "url": "/collections/postcard-x-sojao" } },
      { "type": "shop_item", "settings": { "column": 3, "text": "POSTCARD x ESSE", "url": "/collections/postcard-x-esse" } },
      { "type": "shop_item", "settings": { "column": 3, "text": "POSTCARD x Anya Active", "url": "/collections/postcard-x-anya-active" } },
      { "type": "shop_item", "settings": { "column": 3, "text": "Seasonal", "url": "/collections/seasonal" } },

      { "type": "shop_item", "settings": { "column": 4, "text": "Pick & Mix", "url": "/pages/pick-and-mix" } },
      { "type": "shop_item", "settings": { "column": 4, "text": "Custom Hand & Body Wash", "url": "/pages/custom-hand-and-body-wash" } },
      { "type": "shop_item", "settings": { "column": 4, "text": "Custom Shampoo", "url": "/pages/custom-shampoo" } },
      { "type": "shop_item", "settings": { "column": 4, "text": "Custom Conditioner", "url": "/pages/custom-conditioner" } },

      { "type": "nav_link", "settings": { "text": "Refill",    "url": "/pages/refill" } },
      { "type": "nav_link", "settings": { "text": "Subscribe", "url": "/pages/subscriptions" } },
      { "type": "nav_link", "settings": { "text": "Members",   "url": "/pages/membership" } },
      { "type": "nav_link", "settings": { "text": "About",     "url": "/pages/about" } },
      { "type": "nav_link", "settings": { "text": "Corporate", "url": "/pages/corporate" } }
    ]
  }
}
{% endschema %}
