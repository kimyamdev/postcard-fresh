<main>
  <section class="pc-mem-hero">
    <div class="container">
      <div class="eyebrow">Postcard Membership</div>
      <h1 class="h-display pc-mem-hero__title">Your self-care passport.</h1>
      <p class="pc-mem-hero__body">Earn coins on every order. Unlock perks the more you visit.</p>
      <div class="pc-mem-hero__ctas">
        <a class="btn" href="{{ section.settings.join_link }}">{{ section.settings.join_text }}</a>
        <a class="tlink" href="{{ routes.account_login_url }}">Already a member? Sign in</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="h-display pc-mem-tiers__title">Three tiers. More love. More rewards.</h2>
      <div class="pc-mem-tiers__grid">
        <div class="stamp-frame stamp-side pc-tier-card" style="background: #FFFDF4;">
          <div class="pc-tier-card__head">
            <h3 class="h-display pc-tier-card__name">Deluxe</h3>
            <span class="postmark"><div>01</div></span>
          </div>
          <div class="pc-tier-card__sub">Just sign up</div>
          <div class="pc-tier-card__divider"></div>
          <div class="pc-tier-card__row"><span>Earn</span><span>1 coin / $1</span></div>
          <div class="pc-tier-card__row"><span>Welcome</span><span>&mdash;</span></div>
          <div class="pc-tier-card__row"><span>Shipping</span><span>$80+ orders</span></div>
          <div class="pc-tier-card__row"><span>Birthday</span><span>100 coins</span></div>
          <div class="pc-tier-card__row"><span>Pals events</span><span>&mdash;</span></div>
          <div class="pc-tier-card__row"><span>Exclusive drops</span><span>&mdash;</span></div>
        </div>
        <div class="stamp-frame stamp-side pc-tier-card" style="background: #F2EEDD;">
          <div class="pc-tier-card__head">
            <h3 class="h-display pc-tier-card__name">Club</h3>
            <span class="postmark"><div>02</div></span>
          </div>
          <div class="pc-tier-card__sub">$250+ a year</div>
          <div class="pc-tier-card__divider"></div>
          <div class="pc-tier-card__row"><span>Earn</span><span>1 coin / $1</span></div>
          <div class="pc-tier-card__row"><span>Welcome</span><span>$30 gift card</span></div>
          <div class="pc-tier-card__row"><span>Shipping</span><span>$80+ orders</span></div>
          <div class="pc-tier-card__row"><span>Birthday</span><span>100 coins</span></div>
          <div class="pc-tier-card__row"><span>Pals events</span><span>&#10003;</span></div>
          <div class="pc-tier-card__row"><span>Exclusive drops</span><span>&#10003;</span></div>
        </div>
        <div class="stamp-frame stamp-side pc-tier-card" style="background: #FFB233;">
          <div class="pc-tier-card__head">
            <h3 class="h-display pc-tier-card__name">Villa</h3>
            <span class="postmark"><div>03</div></span>
          </div>
          <div class="pc-tier-card__sub">$500+ a year</div>
          <div class="pc-tier-card__divider"></div>
          <div class="pc-tier-card__row"><span>Earn</span><span>2 coins / $1</span></div>
          <div class="pc-tier-card__row"><span>Welcome</span><span>$60 gift card</span></div>
          <div class="pc-tier-card__row"><span>Shipping</span><span>Always free</span></div>
          <div class="pc-tier-card__row"><span>Birthday</span><span>100 coins</span></div>
          <div class="pc-tier-card__row"><span>Pals events</span><span>&#10003;</span></div>
          <div class="pc-tier-card__row"><span>Exclusive drops</span><span>&#10003;</span></div>
        </div>
      </div>
      <p class="pc-mem-tiers__note">100 coins = $5 store credit.</p>
    </div>
  </section>

  <section class="section pc-mem-earn">
    <div class="container">
      <h2 class="h-display pc-mem-earn__title">Earning coins is as easy as self-care should be.</h2>
      <div class="pc-mem-earn__grid">
        {%- assign earns = 'Place an order|1 coin / $1 (Deluxe + Club). 2 coins / $1 (Villa).~~Celebrate your birthday|100 coins.~~Write a review|20 coins · +10 photo · +15 video.~~Follow on Instagram|20 coins.~~Follow on TikTok|20 coins.~~Refer a friend|You both get 10% off.' | split: '~~' -%}
        {%- for entry in earns -%}
          {%- assign p = entry | split: '|' -%}
          <div class="pc-earn-card">
            <span class="postmark pc-earn-card__pm"><div>EARN</div></span>
            <div>
              <div class="h-display pc-earn-card__h">{{ p[0] }}</div>
              <div class="pc-earn-card__s">{{ p[1] }}</div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </section>
</main>

{% schema %}
{
  "name": "Membership page",
  "settings": [
    { "type": "text", "id": "join_text", "label": "Join CTA text", "default": "Join free →" },
    { "type": "text", "id": "join_link", "label": "Join link", "default": "/account/register" }
  ],
  "presets": [{ "name": "Membership page" }]
}
{% endschema %}
