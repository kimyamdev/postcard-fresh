{%- liquid
  assign accent = section.settings.accent_color | default: '#B07A4E'
-%}
<section class="section--tight section" style="--world-color: {{ accent }};">
  <div class="container pc-sub-noworries">
    {%- if section.settings.postmark_html != blank -%}
      <span class="postmark postmark--yellow pc-sub-noworries__pm"><div>{{ section.settings.postmark_html }}</div></span>
    {%- endif -%}
    <div>
      {%- if section.settings.eyebrow != blank -%}
        <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="h-typewriter pc-sub-noworries__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <p class="pc-sub-noworries__body">{{ section.settings.body }}</p>
      {%- endif -%}
      <div class="pc-sub-noworries__benefits">
        {%- for block in section.blocks -%}
          <div class="pc-sub-noworries__benefit" {{ block.shopify_attributes }}>
            <div class="pc-sub-noworries__benefit-h">✓ {{ block.settings.heading }}</div>
            <div class="pc-sub-noworries__benefit-n">{{ block.settings.note }}</div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Subs · Fine print",
  "tag": "section",
  "settings": [
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#B07A4E" },
    { "type": "html", "id": "postmark_html", "label": "Postmark text (HTML)", "default": "NO<br>HOSTAGES<br>·<br>POSTCARD<br>SG · 26" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The fine print, in friendly typeface" },
    { "type": "text", "id": "title", "label": "Title", "default": "Skip a month. Swap your world. Pause for a holiday. Cancel because you've finally cleared your bathroom shelf." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Two clicks from any email or your account dashboard. No phone tree, no \"we'll miss you\" gauntlet, no penalty for leaving and coming back. We treat your subscription like a houseplant: yours to water, yours to give away." }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Skip an order" },
        { "type": "text", "id": "note", "label": "Note", "default": "Until your next cycle" }
      ]
    }
  ],
  "presets": [{
    "name": "Subs · Fine print",
    "blocks": [
      { "type": "benefit", "settings": { "heading": "Skip an order", "note": "Until your next cycle" }},
      { "type": "benefit", "settings": { "heading": "Swap a world", "note": "Same product, new scent" }},
      { "type": "benefit", "settings": { "heading": "Change cadence", "note": "Slower or faster, anytime" }},
      { "type": "benefit", "settings": { "heading": "Pause indefinitely", "note": "Resume on a tap" }},
      { "type": "benefit", "settings": { "heading": "Cancel", "note": "No questions asked" }}
    ]
  }]
}
{% endschema %}
