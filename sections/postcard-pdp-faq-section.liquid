{%- assign title = section.settings.title | default: 'Questions?' -%}
<section class="section section--tight">
  <div class="container">
    <h2 class="h-display pc-pdp-faq__title">{{ title }}</h2>
    <div class="pc-pdp-faq__list">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <details class="pc-pdp-faq__item"{% if forloop.first %} open{% endif %} {{ block.shopify_attributes }}>
            <summary class="pc-pdp-faq__q">{{ block.settings.q }}</summary>
            <p class="pc-pdp-faq__a">{{ block.settings.a }}</p>
          </details>
        {%- endfor -%}
      {%- else -%}
        <details class="pc-pdp-faq__item">
          <summary class="pc-pdp-faq__q">No FAQs configured.</summary>
          <p class="pc-pdp-faq__a">Add FAQ blocks to this section in the editor.</p>
        </details>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PDP FAQ",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Questions?" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "q", "label": "Question" },
        { "type": "textarea", "id": "a", "label": "Answer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "PDP FAQ",
      "blocks": [
        { "type": "faq", "settings": { "q": "Can I refill an old Postcard bottle from years ago?", "a": "Yes — any age, any world. Even if the label has faded. Bring it in, we wash and refill." } }
      ]
    }
  ]
}
{% endschema %}
