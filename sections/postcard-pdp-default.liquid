{%- liquid
  assign world = product.metafields.postcard.world.value | default: product.metafields.custom.world.value
  if world
    assign world_color = world.accent_color.value
    assign world_theme_class = world.theme_class.value
    assign world_name = world.name.value
    assign world_linked = true
  endif
  assign world_color = world_color | default: '#E8C36A'
  assign world_theme_class = world_theme_class | default: ''
  assign world_name = world_name | default: ''
  assign bg_alpha = section.settings.bg_alpha | default: 10
  assign tint_css = ''
  if world_linked and bg_alpha > 0
    assign tint_css = 'color-mix(in srgb, ' | append: world_color | append: ' ' | append: bg_alpha | append: '%, transparent)'
  endif

  assign ribbon_subline = product.metafields.custom.ribbon_subline | default: product.type
  assign stamp_text = product.metafields.custom.stamp_text | default: section.settings.stamp_text_fallback

  assign current = product.selected_or_first_available_variant
  assign default_plan_id = ''
  assign first_sp_group = product.selling_plan_groups.first
  if first_sp_group and first_sp_group.selling_plans.size > 0
    assign default_plan_id = first_sp_group.selling_plans.first.id
  endif

  assign collection_breadcrumb = ''
  if product.collections.size > 0
    assign first_coll = product.collections.first
    assign collection_breadcrumb = first_coll.title
    assign collection_breadcrumb_url = first_coll.url
  endif
-%}

{%- if tint_css != '' -%}
  <style>
    #MainContent { background: {{ tint_css }}; }
  </style>
{%- endif -%}

<div class="{{ world_theme_class }} pc-pdp-default-wrap" style="--world-color: {{ world_color }};">

  <div class="pc-breadcrumb">
    <div class="container pc-breadcrumb__inner">
      <a href="{{ routes.root_url }}">Home</a>
      {%- if collection_breadcrumb != blank -%}
        / <a href="{{ collection_breadcrumb_url }}">{{ collection_breadcrumb }}</a>
      {%- endif -%}
      / <span class="pc-breadcrumb__current">{{ product.title }}</span>
    </div>
  </div>

  <section class="pc-pdp-main">
    <div class="container pc-pdp-main__inner">
      {% render 'pdp-gallery', product: product, world_color: world_color, stamp_text: stamp_text %}

      <aside class="pc-pdp-buy" x-data='{
        variantId: "{{ current.id }}",
        qty: 1,
        mode: "once",
        cadence: "{{ default_plan_id }}",
        subOpen: false,
        prices: { {%- for v in product.variants -%}"{{ v.id }}": "{{ v.price | money }}"{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%} },
        selectedOptions: [{%- for option in product.options_with_values -%}"{{ option.selected_value | replace: '"', '\"' }}"{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}],
        variantMap: { {%- for v in product.variants -%}"{{ v.option1 | replace: '"', '\"' }}|{{ v.option2 | replace: '"', '\"' }}|{{ v.option3 | replace: '"', '\"' }}": "{{ v.id }}"{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%} },
        updateVariant() {
          var key = (this.selectedOptions[0] || "") + "|" + (this.selectedOptions[1] || "") + "|" + (this.selectedOptions[2] || "");
          if (this.variantMap[key]) this.variantId = this.variantMap[key];
        },
        pickOption(idx) {
          var key = this.selectedOptions.join("|");
          if (this.variantMap[key]) { this.variantId = this.variantMap[key]; return; }
          var picked = this.selectedOptions[idx];
          for (var k in this.variantMap) {
            var parts = k.split("|");
            if (parts[idx] === picked) {
              for (var p = 0; p < this.selectedOptions.length; p++) this.selectedOptions[p] = parts[p];
              this.variantId = this.variantMap[k];
              return;
            }
          }
        },
        valueAvailable(idx, val) {
          for (var k in this.variantMap) {
            var parts = k.split("|");
            if (parts[idx] !== val) continue;
            var ok = true;
            for (var p = 0; p < this.selectedOptions.length; p++) {
              if (p === idx) continue;
              if (this.selectedOptions[p] && parts[p] !== this.selectedOptions[p]) { ok = false; break; }
            }
            if (ok) return true;
          }
          return false;
        }
      }' x-init="$watch('variantId', value => window.dispatchEvent(new CustomEvent('variant-change', { detail: { variantId: value } })))">
        <form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data" class="pc-pdp-buy__form">
          <input type="hidden" name="form_type" value="product">
          <input type="hidden" name="utf8" value="&#x2713;">
          {%- for block in section.blocks -%}
            {% render 'pdp-buy-block', block: block, product: product, world_color: world_color, world_name: world_name, ribbon_subline: ribbon_subline, current: current %}
          {%- endfor -%}
        </form>
      </aside>
    </div>
  </section>

</div>

{% schema %}
{
  "name": "Default PDP",
  "settings": [
    { "type": "paragraph", "content": "Pulls everything possible from the product + linked World metaobject. Use product.metafields.custom.ribbon_subline to override the eyebrow per-product (defaults to product.type); product.metafields.custom.stamp_text to override the corner stamp text; product.metafields.custom.ingredients and product.metafields.custom.benefits (richtext) for the collapsible sections." },
    { "type": "text", "id": "stamp_text_fallback", "label": "Stamp text (fallback)", "default": "POSTCARD<br>· SG ·" },
    { "type": "range", "id": "bg_alpha", "label": "World tint background (%)", "min": 0, "max": 30, "step": 2, "default": 10, "unit": "%", "info": "Applies the linked world's accent color as a subtle tint across the whole product page (gallery, buy block, pairs-with, reviews). 0 disables. Has no effect when no world is linked to the product." }
  ],
  "blocks": [
    { "type": "ribbon", "name": "Eyebrow ribbon", "limit": 1, "settings": [
      { "type": "text", "id": "subline_override", "label": "Subline override (per-template)" }
    ] },
    { "type": "title", "name": "Title", "limit": 1, "settings": [] },
    { "type": "tags_band", "name": "Auto tags band", "limit": 1, "settings": [
      { "type": "paragraph", "content": "Pills auto-appear based on product tags + selling plans. Override labels below." },
      { "type": "text", "id": "refill_label",  "label": "Refillable label",  "default": "Refillable" },
      { "type": "text", "id": "sub_label",     "label": "Subscribable label", "default": "Subscribable" },
      { "type": "text", "id": "vegan_label",   "label": "Vegan label",       "default": "Vegan" },
      { "type": "text", "id": "clean_label",   "label": "Clean label",       "default": "Clean" }
    ] },
    { "type": "description", "name": "Description", "limit": 1, "settings": [
      { "type": "number", "id": "word_limit", "label": "Word limit", "default": 500 }
    ] },
    { "type": "ingredients", "name": "Ingredients (metafield)", "limit": 1, "settings": [
      { "type": "paragraph", "content": "Renders only when product.metafields.custom.ingredients (richtext) is set. Hidden entirely otherwise." },
      { "type": "text", "id": "heading", "label": "Heading", "default": "Ingredients" },
      { "type": "checkbox", "id": "open_by_default", "label": "Open by default", "default": false }
    ] },
    { "type": "benefits", "name": "Benefits (metafield)", "limit": 1, "settings": [
      { "type": "paragraph", "content": "Renders only when product.metafields.custom.benefits (richtext) is set. Hidden entirely otherwise." },
      { "type": "text", "id": "heading", "label": "Heading", "default": "Benefits" },
      { "type": "checkbox", "id": "open_by_default", "label": "Open by default", "default": false }
    ] },
    { "type": "use_cases", "name": "Use case(s) (metafield)", "limit": 1, "settings": [
      { "type": "paragraph", "content": "Renders only when product.metafields.custom.use_cases (richtext) is set. Hidden entirely otherwise." },
      { "type": "text", "id": "heading", "label": "Heading", "default": "Use case(s)" },
      { "type": "checkbox", "id": "open_by_default", "label": "Open by default", "default": false }
    ] },
    { "type": "rating", "name": "Stars + reviews", "limit": 1, "settings": [] },
    { "type": "sizes", "name": "Size variants", "limit": 1, "settings": [
      { "type": "text", "id": "label", "label": "Label", "default": "Size", "info": "Leave as \"Size\" to auto-use the product's first option name (e.g. \"Scent\", \"Color\"). Override here to force a custom label." },
      { "type": "text", "id": "demo_sizes", "label": "Demo sizes (CSV, single-variant fallback)", "default": "100ml,30ml,Refill" },
      { "type": "number", "id": "demo_active_index", "label": "Active demo size (1-based)", "default": 1 }
    ] },
    { "type": "purchase_options", "name": "Purchase options", "limit": 1, "settings": [
      { "type": "text", "id": "label", "label": "Label", "default": "Purchase options" },
      { "type": "text", "id": "once_label", "label": "One-time label", "default": "One-time purchase" },
      { "type": "text", "id": "subscribe_label", "label": "Subscribe label (auto-suffixed with discount %)", "default": "Subscribe & save" },
      { "type": "text", "id": "cadence_note", "label": "Cadence note", "default": "Skip, swap world, or cancel anytime — no postcards held hostage." },
      { "type": "text", "id": "about_label", "label": "About-subscriptions toggle", "default": "About subscriptions" },
      { "type": "textarea", "id": "about_body", "label": "About-subscriptions body" }
    ] },
    { "type": "qty_and_cta", "name": "Quantity + Add to bag", "limit": 1, "settings": [
      { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Add to bag" },
      { "type": "text", "id": "sold_out_text", "label": "Sold-out text", "default": "Sold out" }
    ] },
    { "type": "refill_link", "name": "Refill link", "limit": 1, "settings": [
      { "type": "text", "id": "text", "label": "Text", "default": "Or refill in store →" },
      { "type": "text", "id": "link", "label": "Link", "default": "/pages/refill" },
      { "type": "checkbox", "id": "always_show", "label": "Show even if not refillable", "default": false }
    ] },
    { "type": "stock_indicator", "name": "Stock indicator", "limit": 1, "settings": [
      { "type": "text", "id": "text", "label": "Text", "default": "• In stock · Ships in 1-2 days" }
    ] },
    { "type": "trust_circles", "name": "Trust circles", "limit": 1, "settings": [
      { "type": "text", "id": "label_1", "label": "Label 1", "default": "Made in SG" },
      { "type": "text", "id": "label_2", "label": "Label 2 (refillable, conditional)", "default": "Refillable" },
      { "type": "text", "id": "label_3", "label": "Label 3", "default": "Cruelty-free" },
      { "type": "text", "id": "label_4", "label": "Label 4", "default": "Vegan" },
      { "type": "checkbox", "id": "always_show_refillable", "label": "Always show refillable", "default": false }
    ] }
  ],
  "presets": [{
    "name": "Default PDP",
    "blocks": [
      { "type": "ribbon" }, { "type": "title" }, { "type": "tags_band" }, { "type": "description" },
      { "type": "ingredients" }, { "type": "benefits" }, { "type": "use_cases" },
      { "type": "rating" }, { "type": "sizes" }, { "type": "purchase_options" }, { "type": "qty_and_cta" },
      { "type": "refill_link" }, { "type": "stock_indicator" }, { "type": "trust_circles" }
    ]
  }]
}
{% endschema %}
