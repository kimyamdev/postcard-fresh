{%- liquid
  assign world_handle = section.settings.world_handle | default: 'hotel-lobby'
  assign world = shop.metaobjects.world[world_handle]
  assign world_name = world.name.value | default: 'Hotel Lobby'
  assign world_slug = world.slug.value | default: 'hotel-lobby'
  assign world_family = world.family.value | default: 'Hesperidic Gourmand'
  assign world_color = world.accent_color.value | default: '#E8C36A'
  assign world_theme_class = world.theme_class.value | default: 'world-hotel-lobby'
  assign world_tagline = world.tagline.value

  assign family_line = section.settings.family_line_override
  if family_line == blank
    if world_tagline != blank
      assign family_line = world_family | append: ' · ' | append: world_tagline
    else
      assign family_line = world_family
    endif
  endif

  assign cta_text = section.settings.cta_text
  if cta_text == blank
    assign cta_text = 'Visit ' | append: world_name | append: ' →'
  endif

  assign cta_url = section.settings.cta_url
  if cta_url == blank
    assign cta_url = '/pages/' | append: world_slug
  endif

  assign bg_alpha = section.settings.bg_alpha | default: 14
  assign media_opacity = section.settings.media_opacity | default: 100

  assign light_badges_mode = section.settings.light_badges_mode | default: 'auto'
  assign light_badges = false
  if light_badges_mode == 'on'
    assign light_badges = true
  elsif light_badges_mode == 'auto'
    assign light_badges = world.light_badges.value
  endif

  assign section_class = 'pc-wotm'
  if light_badges
    assign section_class = section_class | append: ' pc-wotm--light'
  endif
-%}
<section
  class="{{ section_class }}"
  style="--world-color: {{ world_color }}; --world-bg-alpha: {{ bg_alpha }}%; background: color-mix(in srgb, {{ world_color }} {{ bg_alpha }}%, transparent);"
>
  <div class="container pc-wotm__inner">
    <div class="pc-wotm__stamp-wrap">
      {%- assign media_height = section.settings.media_height | default: 90 -%}
      {%- assign media_inset = 100 | minus: media_height | divided_by: 2 -%}
      {%- capture media_style -%}opacity: {{ media_opacity }}%; --media-inset: {{ media_inset }}%;{%- endcapture -%}
      {%- comment -%}
        Resolve media in this order: section-level override → world metaobject's
        hero_video / hero_image → nothing. Switching the World dropdown therefore
        flips the playing video automatically; admin can still upload a different
        video/image on this section if they want a one-off.
      {%- endcomment -%}
      {%- assign final_video = section.settings.media_video -%}
      {%- if final_video == blank -%}
        {%- assign final_video = world.hero_video.value -%}
      {%- endif -%}
      {%- assign final_image = section.settings.media_image -%}
      {%- if final_image == blank -%}
        {%- assign final_image = world.hero_image.value -%}
      {%- endif -%}
      {%- if final_video != blank -%}
        <div class="pc-wotm__media" style="{{ media_style }}">
          {{ final_video | video_tag: image_size: '1100x', autoplay: true, loop: true, muted: true, controls: false, class: 'pc-wotm__media-vid' }}
        </div>
      {%- elsif final_image != blank -%}
        {%- assign media_alt = final_image.alt | default: world_name | escape -%}
        <div class="pc-wotm__media" style="{{ media_style }}">
          {{ final_image | image_url: width: 1100 | image_tag: alt: media_alt, loading: 'lazy', class: 'pc-wotm__media-img' }}
        </div>
      {%- endif -%}
      {%- assign wotm_stamp_img = world.world_stamp.value -%}
      {%- if wotm_stamp_img != blank -%}
        {%- assign wotm_stamp_alt = world_name | append: ' stamp' | escape -%}
        <div class="pc-wotm__stamp-img-wrap">
          {{ wotm_stamp_img | image_url: width: 480 | image_tag: alt: wotm_stamp_alt, loading: 'lazy', class: 'pc-wotm__stamp-img', widths: '240,360,480,720' }}
        </div>
      {%- else -%}
        {% render 'stamp', name: world_name, family: world_family, color: world_color, size: 'lg' %}
      {%- endif -%}
      <span class="postmark pc-wotm__postmark-overlay">
        <div>WORLD<br>OF THE<br>MONTH</div>
      </span>
    </div>
    <div>
      {%- if section.settings.eyebrow != blank -%}
        <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      <h2 class="h-typewriter pc-wotm__title">{{ world_name }}.</h2>
      {%- if family_line != blank -%}
        <p class="pc-wotm__family-line">{{ family_line }}</p>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <div class="pc-wotm__body">{{ section.settings.body }}</div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="pc-wotm__formats">
          {%- for block in section.blocks -%}
            {%- if block.type == 'format' -%}
              {%- assign p = block.settings.product -%}
              {%- assign label = block.settings.label_override -%}
              {%- if label == blank -%}
                {%- assign label = p.title | default: 'Format' -%}
              {%- endif -%}
              {%- assign url = block.settings.link -%}
              {%- if url == blank -%}
                {%- assign url = p.url -%}
              {%- endif -%}
              {%- assign img = block.settings.image -%}
              {%- if img == blank -%}
                {%- assign img = p.featured_image -%}
              {%- endif -%}
              {%- if url != blank -%}
                <a class="pc-wotm__format" href="{{ url }}" {{ block.shopify_attributes }}>
              {%- else -%}
                <div class="pc-wotm__format" {{ block.shopify_attributes }}>
              {%- endif -%}
                <div class="ph ph--world {{ world_theme_class }} pc-wotm__format-img" style="--world-color: {{ world_color }};">
                  {%- if img -%}
                    {{ img | image_url: width: 200 | image_tag: alt: '', loading: 'lazy', class: 'pc-wotm__format-pic' }}
                  {%- endif -%}
                </div>
                <span class="pc-wotm__format-label">{{ label }}</span>
              {%- if url != blank -%}
                </a>
              {%- else -%}
                </div>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if cta_text != blank -%}
        <div class="pc-wotm__cta">
          <a class="btn" href="{{ cta_url }}">{{ cta_text }}</a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "World of the Month",
  "settings": [
    { "type": "select", "id": "world_handle", "label": "World", "default": "hotel-lobby",
      "options": [
        { "value": "hotel-lobby",      "label": "Hotel Lobby" },
        { "value": "moon-bloom",       "label": "Moon Bloom" },
        { "value": "coconut-beach",    "label": "Coconut Beach" },
        { "value": "wild-flowers",     "label": "Wild Flowers" },
        { "value": "bath-house",       "label": "Bath House" },
        { "value": "woodland-retreat", "label": "Woodland Retreat" },
        { "value": "icy-peaks",        "label": "Icy Peaks" }
      ],
      "info": "Name, family, accent color, and slug all flow from the world metaobject."
    },
    { "type": "range", "id": "bg_alpha", "label": "Background tint (%)", "min": 0, "max": 40, "step": 2, "default": 14, "unit": "%", "info": "How strongly the world's accent color tints the section background." },
    { "type": "header", "content": "Stamp area media (optional override)" },
    { "type": "paragraph", "content": "By default this section auto-plays the picked world's Hero video (or shows its Hero image), set under Custom data → Metaobjects → World. The fields below are overrides: leave both blank to use the world's media." },
    { "type": "image_picker", "id": "media_image", "label": "Background image (override)", "info": "Overrides the world's hero_image for this section instance only." },
    { "type": "video",        "id": "media_video", "label": "Background video (override)", "info": "Overrides the world's hero_video. Auto-plays muted + loops. Takes priority over the image if both are set." },
    { "type": "range",        "id": "media_opacity", "label": "Media opacity", "min": 10, "max": 100, "step": 5, "default": 100, "unit": "%", "info": "Lower this to fade the image/video so the stamp + postmark read more clearly." },
    { "type": "range",        "id": "media_height",  "label": "Media height",  "min": 50, "max": 150, "step": 5, "default": 90, "unit": "%", "info": "How much of the column's vertical space the media fills. Above 100% the media bleeds into the section padding (≈full section bleed at 130–150% depending on column height). Stamp + postmark stay centered above it." },
    { "type": "select", "id": "light_badges_mode", "label": "White badge borders", "default": "auto",
      "options": [
        { "value": "auto", "label": "Auto — follow the world's setting" },
        { "value": "on",   "label": "Force on" },
        { "value": "off",  "label": "Force off" }
      ],
      "info": "Each world metaobject has its own 'Light badges' field — set it once per world for dark media. Use Force on/off only as a per-instance override."
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "World deep-dive · This month" },
    { "type": "text", "id": "family_line_override", "label": "Family line override", "info": "Leave blank to auto-compose as 'Family · tagline' from the world metaobject." },
    { "type": "richtext", "id": "body", "label": "Body paragraph", "default": "<p>Polished. Refined. Endlessly elegant. Hotel Lobby opens with the brightness of bergamot and orange blossom, then settles into Earl Grey tea, soft vanilla and a brushed apricot warmth — like the moment you push through a revolving door into somewhere that smells looked-after.</p>" },
    { "type": "header", "content": "CTA" },
    { "type": "text", "id": "cta_text", "label": "Text", "info": "Leave blank to auto-fill with 'Visit {world} →'" },
    { "type": "url",  "id": "cta_url",  "label": "Link", "info": "Leave blank to auto-link to /pages/{world slug}" }
  ],
  "blocks": [
    { "type": "format", "name": "Format chip", "settings": [
      { "type": "product",      "id": "product",        "label": "Product",         "info": "Optional. If set, label/image/link auto-fill from this product. Leave blank to use manual fields below." },
      { "type": "text",         "id": "label_override", "label": "Label override" },
      { "type": "image_picker", "id": "image",          "label": "Image override" },
      { "type": "url",          "id": "link",           "label": "Link override" }
    ] }
  ],
  "max_blocks": 8,
  "presets": [{
    "name": "World of the Month",
    "blocks": [
      { "type": "format", "settings": { "label_override": "Anywhere Fragrance" } },
      { "type": "format", "settings": { "label_override": "Hand & Body Wash" } },
      { "type": "format", "settings": { "label_override": "Deodorant Spray" } },
      { "type": "format", "settings": { "label_override": "Reed Diffuser" } }
    ]
  }]
}
{% endschema %}
