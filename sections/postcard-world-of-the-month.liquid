<section class="pc-wotm">
  <div class="container pc-wotm__inner">
    <div class="pc-wotm__stamp-wrap">
      {% render 'stamp', name: 'Hotel Lobby', family: 'Hesperidic Gourmand', color: '#E8C36A', size: 'lg' %}
      <span class="postmark pc-wotm__postmark-overlay">
        <div>WORLD<br>OF THE<br>MONTH</div>
      </span>
    </div>
    <div>
      <div class="eyebrow">World deep-dive &middot; This month</div>
      <h2 class="h-typewriter pc-wotm__title">Hotel Lobby.</h2>
      <p class="pc-wotm__family-line">Hesperidic Gourmand &middot; A bright cup of bergamot with a soft lobby of vanilla.</p>
      <p class="pc-wotm__body">
        Polished. Refined. Endlessly elegant. Hotel Lobby opens with the brightness of bergamot and orange blossom, then settles into Earl Grey tea, soft vanilla and a brushed apricot warmth &mdash; like the moment you push through a revolving door into somewhere that smells looked-after.
      </p>
      <div class="pc-wotm__formats">
        <div class="pc-wotm__format">
          <div class="ph ph--world world-hotel-lobby pc-wotm__format-img"></div>
          Anywhere Fragrance
        </div>
        <div class="pc-wotm__format">
          <div class="ph ph--world world-hotel-lobby pc-wotm__format-img"></div>
          Hand &amp; Body Wash
        </div>
        <div class="pc-wotm__format">
          <div class="ph ph--world world-hotel-lobby pc-wotm__format-img"></div>
          Deodorant Spray
        </div>
        <div class="pc-wotm__format">
          <div class="ph ph--world world-hotel-lobby pc-wotm__format-img"></div>
          Reed Diffuser
        </div>
      </div>
      {%- if section.settings.cta_text != blank -%}
        <div class="pc-wotm__cta">
          <a class="btn" href="{{ section.settings.cta_url | default: '/pages/hotel-lobby' }}">{{ section.settings.cta_text }}</a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "World of the Month",
  "settings": [
    { "type": "header", "content": "CTA" },
    { "type": "text", "id": "cta_text", "label": "Text", "default": "Visit Hotel Lobby →" },
    { "type": "url",  "id": "cta_url",  "label": "Link" }
  ],
  "presets": [{ "name": "World of the Month" }]
}
{% endschema %}
