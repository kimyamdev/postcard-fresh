{{ 'postcard-components.css' | asset_url | stylesheet_tag }}

<footer class="pc-footer">
  <div class="container">
    <div class="pc-footer__grid">
      <div>
        <div class="h-display pc-footer__newsletter-title">POSTCARDS<br>IN YOUR INBOX.</div>
        <p class="pc-footer__newsletter-blurb">New worlds, refill news, occasional treats. No spam &mdash; promise.</p>
        {%- form 'customer', class: 'pc-footer__newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input type="email" name="contact[email]" placeholder="your@email.com" class="pc-footer__newsletter-input" required>
          <button type="submit" class="btn btn--small" style="box-shadow: 3px 3px 0 var(--color-yellow);">Send &rarr;</button>
        {%- endform -%}
        <div class="pc-footer__newsletter-incentive">Sign up &amp; get $10 off your first $50.</div>
      </div>
      <div>
        <div class="eyebrow pc-footer__col-title">Shop</div>
        <a class="pc-footer__link" href="/collections/all">All products</a>
        <a class="pc-footer__link" href="/collections/bestsellers">Bestsellers</a>
        <a class="pc-footer__link" href="/collections/new-and-limited">New &amp; limited</a>
        <a class="pc-footer__link" href="/collections/gifts">Gifts</a>
        <a class="pc-footer__link" href="/collections/discovery">Discovery</a>
        <a class="pc-footer__link" href="/pages/custom">Custom</a>
        <a class="pc-footer__link" href="/collections/refills">Refills</a>
      </div>
      {%- liquid
        assign worlds_all = shop.metaobjects.world.values
        assign world_total = 0
        for w in worlds_all
          if w.tier.value == 'World'
            assign world_total = world_total | plus: 1
          endif
        endfor
        assign worlds_visible = section.settings.worlds_visible | default: 5
      -%}
      <div>
        <div class="eyebrow pc-footer__col-title">{{ section.settings.worlds_heading | default: 'Worlds' }}</div>
        {%- assign emitted = 0 -%}
        {%- for w in worlds_all -%}
          {%- if w.tier.value != 'World' -%}{%- continue -%}{%- endif -%}
          {%- if emitted >= worlds_visible -%}{%- break -%}{%- endif -%}
          {%- assign w_slug = w.slug.value | default: w.handle -%}
          <a class="pc-footer__link" href="/pages/{{ w_slug }}">{{ w.name.value }}</a>
          {%- assign emitted = emitted | plus: 1 -%}
        {%- endfor -%}
        {%- assign see_all_text = section.settings.worlds_see_all | default: 'See all [count] →' | replace: '[count]', world_total -%}
        <a class="pc-footer__link" href="{{ section.settings.worlds_see_all_url | default: '/pages/worlds' }}">{{ see_all_text }}</a>
      </div>
      <div>
        <div class="eyebrow pc-footer__col-title">Discover</div>
        <a class="pc-footer__link" href="/pages/about">About</a>
        <a class="pc-footer__link" href="/pages/membership">Membership</a>
        <a class="pc-footer__link" href="/pages/refill">Refill</a>
        <a class="pc-footer__link" href="/pages/flagship">Visit Orchard flagship</a>
        <a class="pc-footer__link" href="/pages/corporate">Corporate</a>
        <a class="pc-footer__link" href="/pages/workshops">Workshops</a>
        <a class="pc-footer__link" href="/blogs/journal">Journal</a>
      </div>
      <div>
        <div class="eyebrow pc-footer__col-title">Help &amp; Legal</div>
        <a class="pc-footer__link" href="/pages/shipping">Shipping</a>
        <a class="pc-footer__link" href="/pages/returns">Returns</a>
        <a class="pc-footer__link" href="/pages/refill-faq">Refill FAQ</a>
        <a class="pc-footer__link" href="/pages/contact">Contact</a>
        <a class="pc-footer__link" href="/policies/terms-of-service">Terms</a>
        <a class="pc-footer__link" href="/policies/privacy-policy">Privacy</a>
        <a class="pc-footer__link" href="/pages/accessibility">Accessibility</a>
      </div>
    </div>
    <div class="pc-footer__bottom">
      <div class="pc-footer__badges">
        <span class="pc-footer__badge">&middot; Made in Singapore &middot;</span>
        <span class="pc-footer__badge">&middot; Refillable &middot;</span>
        <span class="pc-footer__badge">&middot; Cruelty-free &middot;</span>
        <span class="pc-footer__badge">&middot; Vegan-where-possible &middot;</span>
      </div>
      <div class="pc-footer__copy">
        &copy; {{ 'now' | date: '%Y' }} POSTCARD &middot; Life supplies, forever yours.
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "header", "content": "Worlds column" },
    { "type": "text", "id": "worlds_heading", "label": "Heading", "default": "Worlds" },
    { "type": "range", "id": "worlds_visible", "label": "Worlds to show", "min": 0, "max": 12, "step": 1, "default": 5, "info": "Pulls tier-World metaobjects in admin order." },
    { "type": "text", "id": "worlds_see_all", "label": "See-all text", "default": "See all [count] →", "info": "[count] is replaced with the total tier-World worlds." },
    { "type": "url", "id": "worlds_see_all_url", "label": "See-all URL" }
  ]
}
{% endschema %}
