<section class="section">
  <div class="container">
    <div class="pc-bestsellers__intro">
      <div class="eyebrow">The classics</div>
      <h2 class="h-display pc-bestsellers__title">Postcards we send most often.</h2>
      <p class="pc-bestsellers__lede">The ones you keep coming back to. Sent 1,200+ times in the last 95 days.</p>
    </div>
    <div class="pc-bestsellers__grid">
      {% render 'product-card',
        name: 'Hotel Lobby Anywhere Fragrance',
        world: 'Hotel Lobby',
        world_color: '#E8C36A',
        price: '$42',
        badge: '#1 bestseller',
        href: '/products/hotel-lobby-anywhere-fragrance' %}
      {% render 'product-card',
        name: 'Moon Bloom Anywhere Fragrance',
        world: 'Moon Bloom',
        world_color: '#5C6688',
        price: '$42',
        badge: 'Top sleep scent',
        href: '/products/moon-bloom-anywhere-fragrance' %}
      {% render 'product-card',
        name: 'Hotel Lobby Hand & Body Wash',
        world: 'Hotel Lobby',
        world_color: '#E8C36A',
        price: '$32',
        badge: 'Refillable',
        href: '/products/hotel-lobby-hand-and-body-wash' %}
    </div>
    <div class="pc-bestsellers__more">
      <a class="tlink" href="/collections/bestsellers">See all bestsellers &rarr;</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Postcard Bestsellers",
  "settings": [],
  "presets": [{ "name": "Postcard Bestsellers" }]
}
{% endschema %}
