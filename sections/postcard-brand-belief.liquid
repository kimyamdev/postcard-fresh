<section class="section pc-belief">
  <div class="container pc-belief__inner">
    <div class="ph pc-belief__photo"><span>Hildra &middot; in the beauty kitchen</span></div>
    <div>
      <div class="eyebrow">Made by humans, in Singapore.</div>
      <h2 class="h-display pc-belief__title">Do more with less.</h2>
      <p class="pc-belief__p">
        Postcard started in 2019 &mdash; first as a refillery in Everton Park, then as a brand built around a question: what if self-care was simpler, kinder, and a little bit playful?
      </p>
      <p class="pc-belief__p">
        We mix, pour, and pack everything ourselves. Refill where we can. Source from local farms and distilleries. Painstakingly fuss until it&rsquo;s perfect.
      </p>
      {%- if section.settings.cta_text != blank -%}
        <div class="pc-belief__cta">
          <a class="tlink" href="{{ section.settings.cta_url | default: '/pages/about' }}">{{ section.settings.cta_text }}</a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Postcard Brand Belief",
  "settings": [
    { "type": "header", "content": "CTA" },
    { "type": "text", "id": "cta_text", "label": "Text", "default": "Read our story →" },
    { "type": "url",  "id": "cta_url",  "label": "Link" }
  ],
  "presets": [{ "name": "Postcard Brand Belief" }]
}
{% endschema %}
