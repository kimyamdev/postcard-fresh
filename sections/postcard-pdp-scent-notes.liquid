{%- liquid
  assign world = product.metafields.postcard.world.value
  assign world_color = world.accent_color.value | default: '#E8C36A'
  assign world_family_metaobj = world.family.value
  assign notes_list = world.scent_notes.value
  assign family_label = section.settings.family | default: world_family_metaobj | default: ''
-%}
<section class="section pc-sn">
  <div class="container">
    <div class="pc-sn__head">
      {%- if family_label != blank -%}
        <span class="pc-sn__pill" style="background: {{ world_color }}1f;">{{ family_label }}</span>
      {%- endif -%}
      <h2 class="h-display pc-sn__title">{{ section.settings.title }}</h2>
    </div>

    {%- if notes_list and notes_list.size > 0 -%}
      <div class="pc-sn__grid">
        {%- for note in notes_list -%}
          {%- assign n_name = note.name.value -%}
          {%- assign n_sub = note.subline.value -%}
          {%- assign n_color = note.color.value | default: world_color -%}
          {%- assign n_icon = note.icon.value -%}
          <div class="stamp-frame stamp-side pc-sn__card">
            <div class="pc-sn__icon" style="background: {{ n_color }}33; border-color: var(--color-ink);">
              {%- if n_icon -%}
                {%- assign icon_alt = n_name | escape -%}
                {{ n_icon | image_url: width: 96 | image_tag: alt: icon_alt, class: 'pc-sn__icon-img' }}
              {%- else -%}
                <span class="pc-sn__icon-letters" style="color: var(--color-ink);">
                  {%- assign words = n_name | split: ' ' -%}
                  {%- for w in words limit: 2 -%}{{ w | slice: 0, 1 | upcase }}{%- endfor -%}
                </span>
              {%- endif -%}
            </div>
            <div class="h-display pc-sn__name">{{ n_name }}</div>
            {%- if n_sub != blank -%}<div class="pc-sn__sub">{{ n_sub }}</div>{%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="pc-sn__empty">
        <p>This world has no scent notes configured. Add entries via Settings &rarr; Custom data &rarr; Metaobjects &rarr; Scent Note, then link them on the world&rsquo;s <code>scent_notes</code> field.</p>
      </div>
    {%- endif -%}

    {%- if section.settings.tagline != blank -%}
      <p class="pc-sn__tagline">{{ section.settings.tagline }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Scent notes",
  "settings": [
    { "type": "text", "id": "family", "label": "Family pill (override)" },
    { "type": "text", "id": "title", "label": "Title", "default": "What it smells like." },
    { "type": "textarea", "id": "tagline", "label": "Tagline", "default": "Smells like… a sunlit lobby with polished brass and warm pastries." }
  ],
  "presets": [{ "name": "Scent notes" }]
}
{% endschema %}
