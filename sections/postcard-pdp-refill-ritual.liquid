<section class="section pc-rh">
  <div class="container">
    <div class="pc-rh__head">
      <div class="eyebrow pc-rh__eyebrow">Two ways to refill</div>
      <h2 class="h-display pc-rh__title">How a refill works.</h2>
    </div>
    <div class="pc-rh__split">
      <div class="pc-rh__col pc-rh__col--store">
        <div class="pc-rh__col-head">
          <span class="postmark pc-rh__pm pc-rh__pm--yellow"><div>IN<br>STORE</div></span>
          <div class="h-display pc-rh__col-title pc-rh__col-title--yellow">At the counter.</div>
        </div>
        <ol class="pc-rh__steps">
          <li class="pc-rh__step">
            <span class="pc-rh__num pc-rh__num--yellow">1</span>
            <div>
              <div class="pc-rh__step-h">Bring your bottle.</div>
              <p class="pc-rh__step-p">Any of ours. Any age. Even if the label has faded.</p>
            </div>
          </li>
          <li class="pc-rh__step">
            <span class="pc-rh__num pc-rh__num--yellow">2</span>
            <div>
              <div class="pc-rh__step-h">We weigh &amp; wash.</div>
              <p class="pc-rh__step-p">Empty + clean. You watch.</p>
            </div>
          </li>
          <li class="pc-rh__step">
            <span class="pc-rh__num pc-rh__num--yellow">3</span>
            <div>
              <div class="pc-rh__step-h">Choose your world.</div>
              <p class="pc-rh__step-p">22 to pick from. Switch worlds anytime.</p>
            </div>
          </li>
          <li class="pc-rh__step">
            <span class="pc-rh__num pc-rh__num--yellow">4</span>
            <div>
              <div class="pc-rh__step-h">Pour, cap, pay.</div>
              <p class="pc-rh__step-p">S$18 for 300ml. Walk out in under 5 minutes.</p>
            </div>
          </li>
        </ol>
        <a class="btn btn--small pc-rh__cta pc-rh__cta--yellow" href="/pages/refill">Find a refill counter &rarr;</a>
      </div>
      <div class="pc-rh__col">
        <div class="pc-rh__col-head">
          <span class="postmark pc-rh__pm"><div>BY<br>POST</div></span>
          <div class="h-display pc-rh__col-title">Mailed home.</div>
        </div>
        <ol class="pc-rh__steps">
          <li class="pc-rh__step">
            <span class="pc-rh__num">1</span>
            <div>
              <div class="pc-rh__step-h">Order an aluminium pouch.</div>
              <p class="pc-rh__step-p">500ml or 1L. Reusable, returnable, recyclable.</p>
            </div>
          </li>
          <li class="pc-rh__step">
            <span class="pc-rh__num">2</span>
            <div>
              <div class="pc-rh__step-h">Decant at home.</div>
              <p class="pc-rh__step-p">Slow pour through the spout. Takes 30 seconds.</p>
            </div>
          </li>
          <li class="pc-rh__step">
            <span class="pc-rh__num">3</span>
            <div>
              <div class="pc-rh__step-h">Drop the empty in any postbox.</div>
              <p class="pc-rh__step-p">Pre-paid return label. We sterilise &amp; reuse.</p>
            </div>
          </li>
          <li class="pc-rh__step">
            <span class="pc-rh__num">4</span>
            <div>
              <div class="pc-rh__step-h">Earn coins back.</div>
              <p class="pc-rh__step-p">+50 coins per pouch returned. Club tier members get +75.</p>
            </div>
          </li>
        </ol>
        <a class="btn btn--small pc-rh__cta" href="/products/refill-pouch">Add a pouch &middot; S$18 &rarr;</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Refill ritual",
  "settings": [],
  "presets": [{ "name": "Refill ritual" }]
}
{% endschema %}
