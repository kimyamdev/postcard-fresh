{%- comment -%}
  Mix and Match — build-a-bundle of N items, one chosen from each manually
  curated group. Each "group" block hand-picks its products via a product list.
  On add-to-cart, every chosen variant is added as its own line item and an
  optional discount code is auto-applied via /cart/update.js. Cart refresh +
  drawer open reuse the global window.PostcardCart helper (assets/postcard-cart.js).
{%- endcomment -%}

{%- liquid
  assign groups = section.blocks | where: 'type', 'group'
  assign group_count = groups.size
  assign cta_label = section.settings.cta_label | default: 'Add bundle to cart'
  assign bundle_label = section.settings.bundle_label | default: 'Mix & Match'
  assign discount_type = section.settings.discount_type | default: 'none'
  assign discount_value = section.settings.discount_value | default: '0'
-%}

<section
  class="section mix-and-match{% if section.settings.card_gradient %} mm--card-gradient{% endif %}"
  data-section-id="{{ section.id }}"
>
  {%- style -%}
    .mix-and-match {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  {%- endstyle -%}

  <mix-and-match
    class="container mm"
    data-discount-type="{{ discount_type }}"
    data-discount-value="{{ discount_value | escape }}"
    data-bundle-label="{{ bundle_label | escape }}"
    data-group-count="{{ group_count }}"
    data-money-format="{{ shop.money_format | escape }}"
  >
    <header class="mm__head">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow mm__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="mm__title h-display">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <div class="mm__intro rte">{{ section.settings.intro }}</div>
      {%- endif -%}
    </header>

    {%- for block in groups -%}
      {%- liquid
        assign gi = forloop.index
        assign products = block.settings.products
        if products.size == 0 and block.settings.collection != blank
          assign products = block.settings.collection.products
        endif
        comment
          Optional variant-level curation: paste variant IDs (newline or comma
          separated). When set, the group shows exactly those variants (one card
          each, no dropdown) drawn from the products/collection above.
        endcomment
        assign allowed_raw = block.settings.variant_ids | newline_to_br | replace: '<br />', ',' | replace: ' ', ''
        assign allowed_list = allowed_raw | split: ','
        assign allowed_str = ''
        for av in allowed_list
          if av != blank
            assign allowed_str = allowed_str | append: ',' | append: av | append: ','
          endif
        endfor
        assign variant_mode = false
        if allowed_str != ''
          assign variant_mode = true
        endif
      -%}
      <div class="mm-group" data-mm-group="{{ forloop.index0 }}" data-mm-group-title="{{ block.settings.title | default: 'Choose an item' | escape }}" {{ block.shopify_attributes }}>
        <div class="mm-group__head">
          <span class="mm-group__step">{{ gi }}</span>
          <div>
            <h2 class="mm-group__title h-typewriter">{{ block.settings.title | default: 'Choose an item' }}</h2>
            {%- if block.settings.subtitle != blank -%}
              <p class="mm-group__subtitle">{{ block.settings.subtitle }}</p>
            {%- endif -%}
          </div>
          <span class="mm-group__status" data-mm-group-status>Not selected</span>
        </div>

        {%- if products.size == 0 -%}
          <p class="mm-group__empty">No products in this group yet. Edit this block in the theme editor to pick products or choose a collection.</p>
        {%- else -%}
          <div class="mm-group__carousel">
            <button type="button" class="mm-group__arrow mm-group__arrow--prev" data-mm-prev aria-label="Scroll left" hidden>&lsaquo;</button>
            <div class="mm-group__track" data-mm-track>
            {%- if variant_mode -%}
              {%- for product in products limit: 48 -%}
                {%- for variant in product.variants -%}
                  {%- assign vtoken = ',' | append: variant.id | append: ',' -%}
                  {%- if allowed_str contains vtoken -%}
                    {%- render 'mix-and-match-card', product: product, variant: variant -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endfor -%}
            {%- else -%}
              {%- for product in products limit: 48 -%}
                {%- render 'mix-and-match-card', product: product -%}
              {%- endfor -%}
            {%- endif -%}
            </div>
            <button type="button" class="mm-group__arrow mm-group__arrow--next" data-mm-next aria-label="Scroll right" hidden>&rsaquo;</button>
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}

    <div class="mm-summary" data-mm-summary>
      <span class="mm-summary__tag">{{ bundle_label }} bundle</span>
      <button type="button" class="mm-summary__toggle" data-mm-summary-toggle aria-expanded="true">
        <span data-mm-summary-toggle-text>Minimize</span>
      </button>
      <div class="mm-summary__progress" aria-label="Selected groups">
        {%- for block in groups -%}
          <span class="mm-summary__dot" data-mm-summary-dot="{{ forloop.index0 }}" aria-label="{{ block.settings.title | default: 'Group' | escape }} not selected"></span>
        {%- endfor -%}
      </div>
      <div class="mm-summary__slots" data-mm-slots>
        {%- for block in groups -%}
          <div class="mm-summary__slot" data-mm-slot="{{ forloop.index0 }}">
            <span class="mm-summary__slot-thumb" data-mm-slot-thumb aria-hidden="true"></span>
            <span class="mm-summary__slot-text">
              <span class="mm-summary__slot-label">{{ block.settings.title | default: 'Item' }}</span>
              <span class="mm-summary__slot-value" data-mm-slot-value>—</span>
            </span>
          </div>
        {%- endfor -%}
      </div>
      <div class="mm-summary__total is-hidden" data-mm-total-block>
        <span class="mm-summary__total-label">Bundle total</span>
        <span class="mm-summary__total-line">
          <span class="mm-summary__total-was" data-mm-was hidden></span>
          <span class="mm-summary__total-value" data-mm-total>—</span>
        </span>
        <span class="mm-summary__save" data-mm-save hidden></span>
      </div>
      <button type="button" class="btn mm-summary__cta" data-mm-add disabled>
        <span data-mm-cta-text>{{ cta_label }}</span>
      </button>
      <p class="mm-summary__error" data-mm-error hidden></p>
    </div>
  </mix-and-match>
</section>

{%- stylesheet -%}
{%- endstylesheet -%}

<style>
  .mm { display: block; }
  .mm__head { text-align: center; max-width: 46rem; margin: 0 auto 56px; }
  .mm__eyebrow { margin: 0 0 10px; }
  .mm__title { margin: 0 0 14px; font-size: clamp(34px, 6vw, 60px); }
  .mm__intro { font-family: var(--font-body); font-size: 16px; color: var(--color-ink); opacity: 0.8; }
  .mm__intro p { margin: 0; }

  .mm-group { margin-bottom: 48px; }
  .mm-group__head {
    display: flex;
    align-items: center;
    gap: 14px;
    padding-bottom: 14px;
    margin-bottom: 22px;
    border-bottom: 1.5px solid var(--color-ink);
  }
  .mm-group__step {
    flex: 0 0 auto;
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
    background: var(--color-yellow);
    border: 1.5px solid var(--color-ink);
    box-shadow: 2px 2px 0 var(--color-ink);
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: 16px;
  }
  .mm-group__title { font-size: 22px; }
  .mm-group__subtitle { margin: 3px 0 0; font-family: var(--font-body); font-size: 14px; color: var(--color-ink); opacity: 0.7; }
  .mm-group__status {
    margin-left: auto;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 11px;
    opacity: 0.55;
  }
  .mm-group.is-complete .mm-group__status { opacity: 1; }
  .mm-group.is-complete .mm-group__status::before { content: '✓ '; color: var(--color-ink); }
  .mm-group__empty { font-family: var(--font-body); font-size: 14px; opacity: 0.6; }

  /* Horizontal carousel per group — swipe / scroll instead of vertical wrapping */
  .mm-group__carousel { display: flex; align-items: center; gap: 8px; }
  .mm-group__track {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    gap: 18px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    justify-content: safe center;
    padding: 6px 2px;            /* room so the selected stamp shadow isn't clipped */
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  .mm-group__track::-webkit-scrollbar { display: none; }
  .mm-group__arrow {
    flex: 0 0 auto;
    width: 40px;
    height: 40px;
    display: grid;
    place-items: center;
    border: 1.5px solid var(--color-ink);
    background: var(--color-bg-card);
    box-shadow: 2px 2px 0 var(--color-ink);
    font-family: var(--font-display);
    font-size: 22px;
    line-height: 1;
    color: var(--color-ink);
    transition: transform 0.1s ease, box-shadow 0.1s ease;
  }
  .mm-group__arrow:hover { transform: translate(-1px, -1px); box-shadow: 3px 3px 0 var(--color-ink); }
  .mm-group__arrow[hidden] { display: none; }
  .mm-group__arrow:disabled { opacity: 0.3; cursor: not-allowed; box-shadow: none; transform: none; }
  @media (max-width: 749px) {
    /* Arrows hidden on touch — swipe instead */
    .mm-group__arrow { display: none; }
  }

  .mm-card {
    position: relative;
    flex: 0 0 240px;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    border: 1.5px solid var(--color-ink);
    background: var(--color-bg-card);
    cursor: pointer;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }
  .mm-card:hover { transform: translate(-2px, -2px); box-shadow: var(--shadow-stamp); }
  .mm-card:focus-visible { outline: 2px solid var(--color-ink); outline-offset: 3px; }
  .mm-card.is-selected { box-shadow: var(--shadow-stamp); transform: translate(-2px, -2px); }
  .mm-card--soldout { opacity: 0.5; cursor: not-allowed; }
  .mm-card--soldout:hover { transform: none; box-shadow: none; }

  .mm-card__media {
    position: relative;
    isolation: isolate;
    aspect-ratio: 1 / 1;
    flex: 0 0 auto;
    min-height: 0;
    overflow: hidden;
    background: var(--color-bg-warm);
    border-bottom: 1.5px solid var(--color-ink);
  }
  /* Absolutely positioned so the image can't dictate the frame height —
     aspect-ratio alone controls it, keeping every frame an equal square. */
  .mm-card__media > img, .mm-card__placeholder {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  /* Optional: subtle world-accent gradient behind a contained product image
     (matches the .ph--world soft radial tint used on landing/collection cards) */
  .mm--card-gradient .mm-card__media {
    background:
      radial-gradient(circle at 30% 20%, color-mix(in oklab, var(--world-c, var(--color-yellow)) 38%, var(--color-bg)) 0%, var(--color-bg-warm) 62%),
      repeating-linear-gradient(135deg, rgba(33, 32, 32, 0.04) 0 8px, rgba(33, 32, 32, 0.08) 8px 16px);
  }
  .mm--card-gradient .mm-card__media > img,
  .mm--card-gradient .mm-card__placeholder {
    object-fit: contain;
    padding: 12%;
  }
  .mm-card__check {
    position: absolute;
    top: 74px;
    left: 10px;
    z-index: 4;
    width: 28px;
    height: 28px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: var(--color-ink);
    color: var(--color-bg);
    border: 1.5px solid var(--color-bg-card);
    opacity: 0;
    transform: scale(0.5) rotate(-12deg);
    transition: opacity 0.15s ease, transform 0.15s ease;
  }
  .mm-card.is-selected .mm-card__check { opacity: 1; transform: scale(1) rotate(-8deg); }
  .mm-card__family {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 5;
    width: 58px;
    height: 58px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px;
    border-radius: 50%;
    border: 1.5px solid var(--color-ink);
    background: var(--world-c, var(--color-yellow));
    color: var(--color-ink);
    font-family: "Special Elite", var(--font-display), monospace;
    font-size: 8px;
    line-height: 1.05;
    letter-spacing: 0;
    text-align: center;
    text-transform: uppercase;
    transform: rotate(-7deg);
    overflow-wrap: anywhere;
    pointer-events: none;
  }
  /* World stamp — small postmark seal, top-right of the image */
  .mm-card__world {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 5 !important;
    width: 42px;
    height: 42px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    border: 1.5px solid var(--color-ink);
    background: var(--world-c, #E8C36A);
    box-shadow: 1px 1px 0 var(--color-ink);
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: 12px;
    letter-spacing: 0.04em;
    line-height: 1;
    text-align: center;
    transform: rotate(var(--stamp-rot, -8deg));
  }
  /* When the world has an uploaded stamp image, show it as-is (no circle/accent) */
  .mm-card__world--img {
    display: block !important;
    width: 58px !important;
    height: auto !important;
    min-height: 0 !important;
    border: 0 !important;
    border-radius: 0 !important;
    background: transparent !important;
    box-shadow: none !important;
    transform: rotate(var(--stamp-rot, -6deg));
    transform-origin: 55% 45%;
    pointer-events: none;
  }
  .mm-card__world-img {
    display: block !important;
    position: static !important;
    inset: auto !important;
    width: 100% !important;
    height: auto !important;
    max-width: none !important;
    object-fit: contain !important;
    filter: none !important;
  }
  .mm-card__soldout {
    position: absolute;
    inset: auto 0 0 0;
    text-align: center;
    background: var(--color-ink);
    color: var(--color-bg);
    font-family: var(--font-display);
    font-size: 11px;
    padding: 4px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .mm-card__body { padding: 14px; display: flex; flex-direction: column; gap: 8px; flex: 1 1 auto; }
  .mm-card__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 14px;
    line-height: 1.25;
    /* Reserve two lines so price/variant/select align across cards regardless of title length */
    min-height: calc(14px * 1.25 * 2);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .mm-card__variant-label { margin: -2px 0 0; font-family: var(--font-display); font-size: 12px; opacity: 0.6; }
  .mm-card__price { margin: 0; display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; }
  .mm-card__price-now { font-family: var(--font-display); font-size: 15px; }
  .mm-card__price-was { font-family: var(--font-display); font-size: 12px; text-decoration: line-through; opacity: 0.5; }
  .mm-card__variant select {
    width: 100%;
    padding: 8px 10px;
    font-family: var(--font-display);
    font-size: 12px;
    border: 1.5px solid var(--color-ink);
    border-radius: 0;
    background: var(--color-bg);
    color: var(--color-ink);
    appearance: none;
    background-image: linear-gradient(45deg, transparent 50%, var(--color-ink) 50%), linear-gradient(135deg, var(--color-ink) 50%, transparent 50%);
    background-position: calc(100% - 14px) 50%, calc(100% - 9px) 50%;
    background-size: 5px 5px, 5px 5px;
    background-repeat: no-repeat;
  }
  .mm-card__select {
    margin-top: auto;
    text-align: center;
    font-family: var(--font-display);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 8px;
    border: 1.5px solid var(--color-ink);
    background: var(--color-bg);
    transition: background 0.12s ease, color 0.12s ease;
  }
  .mm-card:hover .mm-card__select { background: var(--color-ink); color: var(--color-bg); }
  .mm-card.is-selected .mm-card__select { background: var(--color-ink); color: var(--color-bg); }
  .mm-card.is-selected .mm-card__select::after { content: 'ed'; }

  /* Fixed vertical side panel (expandable / minimizable) */
  .mm-summary {
    position: fixed;
    top: 50%;
    right: 16px;
    transform: translateY(-50%);
    z-index: 50;
    width: 300px;
    max-width: calc(100vw - 32px);
    max-height: calc(100vh - 32px);
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 14px;
    padding: 20px;
    background: var(--color-bg-card);
    border: 1.5px solid var(--color-ink);
    box-shadow: var(--shadow-stamp-lg);
    overflow-y: auto;
  }
  .mm-summary__toggle {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 26px;
    height: 26px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: 1.5px solid var(--color-ink);
    background: var(--color-bg-card);
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: 16px;
    line-height: 1;
    cursor: pointer;
  }
  .mm-summary__toggle:hover { background: var(--color-ink); color: var(--color-bg); }
  .mm-summary__tag {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    align-self: flex-start;
    font-family: var(--font-display);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 4px 12px;
    background: var(--color-ink);
    color: var(--color-bg);
    padding-right: 12px;
  }
  .mm-summary__tag::before { content: '✦'; color: var(--color-yellow); }
  .mm-summary__progress {
    display: none;
    align-items: center;
    gap: 6px;
  }
  .mm-summary__dot {
    width: 18px;
    height: 18px;
    display: block;
    border: 1.5px solid var(--color-ink);
    background: var(--color-bg);
    box-shadow: 1px 1px 0 var(--color-ink);
  }
  .mm-summary__dot.is-filled {
    background: #6E8B5C;
  }
  .mm-summary__slots { display: flex; flex-direction: column; gap: 12px; }
  .mm-summary__slot { display: flex; flex-direction: row; align-items: center; gap: 10px; }
  .mm-summary__slot-thumb {
    position: relative;
    flex: 0 0 auto;
    width: 42px;
    height: 42px;
    border: 1.5px solid var(--color-ink);
    background: var(--color-bg-warm);
  }
  .mm-summary__slot-thumb:empty { display: none; }
  .mm-summary__thumb-img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .mm-summary__thumb-stamp {
    position: absolute;
    top: -7px;
    right: -7px;
    width: 24px;
    height: auto;
    transform: rotate(-8deg);
  }
  .mm-summary__thumb-seal {
    position: absolute;
    top: -7px;
    right: -7px;
    width: 20px;
    height: 20px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    border: 1px solid var(--color-ink);
    background: var(--world-c, #E8C36A);
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: 8px;
    line-height: 1;
    transform: rotate(-8deg);
  }
  .mm-summary__slot-text { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
  .mm-summary__slot-label { font-family: var(--font-display); font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.55; }
  .mm-summary__slot-value { font-family: var(--font-display); font-size: 14px; opacity: 0.4; }
  .mm-summary__slot.is-filled .mm-summary__slot-value { opacity: 1; }
  .mm-summary__total { display: flex; flex-direction: column; gap: 2px; padding-top: 12px; border-top: 1.5px solid var(--color-line); }
  .mm-summary__total.is-hidden { display: none; }
  .mm-summary__total-label { font-family: var(--font-display); font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.55; }
  .mm-summary__total-line { display: inline-flex; align-items: baseline; gap: 8px; }
  .mm-summary__total-was { font-family: var(--font-display); font-size: 14px; text-decoration: line-through; opacity: 0.5; }
  .mm-summary__total-value { font-family: var(--font-headline); font-size: 30px; letter-spacing: 0.02em; }
  .mm-summary__save {
    align-self: flex-start;
    font-family: var(--font-display);
    font-size: 12px;
    padding: 1px 6px;
    background: var(--color-yellow);
    border: 1.5px solid var(--color-ink);
  }
  .mm-summary__discount-note { font-family: var(--font-body); font-size: 11px; opacity: 0.65; }
  .mm-summary__cta { width: 100%; justify-content: center; white-space: nowrap; }
  .mm-summary__cta[disabled] { opacity: 0.4; cursor: not-allowed; box-shadow: none; transform: none; }
  .mm-summary__cta[disabled]:hover { transform: none; box-shadow: none; }
  .mm-summary__error { margin: 0; font-family: var(--font-body); color: #B3261E; font-size: 13px; }

  /* Minimized = slim vertical tab docked to the right edge */
  .mm-summary.is-collapsed {
    width: auto;
    max-height: none;
    padding: 14px 8px;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    overflow: visible;
    cursor: pointer;
  }
  .mm-summary.is-collapsed .mm-summary__slots,
  .mm-summary.is-collapsed .mm-summary__total,
  .mm-summary.is-collapsed .mm-summary__cta,
  .mm-summary.is-collapsed .mm-summary__error {
    display: none;
  }
  .mm-summary.is-collapsed .mm-summary__tag {
    order: 1;
    writing-mode: vertical-rl;
    align-self: center;
    padding: 10px 4px;
    letter-spacing: 0.16em;
  }
  .mm-summary.is-collapsed .mm-summary__progress {
    order: 2;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .mm-summary.is-collapsed .mm-summary__toggle {
    order: 3;
    position: static;
  }

  @media (max-width: 749px) {
    /* Stay a right-edge vertical bar (like desktop), just sized for small screens.
       Minimized = slim vertical tab; expanded = narrower right-side panel. */
    .mm-summary {
      right: 10px;
      width: min(290px, calc(100vw - 20px));
      max-height: calc(100dvh - 24px);
      padding: 16px;
    }
    .mm-summary__total-value { font-size: 26px; }
  }
</style>

<script>
  (function () {
    if (window.customElements.get('mix-and-match')) return;

    function formatMoney(cents, format) {
      var value = (cents / 100);
      var str;
      if (/no_decimals/.test(format)) {
        str = Math.round(value).toLocaleString('en');
      } else {
        str = value.toLocaleString('en', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
      }
      if (format && /\{\{\s*amount/.test(format)) {
        return format.replace(/\{\{\s*amount[^}]*\}\}/, str);
      }
      return '$' + str;
    }

    class MixAndMatch extends HTMLElement {
      constructor() {
        super();
        this.discountType = this.dataset.discountType || 'none';
        this.discountValue = parseFloat(this.dataset.discountValue) || 0;
        this.bundleLabel = this.dataset.bundleLabel || 'Mix & Match';
        this.moneyFormat = this.dataset.moneyFormat || ('$' + '{' + '{amount}}');
        this.groupCount = parseInt(this.dataset.groupCount, 10) || 0;
        this.selections = {}; // groupIndex -> {variantId, price, title}
        this.addBtn = this.querySelector('[data-mm-add]');
        this.totalEl = this.querySelector('[data-mm-total]');
        this.totalBlock = this.querySelector('[data-mm-total-block]');
        this.wasEl = this.querySelector('[data-mm-was]');
        this.saveEl = this.querySelector('[data-mm-save]');
        this.errorEl = this.querySelector('[data-mm-error]');
        this.ctaText = this.querySelector('[data-mm-cta-text]');
        this.summaryEl = this.querySelector('[data-mm-summary]');
        this.summaryToggle = this.querySelector('[data-mm-summary-toggle]');
        this.summaryToggleText = this.querySelector('[data-mm-summary-toggle-text]');
        this.defaultCta = this.ctaText ? this.ctaText.textContent : 'Add bundle to cart';

        this.bindSummaryToggle();
        this.bindCards();
        this.bindCarousels();
        this.querySelectorAll('[data-mm-card]').forEach((card) => this.updateCardPrice(card));
        this.addBtn.addEventListener('click', () => this.addBundle());
      }

      bindSummaryToggle() {
        if (!this.summaryEl || !this.summaryToggle) return;
        // Start minimized (the slim side bar); the shopper expands it.
        this.setSummaryCollapsed(true);
        this.summaryToggle.addEventListener('click', (e) => {
          e.stopPropagation();
          this.setSummaryCollapsed(!this.summaryEl.classList.contains('is-collapsed'));
        });
        // Tapping anywhere on the minimized bar expands it.
        this.summaryEl.addEventListener('click', () => {
          if (this.summaryEl.classList.contains('is-collapsed')) this.setSummaryCollapsed(false);
        });
      }

      setSummaryCollapsed(collapsed) {
        if (!this.summaryEl || !this.summaryToggle) return;
        this.summaryEl.classList.toggle('is-collapsed', collapsed);
        this.summaryToggle.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
        this.summaryToggle.setAttribute('aria-label', collapsed ? 'Expand bundle summary' : 'Minimize bundle summary');
        if (this.summaryToggleText) {
          this.summaryToggleText.textContent = collapsed ? '‹' : '›';
        }
      }

      bindCarousels() {
        this.querySelectorAll('.mm-group__carousel').forEach((car) => {
          const track = car.querySelector('[data-mm-track]');
          const prev = car.querySelector('[data-mm-prev]');
          const next = car.querySelector('[data-mm-next]');
          if (!track) return;

          const update = () => {
            const overflow = track.scrollWidth - track.clientWidth > 4;
            [prev, next].forEach((b) => { if (b) b.hidden = !overflow; });
            if (overflow) {
              if (prev) prev.disabled = track.scrollLeft <= 2;
              if (next) next.disabled = track.scrollLeft >= track.scrollWidth - track.clientWidth - 2;
            }
          };
          const step = () => Math.max(220, Math.round(track.clientWidth * 0.85));
          if (prev) prev.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }));
          if (next) next.addEventListener('click', () => track.scrollBy({ left: step(), behavior: 'smooth' }));
          track.addEventListener('scroll', update, { passive: true });
          window.addEventListener('resize', update);
          // Images may finish loading after first paint and change scrollWidth.
          track.querySelectorAll('img').forEach((img) => {
            if (!img.complete) img.addEventListener('load', update, { once: true });
          });
          update();
        });
      }

      bindCards() {
        this.querySelectorAll('[data-mm-group]').forEach((group) => {
          const gi = group.dataset.mmGroup;
          group.querySelectorAll('[data-mm-card]').forEach((card) => {
            if (card.dataset.available !== 'true') return;

            const select = card.querySelector('[data-mm-variant-select]');
            if (select) {
              select.addEventListener('change', () => this.onVariantChange(card, select, gi));
              select.addEventListener('click', (e) => e.stopPropagation());
            }
            const choose = () => this.selectCard(group, card, gi);
            card.addEventListener('click', choose);
            card.addEventListener('keydown', (e) => {
              if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); choose(); }
            });
          });
        });
      }

      onVariantChange(card, select, gi) {
        const opt = select.options[select.selectedIndex];
        if (!opt) return;
        card.dataset.variantId = opt.value;
        card.dataset.price = opt.dataset.price || card.dataset.price;
        this.updateCardPrice(card);
        // Swap the card image to the chosen variant's image, if it has one.
        const img = card.querySelector('.mm-card__media > img');
        if (img && opt.dataset.image) {
          img.src = opt.dataset.image;
          img.removeAttribute('srcset');
          img.removeAttribute('sizes');
        }
        // If this card is the active selection for its group, refresh the summary.
        if (this.selections[gi] && card.classList.contains('is-selected')) {
          this.selections[gi].variantId = opt.value;
          this.selections[gi].price = parseInt(card.dataset.price, 10);
          Object.assign(this.selections[gi], this.captureMedia(card));
          this.render();
        }
      }

      // Render a single Special-Elite price per card: the after-discount price,
      // with the original struck through.
      //  - percentage: each item shown at (100 - value)%
      //  - fixed: the whole-bundle amount is split evenly across the groups, so
      //    each card is shown at price minus (amount / number of groups)
      updateCardPrice(card) {
        const cents = parseInt(card.dataset.price, 10) || 0;
        const nowEl = card.querySelector('[data-mm-price-now]');
        const wasEl = card.querySelector('[data-mm-price-was]');
        if (!nowEl) return;
        let now = cents;
        if (this.discountType === 'percentage' && this.discountValue > 0) {
          now = Math.round(cents * (100 - this.discountValue) / 100);
        } else if (this.discountType === 'fixed' && this.discountValue > 0 && this.groupCount > 0) {
          const perItemCents = Math.round(this.discountValue * 100 / this.groupCount);
          now = Math.max(0, cents - perItemCents);
        }
        nowEl.textContent = formatMoney(now, this.moneyFormat);
        if (wasEl) {
          if (now < cents) {
            wasEl.textContent = formatMoney(cents, this.moneyFormat);
            wasEl.hidden = false;
          } else {
            wasEl.hidden = true;
          }
        }
      }

      // Grab the card's current main image + world stamp for the summary thumbnail.
      captureMedia(card) {
        const img = card.querySelector('.mm-card__media > img');
        const stampImgEl = card.querySelector('.mm-card__world-img');
        const seal = card.querySelector('.mm-card__world');
        return {
          image: img ? (img.currentSrc || img.src) : '',
          stampImg: stampImgEl ? (stampImgEl.currentSrc || stampImgEl.src) : '',
          stampInitials: stampImgEl ? '' : (seal ? (seal.textContent || '').trim() : ''),
          stampColor: seal ? (seal.style.getPropertyValue('--world-c') || '#E8C36A') : '#E8C36A',
        };
      }

      slotThumbHTML(sel) {
        if (!sel.image && !sel.stampImg && !sel.stampInitials) return '';
        const img = sel.image ? '<img class="mm-summary__thumb-img" src="' + sel.image + '" alt="" loading="lazy">' : '';
        let stamp = '';
        if (sel.stampImg) {
          stamp = '<img class="mm-summary__thumb-stamp" src="' + sel.stampImg + '" alt="" loading="lazy">';
        } else if (sel.stampInitials) {
          stamp = '<span class="mm-summary__thumb-seal" style="--world-c:' + (sel.stampColor || '#E8C36A') + '">' + sel.stampInitials + '</span>';
        }
        return img + stamp;
      }

      selectCard(group, card, gi) {
        if (card.dataset.available !== 'true') return;
        group.querySelectorAll('[data-mm-card]').forEach((c) => {
          c.classList.remove('is-selected');
          c.setAttribute('aria-pressed', 'false');
        });
        card.classList.add('is-selected');
        card.setAttribute('aria-pressed', 'true');

        this.selections[gi] = Object.assign({
          variantId: card.dataset.variantId,
          price: parseInt(card.dataset.price, 10) || 0,
          title: card.dataset.productTitle || '',
          groupTitle: group.dataset.mmGroupTitle || '',
        }, this.captureMedia(card));

        const status = group.querySelector('[data-mm-group-status]');
        if (status) status.textContent = card.dataset.productTitle || 'Selected';
        group.classList.add('is-complete');

        this.render();
      }

      render() {
        // Per-slot summary values
        this.querySelectorAll('[data-mm-slot]').forEach((slot) => {
          const gi = slot.dataset.mmSlot;
          const valueEl = slot.querySelector('[data-mm-slot-value]');
          const thumbEl = slot.querySelector('[data-mm-slot-thumb]');
          const dotEl = this.querySelector('[data-mm-summary-dot="' + gi + '"]');
          const sel = this.selections[gi];
          if (sel) {
            valueEl.textContent = sel.title;
            if (thumbEl) thumbEl.innerHTML = this.slotThumbHTML(sel);
            slot.classList.add('is-filled');
            if (dotEl) {
              dotEl.classList.add('is-filled');
              var selectedLabel = slot.querySelector('[data-mm-slot-value]');
              dotEl.setAttribute('aria-label', ((selectedLabel && selectedLabel.textContent) || 'Group') + ' selected');
            }
          } else {
            valueEl.textContent = '—';
            if (thumbEl) thumbEl.innerHTML = '';
            slot.classList.remove('is-filled');
            if (dotEl) {
              dotEl.classList.remove('is-filled');
              var labelEl = slot.querySelector('.mm-summary__slot-label');
              const label = (labelEl && labelEl.textContent) || 'Group';
              dotEl.setAttribute('aria-label', label + ' not selected');
            }
          }
        });

        const chosen = Object.keys(this.selections).length;
        const complete = chosen === this.groupCount && this.groupCount > 0;

        // Hide the "Bundle total" block until at least one product is selected.
        if (this.totalBlock) this.totalBlock.classList.toggle('is-hidden', chosen === 0);

        // Auto-expand the panel once the bundle is complete, so the CTA is shown.
        if (complete && !this._autoExpanded) {
          this._autoExpanded = true;
          this.setSummaryCollapsed(false);
        }

        if (complete) {
          let total = 0;
          Object.keys(this.selections).forEach((k) => { total += this.selections[k].price; });

          let discounted = total;
          if (this.discountType === 'percentage' && this.discountValue > 0) {
            discounted = Math.round(total * (100 - this.discountValue) / 100);
          } else if (this.discountType === 'fixed' && this.discountValue > 0) {
            discounted = Math.max(0, total - Math.round(this.discountValue * 100));
          }

          const saved = total - discounted;
          this.totalEl.textContent = formatMoney(discounted, this.moneyFormat);

          if (saved > 0) {
            this.wasEl.textContent = formatMoney(total, this.moneyFormat);
            this.wasEl.hidden = false;
            const pct = Math.round(saved / total * 100);
            this.saveEl.textContent = 'You save ' + formatMoney(saved, this.moneyFormat) + ' (' + pct + '%)';
            this.saveEl.hidden = false;
          } else {
            this.wasEl.hidden = true;
            this.saveEl.hidden = true;
          }
        } else {
          this.totalEl.textContent = '—';
          this.wasEl.hidden = true;
          this.saveEl.hidden = true;
        }

        this.addBtn.disabled = !complete;
        if (this.ctaText) {
          this.ctaText.textContent = complete
            ? this.defaultCta
            : (this.defaultCta + ' (' + chosen + '/' + this.groupCount + ')');
        }
        this.setError('');
      }

      setError(msg) {
        if (!this.errorEl) return;
        if (msg) { this.errorEl.textContent = msg; this.errorEl.hidden = false; }
        else { this.errorEl.textContent = ''; this.errorEl.hidden = true; }
      }

      async addBundle() {
        const keys = Object.keys(this.selections);
        // Stable id for this exact combo: identical combos merge (= bundle qty up),
        // different combos stay as separate groups in the cart.
        const bundleId = keys
          .map((k) => String(this.selections[k].variantId))
          .sort()
          .join('-');
        const items = keys.map((k) => {
          const pos = parseInt(k, 10) + 1;
          const sel = this.selections[k];
          const slot = sel.groupTitle || ('Item ' + pos);
          return {
            id: sel.variantId,
            quantity: 1,
            properties: {
              // Visible at checkout / on the order (no leading underscore).
              // The group title is appended so each line shows which group it came from.
              'Bundle': this.bundleLabel + ' (' + slot + ')',
              // Hidden technical fields used only for cart grouping / display.
              '_bundle_id': bundleId,
              '_bundle_pos': String(pos),
              '_bundle_slot': slot,
            },
          };
        });
        if (items.length !== this.groupCount) return;

        this.addBtn.disabled = true;
        if (this.ctaText) this.ctaText.textContent = 'Adding…';

        try {
          const addRes = await fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/javascript' },
            body: JSON.stringify({ items: items }),
          });
          const addData = await addRes.json();
          if (!addRes.ok) {
            throw new Error((addData && (addData.description || addData.message)) || 'Could not add bundle to cart.');
          }

          // No discount code applied here: a Shopify automatic discount
          // ("Mix & Match bundle") gives 15% off the bundle products at min qty 3,
          // so nothing is exposed at checkout.

          if (window.PostcardCart) {
            await Promise.all([
              window.PostcardCart.refreshDrawer(),
              window.PostcardCart.refreshBag(),
            ]);
            const drawer = document.querySelector('cart-drawer');
            if (drawer && typeof drawer.open === 'function') drawer.open();
            else window.location.assign('/cart');
          } else {
            window.location.assign('/cart');
          }
        } catch (err) {
          this.setError(err.message || 'Something went wrong. Please try again.');
        } finally {
          this.addBtn.disabled = false;
          if (this.ctaText) this.ctaText.textContent = this.defaultCta;
        }
      }
    }

    window.customElements.define('mix-and-match', MixAndMatch);
  })();
</script>

{% schema %}
{
  "name": "Mix and Match",
  "tag": "section",
  "class": "section-mix-and-match",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Build your set" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Mix and Match" },
    { "type": "richtext", "id": "intro", "label": "Intro text", "default": "<p>Pick one from each group to build your bundle of three.</p>" },
    { "type": "text", "id": "cta_label", "label": "Add-to-cart button label", "default": "Add bundle to cart" },
    { "type": "paragraph", "content": "The discount is a Shopify automatic discount (Admin → Discounts → 'Mix & Match bundle'). No code is applied here, so nothing is exposed at checkout. The settings below only drive the prices shown on this page — keep them matching the automatic discount." },
    { "type": "select", "id": "discount_type", "label": "Discount type (for display)", "options": [ { "value": "none", "label": "None" }, { "value": "percentage", "label": "Percentage off" }, { "value": "fixed", "label": "Fixed amount off (whole bundle)" } ], "default": "percentage", "info": "Used to show the discounted price and savings on this page only." },
    { "type": "text", "id": "discount_value", "label": "Discount value", "default": "15", "info": "For percentage enter e.g. 15 (= 15% off). Must match the automatic discount in Shopify admin." },
    { "type": "text", "id": "bundle_label", "label": "Bundle label", "default": "Mix & Match", "info": "Shown on the page and as a tag on each item in the cart." },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Product thumbnails" },
    { "type": "checkbox", "id": "card_gradient", "label": "Gradient background behind product image", "default": false, "info": "Shows the linked world's accent colour as a gradient behind a contained product image. Off = full-bleed image filling the card." },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Top padding", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Bottom padding", "default": 48 }
  ],
  "blocks": [
    {
      "type": "group",
      "name": "Product group",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "title", "label": "Group title", "default": "Choose an item" },
        { "type": "text", "id": "subtitle", "label": "Group subtitle" },
        { "type": "product_list", "id": "products", "label": "Products in this group", "limit": 24 },
        { "type": "collection", "id": "collection", "label": "…or pull from a collection", "info": "Used only when no products are hand-picked above. Shows up to 48 of the collection's products." },
        { "type": "header", "content": "Variant-level curation (optional)" },
        { "type": "textarea", "id": "variant_ids", "label": "Show only these variants", "info": "Paste variant IDs (one per line, or comma-separated) to show exactly those variants as separate cards (no dropdown). Their products must be added above (or in the collection). Find a variant ID in Admin → Products → the product → click a variant → the number at the end of the URL. Leave blank to show whole products with a dropdown." }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Mix and Match",
      "blocks": [
        { "type": "group", "settings": { "title": "Choose your first item" } },
        { "type": "group", "settings": { "title": "Choose your second item" } },
        { "type": "group", "settings": { "title": "Choose your third item" } }
      ]
    }
  ]
}
{% endschema %}
