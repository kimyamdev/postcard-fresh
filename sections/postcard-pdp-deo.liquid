{%- liquid
  assign world = product.metafields.postcard.world.value
  if world
    assign world_color = world.accent_color.value
    assign world_theme_class = world.theme_class.value
    assign world_name = world.name.value
  endif
  assign world_color = world_color | default: '#E8C36A'
  assign world_theme_class = world_theme_class | default: 'world-hotel-lobby'
  assign world_name = world_name | default: 'Hotel Lobby'
  assign ribbon_subline = 'Aluminium-free deodorant'
  assign current = product.selected_or_first_available_variant
-%}

<div class="{{ world_theme_class }}" style="--world-color: {{ world_color }};">

  <div class="pc-breadcrumb">
    <div class="container pc-breadcrumb__inner">
      Home / Body / Deodorant / <span class="pc-breadcrumb__current">{{ product.title }}</span>
    </div>
  </div>

  <section class="pc-pdp-main">
    <div class="container pc-pdp-main__inner">
      {% render 'pdp-gallery', product: product, world_color: world_color, stamp_text: '24h<br>FRESH<br>SG' %}

      <aside class="pc-pdp-buy" x-data='{
        variantId: "{{ current.id }}",
        qty: 1,
        mode: "once",
        cadence: "60d",
        subOpen: false,
        prices: { {%- for v in product.variants -%}"{{ v.id }}": "{{ v.price | money }}"{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%} }
      }'>
        <form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data" class="pc-pdp-buy__form">
          <input type="hidden" name="form_type" value="product">
          <input type="hidden" name="utf8" value="&#x2713;">
          {%- for block in section.blocks -%}
            {% render 'pdp-buy-block', block: block, product: product, world_color: world_color, world_name: world_name, ribbon_subline: ribbon_subline, current: current %}
          {%- endfor -%}
        </form>
      </aside>
    </div>
  </section>

</div>

{% schema %}
{
  "name": "Deodorant PDP",
  "settings": [],
  "blocks": [
    { "type": "ribbon", "name": "Eyebrow ribbon", "limit": 1, "settings": [
      { "type": "text", "id": "subline_override", "label": "Subline override (per-template)" }
    ] },
    { "type": "title", "name": "Title", "limit": 1, "settings": [] },
    { "type": "description", "name": "Description", "limit": 1, "settings": [
      { "type": "number", "id": "word_limit", "label": "Word limit", "default": 30 }
    ] },
    { "type": "rating", "name": "Stars + reviews", "limit": 1, "settings": [] },
    { "type": "sizes", "name": "Size variants", "limit": 1, "settings": [
      { "type": "text", "id": "label", "label": "Label", "default": "Size" },
      { "type": "text", "id": "demo_sizes", "label": "Demo sizes (CSV, single-variant fallback)", "default": "65g Stick,40g Travel,Refill" },
      { "type": "number", "id": "demo_active_index", "label": "Active demo size (1-based)", "default": 1 }
    ] },
    { "type": "purchase_options", "name": "Purchase options", "limit": 1, "settings": [
      { "type": "text", "id": "label", "label": "Label", "default": "Purchase options" },
      { "type": "text", "id": "once_label", "label": "One-time label", "default": "One-time purchase" }
    ] },
    { "type": "qty_and_cta", "name": "Quantity + Add to bag", "limit": 1, "settings": [
      { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Add to bag" },
      { "type": "text", "id": "sold_out_text", "label": "Sold-out text", "default": "Sold out" }
    ] },
    { "type": "refill_link", "name": "Refill link", "limit": 1, "settings": [
      { "type": "text", "id": "text", "label": "Text", "default": "Or refill in store →" },
      { "type": "text", "id": "link", "label": "Link", "default": "/pages/refill" },
      { "type": "checkbox", "id": "always_show", "label": "Show even if not refillable", "default": false }
    ] },
    { "type": "stock_indicator", "name": "Stock indicator", "limit": 1, "settings": [
      { "type": "text", "id": "text", "label": "Text", "default": "• In stock · Ships in 1-2 days" }
    ] },
    { "type": "trust_circles", "name": "Trust circles", "limit": 1, "settings": [
      { "type": "text", "id": "label_1", "label": "Label 1", "default": "Made in SG" },
      { "type": "text", "id": "label_2", "label": "Label 2 (refillable, conditional)", "default": "Refillable" },
      { "type": "text", "id": "label_3", "label": "Label 3", "default": "Cruelty-free" },
      { "type": "text", "id": "label_4", "label": "Label 4", "default": "Vegan" },
      { "type": "checkbox", "id": "always_show_refillable", "label": "Always show refillable", "default": false }
    ] }
  ],
  "presets": [{
    "name": "Deodorant PDP",
    "blocks": [
      { "type": "ribbon" }, { "type": "title" }, { "type": "description" }, { "type": "rating" },
      { "type": "sizes" }, { "type": "purchase_options" }, { "type": "qty_and_cta" },
      { "type": "refill_link" }, { "type": "stock_indicator" }, { "type": "trust_circles" }
    ]
  }]
}
{% endschema %}
