{%- liquid
  assign image = section.settings.image
-%}
<section class="pc-refill-hero">
  <div class="ph pc-refill-hero__image">
    {%- if image != blank -%}
      {{ image | image_url: width: 1200 | image_tag: alt: section.settings.image_alt | default: 'Refill counter', loading: 'eager', widths: '600,900,1200,1600' }}
    {%- else -%}
      <span>{{ section.settings.image_placeholder | default: 'refill counter · steam, glass bottles, sunshine' }}</span>
    {%- endif -%}
  </div>
  <div class="pc-refill-hero__copy">
    {%- if section.settings.eyebrow != blank -%}
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h1 class="h-display pc-refill-hero__title">{{ section.settings.title }}</h1>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <p class="pc-refill-hero__body">{{ section.settings.body }}</p>
    {%- endif -%}
    <div class="pc-refill-hero__ctas">
      {%- if section.settings.cta_primary_text != blank -%}
        <a class="btn" href="{{ section.settings.cta_primary_url | default: '#refill-stores' }}">{{ section.settings.cta_primary_text }}</a>
      {%- endif -%}
      {%- if section.settings.cta_secondary_text != blank -%}
        <a class="tlink" href="{{ section.settings.cta_secondary_url | default: '#refill-list' }}">{{ section.settings.cta_secondary_text }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Refill · Hero",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "text", "id": "image_alt", "label": "Image alt text" },
    { "type": "text", "id": "image_placeholder", "label": "Placeholder text", "default": "refill counter · steam, glass bottles, sunshine" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Forever yours" },
    { "type": "text", "id": "title", "label": "Title", "default": "Refill, repeat, rejoice." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Bring your bottle back. We top it up. Less waste, same scent. You save 20% per refill." },
    { "type": "header", "content": "Primary CTA" },
    { "type": "text", "id": "cta_primary_text", "label": "Text", "default": "Find a refill store →" },
    { "type": "url", "id": "cta_primary_url", "label": "Link" },
    { "type": "header", "content": "Secondary CTA" },
    { "type": "text", "id": "cta_secondary_text", "label": "Text", "default": "See what's refillable" },
    { "type": "url", "id": "cta_secondary_url", "label": "Link" }
  ],
  "presets": [{ "name": "Refill · Hero" }]
}
{% endschema %}
