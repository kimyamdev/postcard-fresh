{%- liquid
  assign per_page = section.settings.products_per_page | default: 16
  assign show_filters = section.settings.show_filters
  if show_filters == nil
    assign show_filters = true
  endif
  assign show_sort = section.settings.show_sort
  if show_sort == nil
    assign show_sort = true
  endif
  assign count_text = section.settings.count_text | default: 'Showing [count] postcards'
  assign card_gradient = section.settings.card_gradient
  if card_gradient == nil
    assign card_gradient = true
  endif
-%}
{%- assign show_filters_for_layout = show_filters -%}
{%- if collection.filters.size == 0 -%}{%- assign show_filters_for_layout = false -%}{%- endif -%}
<section class="section pc-coll-grid-section{% unless card_gradient %} pc-coll-grid-section--flat{% endunless %}" data-section-id="{{ section.id }}">
  <div class="container pc-coll-grid{% unless show_filters_for_layout %} pc-coll-grid--no-filters{% endunless %}">
    {%- paginate collection.products by per_page -%}
      {%- if show_filters and collection.filters.size > 0 -%}
        <aside class="pc-coll-filters">
          <form id="CollectionFilterForm" method="get" class="pc-coll-filters__form">
            {%- if collection.current_type -%}
              <input type="hidden" name="q" value="{{ collection.current_type }}">
            {%- endif -%}
            {%- if collection.current_vendor -%}
              <input type="hidden" name="q" value="{{ collection.current_vendor }}">
            {%- endif -%}
            {%- if show_sort and collection.sort_by != blank -%}
              <input type="hidden" name="sort_by" value="{{ collection.sort_by }}">
            {%- endif -%}
            {%- for filter in collection.filters -%}
              {%- if filter.type == 'price_range' -%}{%- continue -%}{%- endif -%}
              {%- if filter.param_name == 'filter.p.vendor' -%}{%- continue -%}{%- endif -%}
              {%- if section.settings.show_type_buttons and filter.param_name == 'filter.p.product_type' -%}{%- continue -%}{%- endif -%}
              <div class="pc-coll-filter-group{% if forloop.last %} pc-coll-filter-group--last{% endif %}">
                <div class="eyebrow pc-coll-filter-group__title">{{ filter.label }}</div>
                {%- case filter.type -%}
                {%- when 'list', 'boolean' -%}
                  {%- for value in filter.values -%}
                    <label class="pc-coll-filter-row">
                      <input type="checkbox"
                        name="{{ value.param_name }}"
                        value="{{ value.value }}"
                        {% if value.active %}checked{% endif %}
                        {% if value.count == 0 and value.active == false %}disabled{% endif %}
                        onchange="this.form.submit()">
                      {{ value.label }} <span class="pc-coll-filter-row__count">({{ value.count }})</span>
                    </label>
                  {%- endfor -%}
                {%- when 'price_range' -%}
                  <div class="pc-coll-filter-row pc-coll-filter-row--price">
                    <label>
                      <span class="pc-coll-filter-row__label">Min</span>
                      <input type="number" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value }}" placeholder="{{ filter.range_min | money_without_currency | strip_html }}" min="0" max="{{ filter.range_max | money_without_currency | strip_html }}" onchange="this.form.submit()">
                    </label>
                    <label>
                      <span class="pc-coll-filter-row__label">Max</span>
                      <input type="number" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value }}" placeholder="{{ filter.range_max | money_without_currency | strip_html }}" min="0" max="{{ filter.range_max | money_without_currency | strip_html }}" onchange="this.form.submit()">
                    </label>
                  </div>
                {%- endcase -%}
              </div>
            {%- endfor -%}
            {%- if collection.url -%}
              <a class="tlink pc-coll-filters__clear" href="{{ collection.url }}">{{ section.settings.clear_text | default: 'Clear filters' }}</a>
            {%- endif -%}
            <noscript>
              <button type="submit" class="btn btn--small pc-coll-filters__apply">Apply</button>
            </noscript>
          </form>
        </aside>
      {%- endif -%}

      <div>
        {%- if section.settings.show_type_buttons -%}
          {%- assign type_filter = blank -%}
          {%- for filter in collection.filters -%}
            {%- if filter.param_name == 'filter.p.product_type' -%}
              {%- assign type_filter = filter -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if type_filter != blank and type_filter.values.size > 0 -%}
            {%- comment -%} Classify each product type into a high-level category (parallel to values). {%- endcomment -%}
            {%- assign cat_list = '' -%}
            {%- for v in type_filter.values -%}
              {%- capture vc -%}{%- render 'coll-type-category', label: v.label -%}{%- endcapture -%}
              {%- assign cat_list = cat_list | append: vc | strip | append: '~' -%}
            {%- endfor -%}
            {%- assign cat_arr = cat_list | split: '~' -%}
            {%- comment -%} Active state: how many types are active, and which category is "open". {%- endcomment -%}
            {%- assign active_count = 0 -%}
            {%- assign open_cat = '' -%}
            {%- for v in type_filter.values -%}
              {%- if v.active -%}
                {%- assign active_count = active_count | plus: 1 -%}
                {%- if open_cat == blank -%}{%- assign open_cat = cat_arr[forloop.index0] -%}{%- endif -%}
              {%- endif -%}
            {%- endfor -%}
            {%- assign categories = 'Hair,Body,Face,Home,Travel,Pets,Bundles,Gifts,Accessories' | split: ',' -%}
            {%- assign open_cat_url = collection.url -%}
            <div class="pc-coll-type-buttons">
              <div class="pc-coll-cat-buttons">
                <a class="pc-coll-type-btn pc-coll-cat-btn{% if active_count == 0 %} pc-coll-type-btn--active{% endif %}" href="{{ collection.url }}">{{ section.settings.all_button_label | default: 'All' }}</a>
                {%- for cat in categories -%}
                  {%- assign cat_count = 0 -%}
                  {%- assign cat_url = '' -%}
                  {%- for v in type_filter.values -%}
                    {%- if cat_arr[forloop.index0] == cat -%}
                      {%- if v.count == 0 and v.active == false -%}{%- continue -%}{%- endif -%}
                      {%- assign cat_count = cat_count | plus: 1 -%}
                      {%- assign enc = v.value | replace: '&amp;', '&' | url_encode -%}
                      {%- if cat_url == blank -%}
                        {%- assign cat_url = collection.url | append: '?filter.p.product_type=' | append: enc -%}
                      {%- else -%}
                        {%- assign cat_url = cat_url | append: '&filter.p.product_type=' | append: enc -%}
                      {%- endif -%}
                    {%- endif -%}
                  {%- endfor -%}
                  {%- if cat_count > 0 -%}
                    {%- if cat == open_cat -%}{%- assign open_cat_url = cat_url -%}{%- endif -%}
                    <a class="pc-coll-type-btn pc-coll-cat-btn{% if cat == open_cat %} pc-coll-type-btn--active pc-coll-cat-btn--open{% endif %}" href="{{ cat_url }}">{{ cat }}</a>
                  {%- endif -%}
                {%- endfor -%}
              </div>
              {%- if open_cat != blank -%}
                <div class="pc-coll-subtype-buttons">
                  {%- for v in type_filter.values -%}
                    {%- if cat_arr[forloop.index0] == open_cat -%}
                      {%- if v.count == 0 and v.active == false -%}{%- continue -%}{%- endif -%}
                      {%- if v.active and active_count == 1 -%}
                        <a class="pc-coll-type-btn pc-coll-subtype-btn pc-coll-type-btn--active" href="{{ open_cat_url }}">{{ v.label }}</a>
                      {%- else -%}
                        <a class="pc-coll-type-btn pc-coll-subtype-btn" href="{{ collection.url }}?filter.p.product_type={{ v.value | replace: '&amp;', '&' | url_encode }}">{{ v.label }}</a>
                      {%- endif -%}
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endif -%}
        <div class="pc-coll-grid__bar">
          {%- assign visible_count = paginate.items -%}
          {%- assign cap = section.settings.max_products | default: 0 -%}
          {%- if cap > 0 and cap < visible_count -%}
            {%- assign visible_count = cap -%}
          {%- endif -%}
          {%- assign rendered_count_text = count_text | replace: '[count]', visible_count -%}
          <div class="pc-coll-grid__count">{{ rendered_count_text }}</div>
          {%- if show_sort and collection.sort_options.size > 0 -%}
            <form method="get" class="pc-coll-grid__sort-form">
              {%- comment -%} Preserve active filter params when sort changes {%- endcomment -%}
              {%- for filter in collection.filters -%}
                {%- case filter.type -%}
                {%- when 'list', 'boolean' -%}
                  {%- for value in filter.values -%}
                    {%- if value.active -%}
                      <input type="hidden" name="{{ value.param_name }}" value="{{ value.value }}">
                    {%- endif -%}
                  {%- endfor -%}
                {%- when 'price_range' -%}
                  {%- if filter.min_value.value -%}
                    <input type="hidden" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value }}">
                  {%- endif -%}
                  {%- if filter.max_value.value -%}
                    <input type="hidden" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value }}">
                  {%- endif -%}
                {%- endcase -%}
              {%- endfor -%}
              <select class="pc-coll-grid__sort" name="sort_by" onchange="this.form.submit()">
                {%- for option in collection.sort_options -%}
                  <option value="{{ option.value }}" {% if collection.sort_by == option.value %}selected{% endif %}>{{ option.name }}</option>
                {%- endfor -%}
              </select>
            </form>
          {%- endif -%}
        </div>
        <div class="pc-coll-grid__products">
          {%- comment -%} Default sort: group by product type when the shopper hasn't picked an explicit sort. {%- endcomment -%}
          {%- if request.params.sort_by == blank -%}
            {%- assign sorted_products = collection.products | sort: 'type' -%}
          {%- else -%}
            {%- assign sorted_products = collection.products -%}
          {%- endif -%}
          {%- comment -%}
            Editorial "page cards" are interleaved by 1-based position, but only on the
            first page (so they don't repeat across pagination) and only on the
            unfiltered collection view (so they don't appear under every category /
            subcategory filter). A card whose position is beyond the products shown
            is appended at the end.
          {%- endcomment -%}
          {%- assign page_cards = section.blocks | where: 'type', 'page_card' -%}
          {%- comment -%}
            Build the active-filter context: each active product type's value AND its
            high-level category, pipe-delimited and lowercased, so a card's
            "show_filter" can target either (e.g. "Bundle" or "Gifts").
          {%- endcomment -%}
          {%- assign has_active_filter = false -%}
          {%- assign active_ctx = '|' -%}
          {%- for f in collection.filters -%}
            {%- for val in f.values -%}
              {%- if val.active -%}
                {%- assign has_active_filter = true -%}
                {%- assign active_ctx = active_ctx | append: val.value | downcase | append: '|' -%}
                {%- if f.param_name == 'filter.p.product_type' -%}
                  {%- capture acat -%}{%- render 'coll-type-category', label: val.label -%}{%- endcapture -%}
                  {%- assign active_ctx = active_ctx | append: acat | strip | downcase | append: '|' -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endfor -%}
          {%- comment -%} Per-card visibility: unfiltered view, or the card's show_filter matches. {%- endcomment -%}
          {%- assign visible_blocks = '' -%}
          {%- if paginate.current_page == 1 -%}
            {%- for blk in page_cards -%}
              {%- assign blk_show = false -%}
              {%- comment -%}
                Collection gate: if show_collections is set, the card only appears on those
                collections (matched by handle or title). Blank = show on every collection.
              {%- endcomment -%}
              {%- assign coll_ok = true -%}
              {%- if blk.settings.show_collections != blank -%}
                {%- assign coll_ok = false -%}
                {%- assign want_colls = blk.settings.show_collections | downcase | split: ',' -%}
                {%- assign coll_title_l = collection.title | downcase -%}
                {%- for wc in want_colls -%}
                  {%- assign wc_clean = wc | strip -%}
                  {%- if wc_clean == collection.handle or wc_clean == coll_title_l -%}{%- assign coll_ok = true -%}{%- break -%}{%- endif -%}
                {%- endfor -%}
              {%- endif -%}
              {%- if coll_ok -%}
                {%- if has_active_filter == false -%}
                  {%- assign blk_show = true -%}
                {%- elsif blk.settings.show_filter != blank -%}
                  {%- assign wants = blk.settings.show_filter | downcase | split: ',' -%}
                  {%- for w in wants -%}
                    {%- assign tok = w | strip | prepend: '|' | append: '|' -%}
                    {%- if active_ctx contains tok -%}{%- assign blk_show = true -%}{%- break -%}{%- endif -%}
                  {%- endfor -%}
                {%- endif -%}
              {%- endif -%}
              {%- if blk_show -%}{%- assign visible_blocks = visible_blocks | append: blk.id | append: ',' -%}{%- endif -%}
            {%- endfor -%}
          {%- endif -%}
          {%- assign show_page_cards = false -%}
          {%- if visible_blocks != blank -%}{%- assign show_page_cards = true -%}{%- endif -%}
          {%- assign max_products = section.settings.max_products | default: 0 -%}
          {%- assign emitted = 0 -%}
          {%- assign prod_index = 0 -%}
          {%- for p in sorted_products -%}
            {%- if max_products > 0 and emitted >= max_products -%}{%- break -%}{%- endif -%}
            {%- assign prod_index = prod_index | plus: 1 -%}
            {%- if show_page_cards -%}
              {%- for blk in page_cards -%}
                {%- if blk.settings.position == prod_index and visible_blocks contains blk.id -%}
                  {% render 'page-card', block: blk, card_gradient: card_gradient %}
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
            {% render 'product-card', product: p %}
            {%- assign emitted = emitted | plus: 1 -%}
          {%- else -%}
            <div class="pc-coll-grid__empty">
              {{ section.settings.empty_text | default: 'No postcards match these filters.' }}
              {%- if collection.url -%}
                <a class="tlink" href="{{ collection.url }}">{{ section.settings.empty_clear_text | default: 'Clear filters →' }}</a>
              {%- endif -%}
            </div>
          {%- endfor -%}
          {%- if show_page_cards -%}
            {%- for blk in page_cards -%}
              {%- if blk.settings.position > prod_index and visible_blocks contains blk.id -%}
                {% render 'page-card', block: blk, card_gradient: card_gradient %}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        </div>
        {%- if paginate.pages > 1 and max_products == 0 -%}
          <div class="pc-coll-grid__pagination">
            {{ paginate | default_pagination }}
          </div>
        {%- endif -%}
      </div>
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection · Grid",
  "tag": "section",
  "settings": [
    { "type": "paragraph", "content": "Uses Shopify storefront filters configured under Settings → Search & discovery → Filters. Filters and sort apply via GET form submit (no JS required, but onchange auto-submits when JS is available)." },
    { "type": "checkbox", "id": "show_filters", "label": "Show filters sidebar", "default": true },
    { "type": "checkbox", "id": "show_type_buttons", "label": "Show product-type buttons", "default": true, "info": "Renders a row of big buttons above the grid, one per product type. When on, the Type filter is hidden from the sidebar to avoid duplication." },
    { "type": "text", "id": "all_button_label", "label": "All-types button label", "default": "All" },
    { "type": "checkbox", "id": "show_sort", "label": "Show sort dropdown", "default": true },
    { "type": "checkbox", "id": "card_gradient", "label": "World-colour gradient behind product images", "default": true, "info": "On = soft world-accent gradient behind each (contained) product image. Off = plain card background." },
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 6, "max": 36, "step": 2, "default": 16 },
    { "type": "range", "id": "max_products", "label": "Total cap (0 = no cap)", "min": 0, "max": 60, "step": 1, "default": 0, "info": "Hard cap on the number of products shown across all pages. When > 0, pagination is hidden. Use for hand-picked / top-N collections." },
    { "type": "text", "id": "count_text", "label": "Count text", "default": "Showing [count] postcards", "info": "[count] is replaced with the filtered total." },
    { "type": "text", "id": "clear_text", "label": "Clear filters text", "default": "Clear filters" },
    { "type": "text", "id": "empty_text", "label": "Empty-state text", "default": "No postcards match these filters." },
    { "type": "text", "id": "empty_clear_text", "label": "Empty-state clear link", "default": "Clear filters →" }
  ],
  "blocks": [
    {
      "type": "page_card",
      "name": "Page card",
      "limit": 50,
      "settings": [
        { "type": "paragraph", "content": "An editorial card placed in the product grid that links to a page (or any URL) instead of a product. Only shows on the first page of results." },
        { "type": "url", "id": "link", "label": "Link", "info": "Pick a page, blog, collection, or paste any URL." },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "checkbox", "id": "image_fill", "label": "Fill frame with image", "default": true, "info": "On = photo fills the card (cropped). Off = image sits contained like a product photo." },
        { "type": "text", "id": "eyebrow", "label": "Small label (above title)", "default": "Editorial" },
        { "type": "text", "id": "title", "label": "Title", "default": "Read the story" },
        { "type": "text", "id": "badge_label", "label": "Corner badge (optional)", "info": "Small pill on the image, e.g. STORY. Leave blank to hide." },
        { "type": "text", "id": "cta_label", "label": "Link text", "default": "Read" },
        { "type": "color", "id": "accent_color", "label": "Accent colour", "default": "#E8C36A", "info": "Drives the gradient/badge tint, like a world accent." },
        { "type": "header", "content": "Price overlay" },
        { "type": "checkbox", "id": "show_price", "label": "Show price overlay on image", "default": false, "info": "Use for bundle-set promos: shows a struck original price and a discounted price on the card image." },
        { "type": "text", "id": "compare_price", "label": "Original price (struck)", "info": "e.g. $36. Leave blank to show only the discounted price." },
        { "type": "text", "id": "price", "label": "Discounted price", "info": "e.g. $30" },
        { "type": "header", "content": "Placement" },
        { "type": "text", "id": "show_collections", "label": "Show only on these collections", "info": "Comma-separated collection handles (the URL slug) or titles. Leave blank to show on every collection. E.g. 'fathers-day' or 'Father's Day'." },
        { "type": "text", "id": "show_filter", "label": "Also show under filter(s)", "info": "By default the card shows only on the unfiltered view. Enter product type(s) or category name(s) — comma-separated — to also show it when those are selected. E.g. 'Bundle' or 'Travel, Gifts'." },
        { "type": "range", "id": "position", "label": "Position in grid", "min": 1, "max": 24, "step": 1, "default": 3, "info": "Appears before this product number. If larger than the number of products shown, it goes at the end." }
      ]
    }
  ],
  "presets": [{ "name": "Collection · Grid" }]
}
{% endschema %}

<script>
  (function() {
    var root = document.querySelector('.pc-coll-grid-section[data-section-id="{{ section.id }}"]');
    if (!root || root.dataset.pcInit) return;
    root.dataset.pcInit = '1';
    var sectionId = root.getAttribute('data-section-id');

    function showLoading(state) {
      var grid = root.querySelector('.pc-coll-grid__products');
      if (grid) grid.style.opacity = state ? '0.4' : '';
    }

    async function applyURL(url) {
      try {
        showLoading(true);
        var fetchUrl = url + (url.indexOf('?') >= 0 ? '&' : '?') + 'section_id=' + sectionId;
        var res = await fetch(fetchUrl, { headers: { 'Accept': 'text/html' } });
        if (!res.ok) throw new Error('Network');
        var html = await res.text();
        var doc = new DOMParser().parseFromString(html, 'text/html');

        // The section render returns just the section markup (no <section> wrapper).
        // Walk source root and replace inner pieces of our DOM.
        var newButtons = doc.querySelector('.pc-coll-type-buttons');
        var newProducts = doc.querySelector('.pc-coll-grid__products');
        var newCount = doc.querySelector('.pc-coll-grid__count');
        var newPagination = doc.querySelector('.pc-coll-grid__pagination');
        var newFilters = doc.querySelector('.pc-coll-filters');

        var curButtons = root.querySelector('.pc-coll-type-buttons');
        var curProducts = root.querySelector('.pc-coll-grid__products');
        var curCount = root.querySelector('.pc-coll-grid__count');
        var curPagination = root.querySelector('.pc-coll-grid__pagination');
        var curFilters = root.querySelector('.pc-coll-filters');

        if (newButtons && curButtons) curButtons.innerHTML = newButtons.innerHTML;
        if (newProducts && curProducts) curProducts.innerHTML = newProducts.innerHTML;
        if (newCount && curCount) curCount.innerHTML = newCount.innerHTML;
        if (curPagination) curPagination.innerHTML = newPagination ? newPagination.innerHTML : '';
        if (newFilters && curFilters) curFilters.innerHTML = newFilters.innerHTML;

        history.pushState({ pcCollUrl: url }, '', url);
      } catch (e) {
        // Fall back to a normal navigation.
        window.location.href = url;
      } finally {
        showLoading(false);
      }
    }

    root.addEventListener('click', function(e) {
      var btn = e.target.closest('.pc-coll-type-btn');
      if (!btn) return;
      var href = btn.getAttribute('href');
      if (!href) return;
      e.preventDefault();
      applyURL(href);
    });

    window.addEventListener('popstate', function() {
      applyURL(window.location.href);
    });
  })();
</script>
