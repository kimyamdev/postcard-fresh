<section class="pc-worlds-hero">
  <div class="container">
    <div class="eyebrow">22 Worlds</div>
    <h1 class="h-display pc-worlds-hero__title">One bathroom shelf at a time.</h1>
    <p class="pc-worlds-hero__lede">Each one a place we&rsquo;d like to send you.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="eyebrow" style="margin-bottom: 16px;">Six core fragrance worlds</div>
    <div class="pc-worlds-index__core">
      <a class="pc-worlds-index__card" href="/pages/hotel-lobby">
        {% render 'stamp', name: 'Hotel Lobby', family: 'Hesperidic Gourmand', color: '#E8C36A', size: 'md' %}
        <div>
          <div class="eyebrow">Hesperidic Gourmand</div>
          <h3 class="h-display pc-worlds-index__card-name">Hotel Lobby</h3>
          <p class="pc-worlds-index__card-tag">A bright cup of bergamot with a soft lobby of vanilla.</p>
        </div>
      </a>
      <a class="pc-worlds-index__card" href="/pages/moon-bloom">
        {% render 'stamp', name: 'Moon Bloom', family: 'White Floral', color: '#5C6688', size: 'md' %}
        <div>
          <div class="eyebrow">White Floral</div>
          <h3 class="h-display pc-worlds-index__card-name">Moon Bloom</h3>
          <p class="pc-worlds-index__card-tag">Quiet jasmine, the night air, a window left open.</p>
        </div>
      </a>
      <a class="pc-worlds-index__card" href="/pages/coconut-beach">
        {% render 'stamp', name: 'Coconut Beach', family: 'Tropical Fruity Gourmand', color: '#E8B796', size: 'md' %}
        <div>
          <div class="eyebrow">Tropical Fruity Gourmand</div>
          <h3 class="h-display pc-worlds-index__card-name">Coconut Beach</h3>
          <p class="pc-worlds-index__card-tag">Sunscreen, salt skin, a coconut split open on the sand.</p>
        </div>
      </a>
      <a class="pc-worlds-index__card" href="/pages/wild-flowers">
        {% render 'stamp', name: 'Wild Flowers', family: 'Aromatic Foug&egrave;re', color: '#C7A8D6', size: 'md' %}
        <div>
          <div class="eyebrow">Aromatic Foug&egrave;re</div>
          <h3 class="h-display pc-worlds-index__card-name">Wild Flowers</h3>
          <p class="pc-worlds-index__card-tag">A meadow walk after light rain.</p>
        </div>
      </a>
      <a class="pc-worlds-index__card" href="/pages/bath-house">
        {% render 'stamp', name: 'Bath House', family: 'Woody Oriental', color: '#B07A4E', size: 'md' %}
        <div>
          <div class="eyebrow">Woody Oriental</div>
          <h3 class="h-display pc-worlds-index__card-name">Bath House</h3>
          <p class="pc-worlds-index__card-tag">Cedar steam, warm tile, the slow exhale.</p>
        </div>
      </a>
      <a class="pc-worlds-index__card" href="/pages/woodland-retreat">
        {% render 'stamp', name: 'Woodland Retreat', family: 'Aromatic Herbal', color: '#6E7F58', size: 'md' %}
        <div>
          <div class="eyebrow">Aromatic Herbal</div>
          <h3 class="h-display pc-worlds-index__card-name">Woodland Retreat</h3>
          <p class="pc-worlds-index__card-tag">Pine needles underfoot, a fire just lit.</p>
        </div>
      </a>
    </div>

    <div class="eyebrow" style="margin-bottom: 16px;">Skin &middot; hair &middot; wellness &middot; speciality</div>
    <div class="pc-worlds-index__minor">
      {% render 'stamp', name: 'Smoked Roses', color: '#C7A8D6', size: 'sm' %}
      {% render 'stamp', name: 'Threads of Nonya', color: '#9CC4D6', size: 'sm' %}
      {% render 'stamp', name: 'Forever Yours', color: '#E8B796', size: 'sm' %}
      {% render 'stamp', name: 'Oasis Perfume Oil', color: '#FFB233', size: 'sm' %}
      {% render 'stamp', name: 'Bakuchiol Bay', color: '#6E7F58', size: 'sm' %}
      {% render 'stamp', name: 'Hyaluronic Heaven', color: '#B07A4E', size: 'sm' %}
      {% render 'stamp', name: 'Rose Valley', color: '#5C6688', size: 'sm' %}
      {% render 'stamp', name: 'Ancient Tearoom', color: '#C7A8D6', size: 'sm' %}
      {% render 'stamp', name: 'Clear Skies', color: '#9CC4D6', size: 'sm' %}
      {% render 'stamp', name: 'Citrus Circus', color: '#E8B796', size: 'sm' %}
      {% render 'stamp', name: 'Coffee Spot', color: '#FFB233', size: 'sm' %}
      {% render 'stamp', name: 'Java Jungle', color: '#6E7F58', size: 'sm' %}
      {% render 'stamp', name: 'Hidden Garden', color: '#B07A4E', size: 'sm' %}
      {% render 'stamp', name: 'Curl Cove', color: '#5C6688', size: 'sm' %}
      {% render 'stamp', name: 'Sunlit Terrace', color: '#C7A8D6', size: 'sm' %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Postcard Worlds Index",
  "settings": [],
  "presets": [{ "name": "Postcard Worlds Index" }]
}
{% endschema %}
