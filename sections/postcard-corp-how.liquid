<section class="section pc-corp-how">
  <div class="container">
    {%- if section.settings.title != blank -%}
      <h2 class="h-display pc-corp-how__title">{{ section.settings.title }}</h2>
    {%- endif -%}
    <div class="pc-corp-how__grid">
      {%- for block in section.blocks -%}
        <div class="pc-corp-how__cell" {{ block.shopify_attributes }}>
          <div class="h-display pc-corp-how__num">{{ block.settings.number }}</div>
          <div class="h-display pc-corp-how__h">{{ block.settings.heading }}</div>
          <p class="pc-corp-how__p">{{ block.settings.body }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Corporate · How",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "How it works." }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "01" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Tell us." },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Form, volume, scent direction." }
      ]
    }
  ],
  "presets": [{
    "name": "Corporate · How",
    "blocks": [
      { "type": "step", "settings": { "number": "01", "heading": "Tell us.", "body": "Form, volume, scent direction." }},
      { "type": "step", "settings": { "number": "02", "heading": "We propose.", "body": "Within 2 working days." }},
      { "type": "step", "settings": { "number": "03", "heading": "Sample.", "body": "Physical samples on orders >$1,000." }},
      { "type": "step", "settings": { "number": "04", "heading": "We make.", "body": "Singapore beauty kitchen." }},
      { "type": "step", "settings": { "number": "05", "heading": "We deliver.", "body": "Pickup, courier, or direct." }}
    ]
  }]
}
{% endschema %}
