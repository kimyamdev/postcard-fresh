{%- comment -%}
  "Buy it again" section — reorder + autoship from order history
  (snippets/customer-reorder-recs.liquid). Droppable on the account page,
  homepage, etc. Renders nothing for logged-out visitors or when there are no
  eligible (available + subscribable) past purchases.
{%- endcomment -%}
{%- liquid
  assign sec_bg = section.settings.bg_color
-%}
{%- style -%}
  #pc-reorder-{{ section.id }} {
    padding: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px 16px {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    {% if sec_bg != blank %}background: {{ sec_bg }};{% endif %}
  }
  @media screen and (min-width: 750px) {
    #pc-reorder-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}
<section id="pc-reorder-{{ section.id }}">
  <div class="pc-reorder__wrap">
    {%- render 'customer-reorder-recs',
      heading: section.settings.heading,
      limit: section.settings.limit,
      columns: section.settings.columns
    -%}
  </div>
</section>
{% schema %}
{
  "name": "Buy it again",
  "tag": "section",
  "settings": [
    { "type": "paragraph", "content": "Reorder + autoship for a logged-in customer's previously bought, still-available, subscribable products. Hidden for logged-out visitors and when there's nothing eligible." },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Buy it again" },
    { "type": "range", "id": "limit", "label": "Max products", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "range", "id": "columns", "label": "Columns (desktop)", "min": 2, "max": 5, "step": 1, "default": 4 },
    { "type": "color", "id": "bg_color", "label": "Background" },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding_top", "label": "Top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 64 }
  ],
  "presets": [{ "name": "Buy it again" }]
}
{% endschema %}
