{%- liquid
  assign world = product.metafields.postcard.world.value
  assign world_color = world.accent_color.value | default: '#6E8B5C'
  assign world_name_upper = world.name.value | upcase

  assign current = product.selected_or_first_available_variant
  assign weight_g = current.weight
  if current.weight_unit == 'kg'
    assign weight_g = weight_g | times: 1000
  elsif current.weight_unit == 'lb'
    assign weight_g = weight_g | times: 453.592 | round
  elsif current.weight_unit == 'oz'
    assign weight_g = weight_g | times: 28.3495 | round
  endif
  assign weight_g = weight_g | round

  assign auto_label_top = world_name_upper | default: product.title | upcase
  assign auto_label_bottom = ''
  if weight_g > 0
    assign auto_label_bottom = weight_g | append: 'g · postcard sg'
  endif
  assign auto_left_price = current.price | money

  assign label_top    = section.settings.bar_label_top    | default: auto_label_top
  assign label_bottom = section.settings.bar_label_bottom | default: auto_label_bottom
  assign left_price   = section.settings.left_price       | default: auto_left_price
-%}
<section class="section pc-fp" style="--world-color: {{ world_color }};">
  <div class="container">
    <div class="pc-fp__head">
      <span class="pc-fp__pill" style="background: {{ world_color }}22;">{{ section.settings.eyebrow }}</span>
      <h2 class="h-display pc-fp__title">{{ section.settings.title }}</h2>
    </div>

    <div class="pc-fp__swap">
      <div class="pc-fp__col">
        <svg viewBox="0 0 200 140" width="220" height="154" class="pc-fp__svg">
          <ellipse cx="100" cy="120" rx="78" ry="6" fill="rgba(33,32,32,0.12)"/>
          <rect x="32" y="36" width="136" height="80" rx="14" fill="{{ world_color }}" stroke="#212020" stroke-width="1.8"/>
          <rect x="32" y="36" width="136" height="14" rx="14" fill="rgba(248,246,237,0.18)"/>
          <text x="100" y="84" text-anchor="middle" font-family="Special Elite, monospace" font-size="11" fill="#212020" letter-spacing="0.1em">{{ label_top }}</text>
          <text x="100" y="100" text-anchor="middle" font-family="Special Elite, monospace" font-size="9" fill="#212020" opacity="0.7" letter-spacing="0.08em">{{ label_bottom }}</text>
        </svg>
        <div class="h-display pc-fp__big">1</div>
        <div class="eyebrow">{{ section.settings.left_unit }}</div>
        <div class="pc-fp__price">{{ left_price }}</div>
      </div>

      <div class="h-display pc-fp__equals">=</div>

      <div class="pc-fp__col">
        <div class="pc-fp__bottles">
          <svg viewBox="0 0 80 160" width="76" height="152" class="pc-fp__svg pc-fp__svg--faded">
            <ellipse cx="40" cy="152" rx="28" ry="3" fill="rgba(33,32,32,0.12)"/>
            <rect x="30" y="6" width="20" height="14" rx="2" fill="none" stroke="#212020" stroke-width="1.5"/>
            <path d="M 22 24 L 22 142 Q 22 150 30 150 L 50 150 Q 58 150 58 142 L 58 24 Z" fill="{{ world_color }}33" stroke="#212020" stroke-width="1.5"/>
            <line x1="22" y1="60" x2="58" y2="60" stroke="#212020" stroke-width="0.8" stroke-dasharray="2 2" opacity="0.4"/>
          </svg>
          <svg viewBox="0 0 80 160" width="76" height="152" class="pc-fp__svg pc-fp__svg--faded">
            <ellipse cx="40" cy="152" rx="28" ry="3" fill="rgba(33,32,32,0.12)"/>
            <rect x="30" y="6" width="20" height="14" rx="2" fill="none" stroke="#212020" stroke-width="1.5"/>
            <path d="M 22 24 L 22 142 Q 22 150 30 150 L 50 150 Q 58 150 58 142 L 58 24 Z" fill="{{ world_color }}33" stroke="#212020" stroke-width="1.5"/>
            <line x1="22" y1="60" x2="58" y2="60" stroke="#212020" stroke-width="0.8" stroke-dasharray="2 2" opacity="0.4"/>
          </svg>
        </div>
        <div class="h-display pc-fp__big">2</div>
        <div class="eyebrow">{{ section.settings.right_unit }}</div>
        <div class="pc-fp__price pc-fp__price--strike">{{ section.settings.right_price }}</div>
      </div>

      <span class="postmark postmark--yellow pc-fp__seal">
        <div>{{ section.settings.seal_text }}</div>
      </span>
    </div>

    <div class="pc-fp__stats">
      {%- for block in section.blocks -%}
        <div class="pc-fp__stat" {{ block.shopify_attributes }}>
          <div class="h-display pc-fp__stat-num" style="color: {{ world_color }};">{{ block.settings.number }}</div>
          <div class="eyebrow pc-fp__stat-sub">{{ block.settings.sub }}</div>
          <p class="pc-fp__stat-body">{{ block.settings.body }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Format proof",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Pill text", "default": "The format proof" },
    { "type": "text", "id": "title", "label": "Title", "default": "What you're swapping." },
    { "type": "text", "id": "bar_label_top", "label": "Bar label top (blank = world name)", "info": "Auto-fills with the linked world's name in caps" },
    { "type": "text", "id": "bar_label_bottom", "label": "Bar label bottom (blank = variant weight)", "info": "Auto-fills as e.g. '75g · postcard sg' from variant weight" },
    { "type": "text", "id": "left_unit", "label": "Left side unit", "default": "Bar" },
    { "type": "text", "id": "left_price", "label": "Left price (blank = product price)", "info": "Auto-fills with current variant price" },
    { "type": "text", "id": "right_unit", "label": "Right side unit", "default": "250ml bottles" },
    { "type": "text", "id": "right_price", "label": "Right price (struck through)", "default": "S$48 of plastic" },
    { "type": "text", "id": "seal_text", "label": "Postmark seal", "default": "SAVES<br>· 500g ·<br>PLASTIC" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "number", "label": "Number" },
        { "type": "text", "id": "sub", "label": "Sub-line" },
        { "type": "textarea", "id": "body", "label": "Body" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Format proof",
      "blocks": [
        { "type": "stat", "settings": { "number": "80", "sub": "washes per bar", "body": "Tested on shoulder-length hair, twice-weekly wash. Short hair? Closer to 100." } },
        { "type": "stat", "settings": { "number": "0g", "sub": "plastic packaging", "body": "Wrapped in seed paper. Plant the wrapper, get a basil bush." } },
        { "type": "stat", "settings": { "number": "100g", "sub": "airline-friendly", "body": "Carry-on legal. No 100ml liquid limit. Travels in the tin." } }
      ]
    }
  ]
}
{% endschema %}
