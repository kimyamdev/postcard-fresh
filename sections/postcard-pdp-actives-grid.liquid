<section class="section pc-ag" style="background: var(--color-bg-warm);">
  <div class="container">
    <div class="pc-ag__head">
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h2 class="h-display pc-ag__title">{{ section.settings.title }}</h2>
      {%- if section.settings.lede != blank -%}
        <p class="pc-ag__lede">{{ section.settings.lede }}</p>
      {%- endif -%}
    </div>

    <div class="pc-ag__grid">
      <div class="stamp-frame stamp-side pc-ag__card">
        <div class="pc-ag__icon">
          <svg viewBox="0 0 64 64" width="60" height="60">
            <g fill="none" stroke="#212020" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="32" cy="32" r="20"/>
              <path d="M16 32 q 8 -10 16 0 q 8 10 16 0" stroke-width="1.4"/>
              <path d="M22 26 q 4 4 0 8" stroke-width="1.1"/>
              <path d="M32 22 q 4 4 0 8" stroke-width="1.1"/>
              <path d="M42 26 q 4 4 0 8" stroke-width="1.1"/>
              <text x="32" y="46" text-anchor="middle" font-family="Special Elite, monospace" font-size="9" fill="#212020">Mg</text>
            </g>
          </svg>
        </div>
        <div class="pc-ag__copy">
          <div class="eyebrow">Odour neutraliser</div>
          <h3 class="h-typewriter pc-ag__name">Magnesium Hydroxide 12%</h3>
          <p class="pc-ag__story">Raises pit pH so odour-causing bacteria can&rsquo;t set up shop. Won&rsquo;t block your sweat &mdash; your body still cools itself.</p>
        </div>
      </div>

      <div class="stamp-frame stamp-side pc-ag__card">
        <div class="pc-ag__icon">
          <svg viewBox="0 0 64 64" width="60" height="60">
            <g fill="none" stroke="#212020" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <ellipse cx="22" cy="28" rx="7" ry="5"/>
              <ellipse cx="38" cy="22" rx="6" ry="4"/>
              <ellipse cx="44" cy="38" rx="7" ry="5"/>
              <ellipse cx="26" cy="44" rx="6" ry="4"/>
              <circle cx="22" cy="28" r="1.4" fill="#212020"/>
              <circle cx="38" cy="22" r="1.2" fill="#212020"/>
              <circle cx="44" cy="38" r="1.4" fill="#212020"/>
              <circle cx="26" cy="44" r="1.2" fill="#212020"/>
            </g>
          </svg>
        </div>
        <div class="pc-ag__copy">
          <div class="eyebrow">Live odour-eating culture</div>
          <h3 class="h-typewriter pc-ag__name">Saccharomyces Ferment</h3>
          <p class="pc-ag__story">A skin-friendly probiotic that keeps the underarm microbiome calm. Less smell to fight, less product needed.</p>
        </div>
      </div>

      <div class="stamp-frame stamp-side pc-ag__card">
        <div class="pc-ag__icon">
          <svg viewBox="0 0 64 64" width="60" height="60">
            <g fill="none" stroke="#212020" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 18 q 12 -6 24 0 v 26 q -12 6 -24 0 z"/>
              <path d="M20 18 q 12 6 24 0" stroke-width="1.2"/>
              <path d="M26 26 q 6 -1 12 0" stroke-width="0.9"/>
              <path d="M26 32 q 6 -1 12 0" stroke-width="0.9"/>
              <path d="M26 38 q 6 -1 12 0" stroke-width="0.9"/>
            </g>
          </svg>
        </div>
        <div class="pc-ag__copy">
          <div class="eyebrow">Dryness, no chalk</div>
          <h3 class="h-typewriter pc-ag__name">Tapioca Starch + Arrowroot</h3>
          <p class="pc-ag__story">Plant-derived powders soak up wetness without the chalky drag of cornstarch. Glides on, stays invisible on dark fabric.</p>
        </div>
      </div>

      <div class="stamp-frame stamp-side pc-ag__card">
        <div class="pc-ag__icon">
          <svg viewBox="0 0 64 64" width="60" height="60">
            <g fill="none" stroke="#212020" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="32" cy="32" r="6"/>
              <ellipse cx="32" cy="14" rx="3.5" ry="6.5"/>
              <ellipse cx="32" cy="14" rx="3.5" ry="6.5" transform="rotate(45 32 32)"/>
              <ellipse cx="32" cy="14" rx="3.5" ry="6.5" transform="rotate(90 32 32)"/>
              <ellipse cx="32" cy="14" rx="3.5" ry="6.5" transform="rotate(135 32 32)"/>
              <ellipse cx="32" cy="14" rx="3.5" ry="6.5" transform="rotate(180 32 32)"/>
              <ellipse cx="32" cy="14" rx="3.5" ry="6.5" transform="rotate(225 32 32)"/>
              <ellipse cx="32" cy="14" rx="3.5" ry="6.5" transform="rotate(270 32 32)"/>
              <ellipse cx="32" cy="14" rx="3.5" ry="6.5" transform="rotate(315 32 32)"/>
            </g>
          </svg>
        </div>
        <div class="pc-ag__copy">
          <div class="eyebrow">Calms freshly-shaved skin</div>
          <h3 class="h-typewriter pc-ag__name">Calendula + Allantoin</h3>
          <p class="pc-ag__story">For the day after the razor. Calendula soothes, allantoin builds the barrier back. Sting-free promise.</p>
        </div>
      </div>
    </div>

    <div class="pc-ag__warning">
      <span class="postmark pc-ag__warning-pm"><div>NO<br>&middot; INSIDE &middot;<br>WHATSOEVER</div></span>
      <div class="pc-ag__warning-copy">
        <div class="eyebrow">{{ section.settings.warning_label }}</div>
        <div class="pc-ag__warning-list">{{ section.settings.warning_list }}</div>
      </div>
      <a class="tlink pc-ag__warning-cta" href="#full-inci">See full INCI &rarr;</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Actives grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "What's actually in it" },
    { "type": "text", "id": "title", "label": "Title", "default": "Four actives. No filler." },
    { "type": "textarea", "id": "lede", "label": "Lede", "default": "We're skipping the scent-notes section here — that's on the fragrance PDP. This is the chemistry: the things that block, the things that calm, and why we picked them." },
    { "type": "text", "id": "warning_label", "label": "Warning label", "default": "What you won't find" },
    { "type": "textarea", "id": "warning_list", "label": "Warning list", "default": "Aluminium chlorohydrate · Baking soda · Triclosan · Parabens · Phthalates · Synthetic dye · Talc" }
  ],
  "presets": [{ "name": "Actives grid" }]
}
{% endschema %}
