{%- liquid
  assign src = section.settings.collection
  assign source = collections[src]
  assign has_source = false
  if source != blank and source.products_count > 0
    assign has_source = true
  endif

  comment
    Pre-pass: collect handles already claimed by an explicit filter,
    so the catch-all ("Other" — filter with empty match_types) picks up the rest.
  endcomment
  assign matched = '|'
  if has_source
    for block in section.blocks
      if block.type == 'filter'
        assign mt = block.settings.match_types | default: ''
        if mt != ''
          assign types = mt | split: ','
          for p in source.products
            for t in types
              assign tt = t | strip
              if p.type == tt
                assign matched = matched | append: p.handle | append: '|'
                break
              endif
            endfor
          endfor
        endif
      endif
    endfor
  endif
-%}
<section class="section pc-refill-cat" id="{{ section.settings.anchor_id | default: 'refill-list' }}" x-data="{ active: 0 }">
  <div class="container">
    <div class="pc-refill-cat__head">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <div class="eyebrow">{{ section.settings.eyebrow }}</div>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="h-display pc-refill-cat__title">{{ section.settings.title }}</h2>
        {%- endif -%}
      </div>

      <div class="pc-refill-cat__filters">
        {%- assign fi = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'filter' -%}
            <button class="pc-refill-cat__filter"
                    :class="active === {{ fi }} && 'pc-refill-cat__filter--active'"
                    type="button"
                    @click="active = {{ fi }}"
                    {{ block.shopify_attributes }}>
              {{ block.settings.label }}
            </button>
            {%- assign fi = fi | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    {%- if has_source -%}
      {%- assign fi = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'filter' -%}
          <div class="pc-refill-cat__panel" x-show="active === {{ fi }}" x-cloak>
            <div class="pc-refill-cat__grid">
              {%- assign mt = block.settings.match_types | default: '' -%}
              {%- if mt == '' -%}
                {%- for p in source.products -%}
                  {%- assign needle = '|' | append: p.handle | append: '|' -%}
                  {%- unless matched contains needle -%}
                    {% render 'product-card', product: p, badge: 'Refill' %}
                  {%- endunless -%}
                {%- endfor -%}
              {%- else -%}
                {%- assign types = mt | split: ',' -%}
                {%- for p in source.products -%}
                  {%- assign hit = false -%}
                  {%- for t in types -%}
                    {%- assign tt = t | strip -%}
                    {%- if p.type == tt -%}
                      {%- assign hit = true -%}
                      {%- break -%}
                    {%- endif -%}
                  {%- endfor -%}
                  {%- if hit -%}
                    {% render 'product-card', product: p, badge: 'Refill' %}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
            </div>
          </div>
          {%- assign fi = fi | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    {%- else -%}
      {%- comment -%} Fallback: no collection picked yet — render legacy static product blocks. {%- endcomment -%}
      <div class="pc-refill-cat__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'product' -%}
            {%- if block.settings.product != blank -%}
              {% render 'product-card', product: block.settings.product, badge: block.settings.badge %}
            {%- else -%}
              <div {{ block.shopify_attributes }}>
                {% render 'product-card',
                  name: block.settings.name,
                  world: block.settings.world,
                  world_color: block.settings.world_color,
                  price: block.settings.price,
                  badge: block.settings.badge %}
              </div>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Refill · Catalogue",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "anchor_id", "label": "Anchor ID", "default": "refill-list", "info": "Used in #anchor links from CTAs." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The catalogue" },
    { "type": "text", "id": "title", "label": "Title", "default": "Every postcard you can return." },
    { "type": "collection", "id": "collection", "label": "Refillable collection", "info": "Source of products shown. Tabs bucket them by Product Type." }
  ],
  "blocks": [
    {
      "type": "filter",
      "name": "Filter tab",
      "settings": [
        { "type": "text", "id": "label", "label": "Tab label", "default": "Body & bath" },
        { "type": "textarea", "id": "match_types", "label": "Product types to include", "info": "Comma-separated product types (matches Shopify product.type). Leave empty to make this the catch-all (Other)." }
      ]
    },
    {
      "type": "product",
      "name": "Static product (legacy)",
      "limit": 24,
      "settings": [
        { "type": "product", "id": "product", "label": "Product (preferred)", "info": "Used only when no Refillable collection is selected above." },
        { "type": "text", "id": "name", "label": "Name (manual)", "default": "Hotel Lobby Hand & Body Wash" },
        { "type": "text", "id": "world", "label": "World name", "default": "Hotel Lobby" },
        { "type": "color", "id": "world_color", "label": "World color", "default": "#E8C36A" },
        { "type": "text", "id": "price", "label": "Price", "default": "$26" },
        { "type": "text", "id": "badge", "label": "Badge", "default": "Refill" }
      ]
    }
  ],
  "presets": [{
    "name": "Refill · Catalogue",
    "blocks": [
      { "type": "filter", "settings": { "label": "Body & bath", "match_types": "Body Soap, Liquid Body Wash, Soap, Bar Soap, Head to Toe Cleansing Bar, Head to Toe Powder Wash, Body Balm Refill, Body Lotion, Hand Cream, Hand Sanitizer, Sun Care, Baby Care, Bath & Travel Accessories" }},
      { "type": "filter", "settings": { "label": "Hair", "match_types": "Shampoo Bar, Liquid Shampoo, Conditioner Bar, Hair Oil, Dry Shampoo" }},
      { "type": "filter", "settings": { "label": "Face", "match_types": "Facial Bar, Facial Oil, Facial Serum, Facial Mist, Facial Moisturiser, Facial Powder Wash, Serum, Cream Mask, Lip Balm Stick, Bi-Phase Make Up Remover, Makeup, Reparative Care" }},
      { "type": "filter", "settings": { "label": "Deodorant", "match_types": "Deodorant, Deodorant Stick, Refillable Stick" }},
      { "type": "filter", "settings": { "label": "Home", "match_types": "Home Scent, Home Cleaning, Diffuser Oil, Electric Diffuser, Anywhere Fragrance, Essential Oil" }},
      { "type": "filter", "settings": { "label": "Other", "match_types": "" }}
    ]
  }]
}
{% endschema %}
