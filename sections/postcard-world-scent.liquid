{%- liquid
  assign world = page.metafields.custom.world.value
  assign world_name = world.name.value
  assign world_color = world.accent_color.value | default: '#E8C36A'
  assign world_wear_notes = world.wear_notes_quote.value | default: 'Bright then cozy. Reads as unisex but leans slightly feminine. Year-round, but especially welcoming in cooler weather.'
  assign world_character_label = world.character_label.value | default: 'Unisex · Year-round'
  assign world_character_desc = world.character_description.value | default: 'Reads polite, leans cosy in cooler weather.'
  assign bg_alpha = section.settings.bg_alpha | default: 8

  assign top_arr = ''
  assign heart_arr = ''
  assign base_arr = ''
  if world.notes_top.value != blank
    assign top_arr = world.notes_top.value | join: ', '
  endif
  if world.notes_heart.value != blank
    assign heart_arr = world.notes_heart.value | join: ', '
  endif
  if world.notes_base.value != blank
    assign base_arr = world.notes_base.value | join: ', '
  endif
  assign use_scent_top = false
  assign use_scent_heart = false
  assign use_scent_base = false
  if top_arr == blank
    assign use_scent_top = true
  endif
  if heart_arr == blank
    assign use_scent_heart = true
  endif
  if base_arr == blank
    assign use_scent_base = true
  endif
  assign scent_notes = world.scent_notes.value
  if scent_notes
    for n in scent_notes
      case n.family.value
        when 'Top'
          if use_scent_top
            if top_arr == blank
              assign top_arr = n.name.value
            else
              assign top_arr = top_arr | append: ', ' | append: n.name.value
            endif
          endif
        when 'Heart'
          if use_scent_heart
            if heart_arr == blank
              assign heart_arr = n.name.value
            else
              assign heart_arr = heart_arr | append: ', ' | append: n.name.value
            endif
          endif
        when 'Base'
          if use_scent_base
            if base_arr == blank
              assign base_arr = n.name.value
            else
              assign base_arr = base_arr | append: ', ' | append: n.name.value
            endif
          endif
      endcase
    endfor
  endif
  assign top_arr = top_arr | default: 'Bergamot, Orange Blossom'
  assign heart_arr = heart_arr | default: 'Earl Grey Tea, Apricot'
  assign base_arr = base_arr | default: 'Vanilla, White Musk'

  comment
    Editor overrides win over both the metaobject's notes lists and the scent_notes fallback.
    Newlines and commas both accepted; we normalise to a comma-separated string.
  endcomment
  if section.settings.top_notes_override != blank
    assign top_arr = section.settings.top_notes_override | newline_to_br | replace: '<br />', ', ' | replace: '<br>', ', '
  endif
  if section.settings.heart_notes_override != blank
    assign heart_arr = section.settings.heart_notes_override | newline_to_br | replace: '<br />', ', ' | replace: '<br>', ', '
  endif
  if section.settings.base_notes_override != blank
    assign base_arr = section.settings.base_notes_override | newline_to_br | replace: '<br />', ', ' | replace: '<br>', ', '
  endif

  assign top_desc = world.top_description.value | default: section.settings.top_desc | default: 'The bright doorway moment.'
  assign heart_desc = world.heart_description.value | default: section.settings.heart_desc | default: 'Warm tea steam, soft fruit.'
  assign base_desc = world.base_description.value | default: section.settings.base_desc | default: 'The settled, skin-like finish.'

  if section.settings.character_notes_override != blank
    assign world_character_label = section.settings.character_notes_override
  endif
  if section.settings.character_desc_override != blank
    assign world_character_desc = section.settings.character_desc_override
  endif
  if section.settings.wear_notes_override != blank
    assign world_wear_notes = section.settings.wear_notes_override
  endif
-%}

{%- assign show_descriptions = section.settings.show_descriptions -%}
{%- if show_descriptions == nil -%}{%- assign show_descriptions = true -%}{%- endif -%}
{%- if world -%}
<section class="section section--tight pc-world-scent{% unless show_descriptions %} pc-world-scent--no-desc{% endunless %}" style="--world-color: {{ world_color }}; background: color-mix(in srgb, {{ world_color }} {{ bg_alpha }}%, transparent);">
  <div class="container">
    <div class="pc-scent__head">
      {%- if section.settings.eyebrow != blank -%}
        <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="h-display pc-scent__title">{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>
    <div class="pc-scent__table">
      <div class="pc-scent__row">
        <div class="h-display pc-scent__layer">{{ section.settings.top_label | default: 'Top' }}</div>
        <div class="pc-scent__notes">{{ top_arr }}</div>
        <div class="pc-scent__desc">{{ top_desc }}</div>
      </div>
      <div class="pc-scent__row">
        <div class="h-display pc-scent__layer">{{ section.settings.heart_label | default: 'Heart' }}</div>
        <div class="pc-scent__notes">{{ heart_arr }}</div>
        <div class="pc-scent__desc">{{ heart_desc }}</div>
      </div>
      <div class="pc-scent__row">
        <div class="h-display pc-scent__layer">{{ section.settings.base_label | default: 'Base' }}</div>
        <div class="pc-scent__notes">{{ base_arr }}</div>
        <div class="pc-scent__desc">{{ base_desc }}</div>
      </div>
      <div class="pc-scent__row pc-scent__row--last">
        <div class="h-display pc-scent__layer">{{ section.settings.character_label | default: 'Character' }}</div>
        <div class="pc-scent__notes">{{ world_character_label }}</div>
        <div class="pc-scent__desc">{{ world_character_desc }}</div>
      </div>
    </div>
  </div>
</section>

{%- if section.settings.show_wear_notes -%}
  <section class="pc-world-quote">
    <div class="container--narrow pc-world-quote__inner">
      <span class="postmark pc-world-quote__pm"><div>{{ section.settings.wear_notes_label | default: 'WEAR<br>NOTES' }}</div></span>
      <p class="h-typewriter pc-world-quote__text">&ldquo;{{ world_wear_notes }}&rdquo;</p>
    </div>
  </section>
{%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "World page · Scent",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "How it's built" },
    { "type": "text", "id": "title",   "label": "Title",   "default": "The scent breakdown." },
    { "type": "range", "id": "bg_alpha", "label": "Background tint (%)", "min": 0, "max": 30, "step": 2, "default": 8, "unit": "%", "info": "How strongly the world's accent color tints the section background." },
    { "type": "checkbox", "id": "show_descriptions", "label": "Show description column", "default": true, "info": "When off, hides the third column (the per-layer descriptions) so only Layer + Notes are shown." },
    { "type": "header", "content": "Layer rows" },
    { "type": "text", "id": "top_label",       "label": "Top label",       "default": "Top" },
    { "type": "textarea", "id": "top_notes_override", "label": "Top notes (override)", "info": "Comma-separated or one per line. Leave blank to use the world metaobject's notes_top (or scent_notes fallback)." },
    { "type": "text", "id": "top_desc",        "label": "Top description", "default": "The bright doorway moment." },
    { "type": "text", "id": "heart_label",     "label": "Heart label",     "default": "Heart" },
    { "type": "textarea", "id": "heart_notes_override", "label": "Heart notes (override)", "info": "Comma-separated or one per line. Leave blank to use the world metaobject's notes_heart." },
    { "type": "text", "id": "heart_desc",      "label": "Heart description","default": "Warm tea steam, soft fruit." },
    { "type": "text", "id": "base_label",      "label": "Base label",      "default": "Base" },
    { "type": "textarea", "id": "base_notes_override", "label": "Base notes (override)", "info": "Comma-separated or one per line. Leave blank to use the world metaobject's notes_base." },
    { "type": "text", "id": "base_desc",       "label": "Base description","default": "The settled, skin-like finish." },
    { "type": "text", "id": "character_label", "label": "Character label", "default": "Character" },
    { "type": "text", "id": "character_notes_override", "label": "Character (override)", "info": "Leave blank to use the world metaobject's character_label (e.g. 'Unisex · Year-round')." },
    { "type": "text", "id": "character_desc_override", "label": "Character description (override)", "info": "Leave blank to use the world metaobject's character_description." },
    { "type": "header", "content": "Wear-notes quote" },
    { "type": "checkbox", "id": "show_wear_notes", "label": "Show wear-notes quote", "default": true },
    { "type": "textarea", "id": "wear_notes_override", "label": "Wear notes quote (override)", "info": "Leave blank to use the world metaobject's wear_notes_quote." },
    { "type": "text", "id": "wear_notes_label", "label": "Postmark label (HTML)", "default": "WEAR<br>NOTES" }
  ],
  "presets": [{ "name": "World page · Scent" }]
}
{% endschema %}
