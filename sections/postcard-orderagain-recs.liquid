{%- comment -%}
  "Order it again" section — the exact products the logged-in customer bought
  before that are still available, with quick-add + shuffle
  (snippets/customer-orderagain-recs.liquid). Droppable on the account page,
  homepage, etc. Renders nothing for logged-out visitors or when nothing
  they've bought is still available.
{%- endcomment -%}
{%- liquid
  assign sec_bg = section.settings.bg_color
  assign exclude = nil
  if product
    assign exclude = product.id
  endif
-%}
{%- style -%}
  #pc-orderagain-{{ section.id }} {
    padding: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px 16px {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    {% if sec_bg != blank %}background: {{ sec_bg }};{% endif %}
  }
  @media screen and (min-width: 750px) {
    #pc-orderagain-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}
<section id="pc-orderagain-{{ section.id }}">
  <div class="pc-world-recs__wrap">
    {%- render 'customer-orderagain-recs',
      heading: section.settings.heading,
      blurb: section.settings.blurb,
      limit: section.settings.limit,
      columns: section.settings.columns,
      exclude_id: exclude
    -%}
  </div>
</section>
{% schema %}
{
  "name": "Order it again",
  "tag": "section",
  "settings": [
    { "type": "paragraph", "content": "The exact products a logged-in customer ordered before that are still available, with quick-add + shuffle. Hidden for logged-out visitors and when nothing's eligible." },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Order it again" },
    { "type": "text", "id": "blurb", "label": "Sub-line", "default": "Pick up where you left off." },
    { "type": "range", "id": "limit", "label": "Shown at once", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "range", "id": "columns", "label": "Columns (desktop)", "min": 2, "max": 5, "step": 1, "default": 4 },
    { "type": "color", "id": "bg_color", "label": "Background" },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding_top", "label": "Top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 64 }
  ],
  "presets": [{ "name": "Order it again" }]
}
{% endschema %}
