<main>
  <section class="pc-corp-hero">
    <div class="pc-corp-hero__copy">
      <div class="eyebrow pc-corp-hero__eyebrow">Corporate &amp; Hospitality</div>
      <h1 class="h-display pc-corp-hero__title">Pamper with a postcard.</h1>
      <p class="pc-corp-hero__body">Bespoke gifts, hotel amenities, and brand collaborations &mdash; made in Singapore, delivered with care.</p>
      <div class="pc-corp-hero__ctas">
        <a class="btn" href="#enquiry">Start an enquiry &rarr;</a>
        <a class="tlink pc-corp-hero__link2" href="{{ section.settings.pdf_link }}">Download one-pager (PDF)</a>
      </div>
    </div>
    <div class="ph ph--ink pc-corp-hero__image"><span>luxe hamper &middot; top-down</span></div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="h-display pc-corp-ways__title">Three ways we work together.</h2>
      <div class="pc-corp-ways__grid">
        <div class="stamp-frame stamp-side pc-corp-way-card">
          <div class="ph pc-corp-way-card__media"><span>Corporate gifts &amp; hampers</span></div>
          <span class="postmark pc-corp-way-card__pm"><div>CORPORATE</div></span>
          <h3 class="h-display pc-corp-way-card__h">Send a gift they&rsquo;ll keep.</h3>
          <p class="pc-corp-way-card__p">From $80 / recipient. Bespoke wrap. Logo print available.</p>
          <a class="tlink" href="#enquiry">Enquire &rarr;</a>
        </div>
        <div class="stamp-frame stamp-side pc-corp-way-card">
          <div class="ph pc-corp-way-card__media"><span>Hotel &amp; spa amenities</span></div>
          <span class="postmark pc-corp-way-card__pm"><div>HOTEL</div></span>
          <h3 class="h-display pc-corp-way-card__h">Your guests, our supplies.</h3>
          <p class="pc-corp-way-card__p">Refillable formats. Custom scents. Trusted by Resorts World Sentosa.</p>
          <a class="tlink" href="#enquiry">Enquire &rarr;</a>
        </div>
        <div class="stamp-frame stamp-side pc-corp-way-card">
          <div class="ph pc-corp-way-card__media"><span>Brand collaborations</span></div>
          <span class="postmark pc-corp-way-card__pm"><div>BRAND</div></span>
          <h3 class="h-display pc-corp-way-card__h">Build something together.</h3>
          <p class="pc-corp-way-card__p">Co-branded products. Workshops. Sustainable merch.</p>
          <a class="tlink" href="#enquiry">Enquire &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section pc-corp-how">
    <div class="container">
      <h2 class="h-display pc-corp-how__title">How it works.</h2>
      <div class="pc-corp-how__grid">
        <div class="pc-corp-how__cell"><div class="h-display pc-corp-how__num">01</div><div class="h-display pc-corp-how__h">Tell us.</div><p class="pc-corp-how__p">Form, volume, scent direction.</p></div>
        <div class="pc-corp-how__cell"><div class="h-display pc-corp-how__num">02</div><div class="h-display pc-corp-how__h">We propose.</div><p class="pc-corp-how__p">Within 2 working days.</p></div>
        <div class="pc-corp-how__cell"><div class="h-display pc-corp-how__num">03</div><div class="h-display pc-corp-how__h">Sample.</div><p class="pc-corp-how__p">Physical samples on orders &gt;$1,000.</p></div>
        <div class="pc-corp-how__cell"><div class="h-display pc-corp-how__num">04</div><div class="h-display pc-corp-how__h">We make.</div><p class="pc-corp-how__p">Singapore beauty kitchen.</p></div>
        <div class="pc-corp-how__cell"><div class="h-display pc-corp-how__num">05</div><div class="h-display pc-corp-how__h">We deliver.</div><p class="pc-corp-how__p">Pickup, courier, or direct.</p></div>
      </div>
    </div>
  </section>

  <section class="section" id="enquiry">
    <div class="container pc-corp-form__inner">
      <div>
        <div class="eyebrow">Tell us what you need</div>
        <h2 class="h-display pc-corp-form__title">We reply in 2 working days.</h2>
        <p class="pc-corp-form__sub">No bots, just Postcard humans.</p>
        <div class="script pc-corp-form__sig">&mdash; Hildra &amp; team</div>
      </div>
      {%- form 'contact', class: 'pc-corp-form__form' -%}
        <input type="hidden" name="contact[tags]" value="corporate">
        <div class="pc-corp-form__field">
          <label class="eyebrow">Your name *</label>
          <input type="text" name="contact[name]" required>
        </div>
        <div class="pc-corp-form__field">
          <label class="eyebrow">Company name *</label>
          <input type="text" name="contact[company]" required>
        </div>
        <div class="pc-corp-form__field">
          <label class="eyebrow">Work email *</label>
          <input type="email" name="contact[email]" required>
        </div>
        <div class="pc-corp-form__field">
          <label class="eyebrow">Phone (optional)</label>
          <input type="tel" name="contact[phone]">
        </div>
        <div class="pc-corp-form__field">
          <label class="eyebrow">I&rsquo;m interested in *</label>
          <div class="pc-corp-form__pills">
            {%- assign topics = 'Gifts,Hospitality,Collaboration,Workshop,Other' | split: ',' -%}
            {%- for t in topics -%}
              <label class="pc-corp-form__pill"><input type="radio" name="contact[topic]" value="{{ t }}"> {{ t }}</label>
            {%- endfor -%}
          </div>
        </div>
        <div class="pc-corp-form__field">
          <label class="eyebrow">Tell us more</label>
          <textarea name="contact[body]" rows="4"></textarea>
        </div>
        <button class="btn" type="submit">Send enquiry &rarr;</button>
      {%- endform -%}
    </div>
  </section>
</main>

{% schema %}
{
  "name": "Corporate page",
  "settings": [
    { "type": "text", "id": "pdf_link", "label": "One-pager PDF link", "default": "#" }
  ],
  "presets": [{ "name": "Corporate page" }]
}
{% endschema %}
