{%- comment -%}
  "From your worlds" section — same-world cross-sell from the logged-in
  customer's order history (snippets/customer-world-recs.liquid). Droppable on
  the homepage, account page, and product pages. Renders nothing for logged-out
  visitors or when there are no fresh suggestions, so it's safe everywhere.
  On a product page it excludes the current product.
{%- endcomment -%}
{%- liquid
  assign sec_bg = section.settings.bg_color
  assign exclude = nil
  if product
    assign exclude = product.id
  endif
-%}
{%- style -%}
  #pc-world-recs-{{ section.id }} {
    padding: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px 16px {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    {% if sec_bg != blank %}background: {{ sec_bg }};{% endif %}
  }
  @media screen and (min-width: 750px) {
    #pc-world-recs-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}
<section id="pc-world-recs-{{ section.id }}">
  <div class="pc-world-recs__wrap">
    {%- render 'customer-world-recs',
      heading: section.settings.heading,
      blurb: section.settings.blurb,
      limit: section.settings.limit,
      columns: section.settings.columns,
      exclude_id: exclude
    -%}
  </div>
</section>
{% schema %}
{
  "name": "From your worlds",
  "tag": "section",
  "settings": [
    { "type": "paragraph", "content": "Shows products from the worlds a logged-in customer has already bought into, excluding ones they own. Hidden for logged-out visitors and when there are no suggestions." },
    { "type": "text", "id": "heading", "label": "Heading", "default": "From your worlds" },
    { "type": "text", "id": "blurb", "label": "Sub-line", "default": "More from the worlds you love." },
    { "type": "range", "id": "limit", "label": "Max products", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "range", "id": "columns", "label": "Columns (desktop)", "min": 2, "max": 5, "step": 1, "default": 4 },
    { "type": "color", "id": "bg_color", "label": "Background" },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding_top", "label": "Top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 64 }
  ],
  "presets": [{ "name": "From your worlds" }]
}
{% endschema %}
