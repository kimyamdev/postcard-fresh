{%- liquid
  assign world = product.metafields.postcard.world.value
  if world
    assign world_color = world.accent_color.value
    assign world_theme_class = world.theme_class.value
    assign world_family = world.family.value
  endif
  assign world_color = world_color | default: '#E8C36A'
  assign world_theme_class = world_theme_class | default: 'world-hotel-lobby'
  assign world_family = world_family | default: 'Hesperidic Gourmand'
-%}

<div class="{{ world_theme_class }}" style="--world-color: {{ world_color }};">

  <div class="pc-breadcrumb">
    <div class="container pc-breadcrumb__inner">
      Home / Anywhere Fragrance / <span class="pc-breadcrumb__current">{{ product.title }}</span>
    </div>
  </div>

  <section class="pc-pdp-main">
    <div class="container pc-pdp-main__inner">
      {% render 'pdp-gallery', product: product, world_color: world_color, stamp_text: 'HOTEL<br>LOBBY<br>SG' %}
      {% render 'pdp-buy-box',
        product: product,
        world_color: world_color,
        ribbon_subline: world_family,
        demo_sizes: '30ml,100ml,Refill',
        demo_active_index: 2,
        refill_link_text: 'Or refill your bottle in store →' %}
    </div>
  </section>

</div>

{% schema %}
{
  "name": "Scent PDP",
  "settings": [],
  "presets": [{ "name": "Scent PDP" }]
}
{% endschema %}
