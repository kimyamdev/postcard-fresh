<section class="pc-sx">
  <div class="container pc-sx__inner">
    <div class="ph pc-sx__image"><span>{{ section.settings.image_caption }}</span></div>
    <div class="pc-sx__copy">
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h2 class="h-display pc-sx__title">{{ section.settings.title }}</h2>
      <p class="pc-sx__body">{{ section.settings.body }}</p>
    </div>
    <div class="pc-sx__ctas">
      <a class="btn btn--ink" href="{{ section.settings.primary_link }}">{{ section.settings.primary_text }}</a>
      <a class="tlink" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_text }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Storage cross-sell",
  "settings": [
    { "type": "text", "id": "image_caption", "label": "Image caption", "default": "tin · macro" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "A bar lives twice as long if you let it dry." },
    { "type": "text", "id": "title", "label": "Title", "default": "Add the travel tin." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Aluminum, ventilated lid, hand-stamped Java Jungle. Drains the bar between washes, slips into a carry-on. Doubles your washes per bar." },
    { "type": "text", "id": "primary_text", "label": "Primary CTA", "default": "Add tin · +S$14" },
    { "type": "text", "id": "primary_link", "label": "Primary link", "default": "#" },
    { "type": "text", "id": "secondary_text", "label": "Secondary CTA", "default": "Or buy the bundle (saves S$4) →" },
    { "type": "text", "id": "secondary_link", "label": "Secondary link", "default": "#" }
  ],
  "presets": [{ "name": "Storage cross-sell" }]
}
{% endschema %}
