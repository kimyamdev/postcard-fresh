<section class="section">
  <div class="container">
    <div class="pc-refill__intro">
      <div class="eyebrow">Refill, repeat, rejoice</div>
      <h2 class="h-display pc-refill__title">Bring it back. We&rsquo;ll top you up.</h2>
      <p class="pc-refill__lede">Visit our Orchard flagship. Less waste, same scent. Save 20% on every refill.</p>
    </div>
    <div class="pc-refill__grid">
      <div class="stamp-frame stamp-side pc-refill__card">
        <div class="pc-refill__card-head">
          <div class="h-display pc-refill__num">01</div>
          <div class="postmark postmark--yellow"><div>NO FOMO</div></div>
        </div>
        <div class="ph pc-refill__panel"><span>illustrated postcard panel</span></div>
        <h3 class="h-typewriter pc-refill__step-h">Bring it back.</h3>
        <p class="pc-refill__step-p">Empty Postcard bottle. Any size, any world.</p>
      </div>
      <div class="stamp-frame stamp-side pc-refill__card">
        <div class="pc-refill__card-head">
          <div class="h-display pc-refill__num">02</div>
          <div class="postmark postmark--yellow"><div>MADE FRESH</div></div>
        </div>
        <div class="ph pc-refill__panel"><span>illustrated postcard panel</span></div>
        <h3 class="h-typewriter pc-refill__step-h">We refill it.</h3>
        <p class="pc-refill__step-p">From the beauty kitchen. Same recipe, same scent.</p>
      </div>
      <div class="stamp-frame stamp-side pc-refill__card">
        <div class="pc-refill__card-head">
          <div class="h-display pc-refill__num">03</div>
          <div class="postmark postmark--yellow"><div>FOREVER<br>YOURS</div></div>
        </div>
        <div class="ph pc-refill__panel"><span>illustrated postcard panel</span></div>
        <h3 class="h-typewriter pc-refill__step-h">You go again.</h3>
        <p class="pc-refill__step-p">Less waste, same scent. Save 20% per visit.</p>
      </div>
    </div>
    <div class="pc-refill__ctas">
      <a class="btn" href="/pages/refill">See the refill list &rarr;</a>
      <a class="tlink" href="/pages/flagship">Find a store &rarr;</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Postcard Refill Trio",
  "settings": [],
  "presets": [{ "name": "Postcard Refill Trio" }]
}
{% endschema %}
