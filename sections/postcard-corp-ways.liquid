<section class="section">
  <div class="container">
    {%- if section.settings.title != blank -%}
      <h2 class="h-display pc-corp-ways__title">{{ section.settings.title }}</h2>
    {%- endif -%}
    <div class="pc-corp-ways__grid">
      {%- for block in section.blocks -%}
        {%- assign card_alt = block.settings.heading | default: 'Way card' | escape -%}
        <div class="stamp-frame stamp-side pc-corp-way-card" {{ block.shopify_attributes }}>
          <div class="ph pc-corp-way-card__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: alt: card_alt, loading: 'lazy' }}
            {%- else -%}
              <span>{{ block.settings.image_placeholder | default: 'image' }}</span>
            {%- endif -%}
          </div>
          <span class="postmark pc-corp-way-card__pm"><div>{{ block.settings.postmark_html }}</div></span>
          <h3 class="h-display pc-corp-way-card__h">{{ block.settings.heading }}</h3>
          <p class="pc-corp-way-card__p">{{ block.settings.body }}</p>
          {%- if block.settings.cta_text != blank -%}
            <a class="tlink" href="{{ block.settings.cta_url | default: '#enquiry' }}">{{ block.settings.cta_text }}</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Corporate · Ways",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Three ways we work together." }
  ],
  "blocks": [
    {
      "type": "way",
      "name": "Way card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_placeholder", "label": "Placeholder text", "default": "Corporate gifts & hampers" },
        { "type": "html", "id": "postmark_html", "label": "Postmark text (HTML)", "default": "CORPORATE" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Send a gift they'll keep." },
        { "type": "textarea", "id": "body", "label": "Body", "default": "From $80 / recipient. Bespoke wrap. Logo print available." },
        { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Enquire →" },
        { "type": "url", "id": "cta_url", "label": "CTA link" }
      ]
    }
  ],
  "presets": [{
    "name": "Corporate · Ways",
    "blocks": [
      { "type": "way", "settings": { "image_placeholder": "Corporate gifts & hampers", "postmark_html": "CORPORATE", "heading": "Send a gift they'll keep.", "body": "From $80 / recipient. Bespoke wrap. Logo print available." }},
      { "type": "way", "settings": { "image_placeholder": "Hotel & spa amenities", "postmark_html": "HOTEL", "heading": "Your guests, our supplies.", "body": "Refillable formats. Custom scents. Trusted by Resorts World Sentosa." }},
      { "type": "way", "settings": { "image_placeholder": "Brand collaborations", "postmark_html": "BRAND", "heading": "Build something together.", "body": "Co-branded products. Workshops. Sustainable merch." }}
    ]
  }]
}
{% endschema %}
