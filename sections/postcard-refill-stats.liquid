<section class="section--tight section">
  <div class="container">
    <div class="pc-refill-stats">
      {%- for block in section.blocks -%}
        <div class="pc-refill-stat" {{ block.shopify_attributes }}>
          <div class="h-display pc-refill-stat__n">{{ block.settings.number }}</div>
          <div class="eyebrow pc-refill-stat__t">{{ block.settings.label }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Refill · Stats",
  "tag": "section",
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "20%" },
        { "type": "text", "id": "label", "label": "Label", "default": "off every refill" }
      ]
    }
  ],
  "presets": [{
    "name": "Refill · Stats",
    "blocks": [
      { "type": "stat", "settings": { "number": "20%", "label": "off every refill" }},
      { "type": "stat", "settings": { "number": "80%", "label": "less packaging per top-up" }},
      { "type": "stat", "settings": { "number": "0", "label": "label waste" }}
    ]
  }]
}
{% endschema %}
