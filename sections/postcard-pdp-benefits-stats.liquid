{%- liquid
  assign world_color = product.metafields.postcard.world.value.accent_color.value | default: '#9CC4D6'
-%}
<section class="section pc-bs" style="--world-color: {{ world_color }};">
  <div class="container">
    <div class="pc-bs__head">
      <span class="pc-bs__pill" style="background: {{ world_color }}22;">{{ section.settings.eyebrow }}</span>
      <h2 class="h-display pc-bs__title">{{ section.settings.title }}</h2>
    </div>
    <div class="pc-bs__grid">
      {%- for block in section.blocks -%}
        <div class="stamp-frame stamp-side pc-bs__card" {{ block.shopify_attributes }}>
          <span class="postmark pc-bs__pm"><div>{{ block.settings.heading | upcase }}</div></span>
          <h3 class="h-display pc-bs__heading">{{ block.settings.heading }}.</h3>
          <div class="pc-bs__metric">{{ block.settings.metric }}</div>
          <p class="pc-bs__body">{{ block.settings.body }}</p>
        </div>
      {%- endfor -%}
    </div>
    {%- if section.settings.tagline != blank -%}
      <p class="h-typewriter pc-bs__tagline">{{ section.settings.tagline }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Benefits stats",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Pill text", "default": "Active hydration" },
    { "type": "text", "id": "title", "label": "Title", "default": "What it does." },
    { "type": "textarea", "id": "tagline", "label": "Tagline below grid" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading (e.g. Plumps)" },
        { "type": "text", "id": "metric", "label": "Metric line" },
        { "type": "textarea", "id": "body", "label": "Body" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits stats",
      "blocks": [
        { "type": "stat", "settings": { "heading": "Plumps", "metric": "+47% surface volume", "body": "In 7 days. Independently tested on 32 humans." } },
        { "type": "stat", "settings": { "heading": "Hydrates", "metric": "12-hr lasting hydration", "body": "Multi-weight HA holds 1000× its weight in water." } },
        { "type": "stat", "settings": { "heading": "Glows", "metric": "+82% reported \"bouncier\"", "body": "Dermatologist consumer panel · 4 weeks." } }
      ]
    }
  ]
}
{% endschema %}
