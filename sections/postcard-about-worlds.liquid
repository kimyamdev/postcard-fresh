<section class="section--tight section pc-about-worlds">
  <div class="container">
    {%- if section.settings.title != blank -%}
      <h2 class="h-display pc-about-worlds__title">{{ section.settings.title }}</h2>
    {%- endif -%}
    <div class="pc-about-worlds__strip">
      {%- for block in section.blocks -%}
        <div class="pc-about-worlds__cell" {{ block.shopify_attributes }}>
          {%- if block.settings.show_family and block.settings.family != blank -%}
            {% render 'stamp', name: block.settings.name, family: block.settings.family, color: block.settings.color, size: 'sm' %}
          {%- else -%}
            {% render 'stamp', name: block.settings.name, color: block.settings.color, size: 'sm' %}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About · Worlds index",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "22 worlds. One bathroom shelf at a time." }
  ],
  "blocks": [
    {
      "type": "world_stamp",
      "name": "World stamp",
      "settings": [
        { "type": "text", "id": "name", "label": "World name", "default": "Hotel Lobby" },
        { "type": "color", "id": "color", "label": "Color", "default": "#E8C36A" },
        { "type": "checkbox", "id": "show_family", "label": "Show family label", "default": false },
        { "type": "text", "id": "family", "label": "Family (optional)", "default": "Hesperidic Gourmand" }
