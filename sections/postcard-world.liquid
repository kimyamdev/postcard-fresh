{%- liquid
  assign world = page.metafields.custom.world.value
  if world
    assign world_name = world.name.value
    assign world_family = world.family.value
    assign world_tagline = world.tagline.value
    assign world_color = world.accent_color.value
    assign world_theme_class = world.theme_class.value
    assign world_slug = world.slug.value
    assign world_wear_notes = world.wear_notes_quote.value
    assign world_character_label = world.character_label.value
    assign world_character_desc = world.character_description.value
  endif
  assign world_wear_notes = world_wear_notes | default: 'Bright then cozy. Reads as unisex but leans slightly feminine. Year-round, but especially welcoming in cooler weather.'
  assign world_character_label = world_character_label | default: 'Unisex · Year-round'
  assign world_character_desc = world_character_desc | default: 'Reads polite, leans cosy in cooler weather.'
-%}

{%- if world -%}
<div class="{{ world_theme_class }}" style="--world-color: {{ world_color }}; --world-tint: {{ world_color }}1f;">

  <div class="pc-breadcrumb">
    <div class="container pc-breadcrumb__inner">Home / Worlds / <span class="pc-breadcrumb__current">{{ world_name }}</span></div>
  </div>

  <section class="pc-world-hero">
    <div class="container pc-world-hero__inner">
      <div class="pc-world-hero__stamp">
        {% render 'stamp', name: world_name, family: world_family, color: world_color, size: 'lg' %}
      </div>
      <div>
        <div class="eyebrow">{{ world_family }}</div>
        <h1 class="h-typewriter pc-world-hero__title">{{ world_name }}.</h1>
        <p class="pc-world-hero__lede">{{ world_tagline }}</p>
        <div class="script pc-world-hero__sig">greetings from the {{ world_name | downcase }}.</div>
      </div>
    </div>
  </section>

  {%- liquid
    assign scent_notes = world.scent_notes.value
    assign top_arr = ''
    assign heart_arr = ''
    assign base_arr = ''
    if scent_notes
      for n in scent_notes
        case n.family.value
          when 'Top'
            if top_arr == ''
              assign top_arr = n.name.value
            else
              assign top_arr = top_arr | append: ', ' | append: n.name.value
            endif
          when 'Heart'
            if heart_arr == ''
              assign heart_arr = n.name.value
            else
              assign heart_arr = heart_arr | append: ', ' | append: n.name.value
            endif
          when 'Base'
            if base_arr == ''
              assign base_arr = n.name.value
            else
              assign base_arr = base_arr | append: ', ' | append: n.name.value
            endif
        endcase
      endfor
    endif
    if top_arr == '' and world.notes_top.value != blank
      assign top_arr = world.notes_top.value | join: ', '
    endif
    if heart_arr == '' and world.notes_heart.value != blank
      assign heart_arr = world.notes_heart.value | join: ', '
    endif
    if base_arr == '' and world.notes_base.value != blank
      assign base_arr = world.notes_base.value | join: ', '
    endif
    assign top_arr = top_arr | default: 'Bergamot, Orange Blossom'
    assign heart_arr = heart_arr | default: 'Earl Grey Tea, Apricot'
    assign base_arr = base_arr | default: 'Vanilla, White Musk'
  -%}

  <section class="section section--tight">
    <div class="container">
      <div class="pc-scent__head">
        <div class="eyebrow">How it&rsquo;s built</div>
        <h2 class="h-display pc-scent__title">The scent breakdown.</h2>
      </div>
      <div class="pc-scent__table">
        <div class="pc-scent__row">
          <div class="h-display pc-scent__layer">Top</div>
          <div class="pc-scent__notes">{{ top_arr }}</div>
          <div class="pc-scent__desc">The bright doorway moment.</div>
        </div>
        <div class="pc-scent__row">
          <div class="h-display pc-scent__layer">Heart</div>
          <div class="pc-scent__notes">{{ heart_arr }}</div>
          <div class="pc-scent__desc">Warm tea steam, soft fruit.</div>
        </div>
        <div class="pc-scent__row">
          <div class="h-display pc-scent__layer">Base</div>
          <div class="pc-scent__notes">{{ base_arr }}</div>
          <div class="pc-scent__desc">The settled, skin-like finish.</div>
        </div>
        <div class="pc-scent__row pc-scent__row--last">
          <div class="h-display pc-scent__layer">Character</div>
          <div class="pc-scent__notes">{{ world_character_label }}</div>
          <div class="pc-scent__desc">{{ world_character_desc }}</div>
        </div>
      </div>
    </div>
  </section>

  <section class="pc-world-quote">
    <div class="container--narrow pc-world-quote__inner">
      <span class="postmark pc-world-quote__pm"><div>WEAR<br>NOTES</div></span>
      <p class="h-typewriter pc-world-quote__text">
        &ldquo;{{ world_wear_notes }}&rdquo;
      </p>
    </div>
  </section>

  <section class="section pc-world-rituals">
    <div class="container">
      <div class="pc-ritual">
        <div class="pc-ritual__head">
          <h2 class="h-display pc-ritual__title">On your skin.</h2>
          <a class="tlink" href="/collections/{{ world_slug }}-skin">View all &rarr;</a>
        </div>
        <div class="pc-ritual__grid">
          {% render 'product-card', name: world_name | append: ' Hand & Body Wash', world: world_name, world_color: world_color, price: '$32', badge: 'Refillable', href: '/products/' | append: world_slug | append: '-hand-and-body-wash' %}
          {% render 'product-card', name: world_name | append: ' Body Oil', world: world_name, world_color: world_color, price: '$38', href: '/products/' | append: world_slug | append: '-body-oil' %}
          {% render 'product-card', name: world_name | append: ' Hand Cream', world: world_name, world_color: world_color, price: '$24', href: '/products/' | append: world_slug | append: '-hand-cream' %}
          {% render 'product-card', name: world_name | append: ' Deodorant Spray', world: world_name, world_color: world_color, price: '$26', href: '/products/' | append: world_slug | append: '-deodorant-spray' %}
        </div>
      </div>

      <div class="pc-ritual">
        <div class="pc-ritual__head">
          <h2 class="h-display pc-ritual__title">In the room.</h2>
          <a class="tlink" href="/collections/{{ world_slug }}-room">View all &rarr;</a>
        </div>
        <div class="pc-ritual__grid">
          {% render 'product-card', name: world_name | append: ' Anywhere Fragrance', world: world_name, world_color: world_color, price: '$42' %}
          {% render 'product-card', name: world_name | append: ' Reed Diffuser', world: world_name, world_color: world_color, price: '$48' %}
          {% render 'product-card', name: world_name | append: ' Reed Diffuser Refill', world: world_name, world_color: world_color, price: '$28', badge: 'Refill' %}
          {% render 'product-card', name: world_name | append: ' Travel Mist', world: world_name, world_color: world_color, price: '$22' %}
        </div>
      </div>

      <div class="pc-ritual">
        <div class="pc-ritual__head">
          <h2 class="h-display pc-ritual__title">Travel-size.</h2>
          <a class="tlink" href="/collections/{{ world_slug }}-travel">View all &rarr;</a>
        </div>
        <div class="pc-ritual__grid">
          {% render 'product-card', name: 'Mini ' | append: world_name | append: ' Anywhere Fragrance', world: world_name, world_color: world_color, price: '$18' %}
          {% render 'product-card', name: 'Mini ' | append: world_name | append: ' Body Wash', world: world_name, world_color: world_color, price: '$14' %}
          {% render 'product-card', name: 'Mini ' | append: world_name | append: ' Hand Cream', world: world_name, world_color: world_color, price: '$12' %}
          {% render 'product-card', name: 'Mini ' | append: world_name | append: ' Deodorant', world: world_name, world_color: world_color, price: '$10' %}
        </div>
      </div>
    </div>
  </section>

  <section class="section--tight section pc-world-neighbours">
    <div class="container">
      <div class="eyebrow">If you love {{ world_name }}</div>
      <h2 class="h-display pc-world-neighbours__title">&hellip;send yourself a postcard from:</h2>
      <div class="pc-neighbours">
        {%- assign all_worlds = shop.metaobjects.world.values -%}
        {%- assign shown = 0 -%}
        {%- for w in all_worlds -%}
          {%- if shown >= 3 -%}{%- break -%}{%- endif -%}
          {%- assign w_slug = w.slug.value | default: w.handle -%}
          {%- if w_slug != world_slug -%}
            {%- assign w_name = w.name.value -%}
            {%- assign w_family = w.family.value -%}
            {%- assign w_color = w.accent_color.value | default: '#E8C36A' -%}
            {%- assign w_tagline = w.tagline.value -%}
            <a class="pc-neighbour" href="/pages/{{ w_slug }}">
              {% render 'stamp', name: w_name, family: w_family, color: w_color, size: 'sm' %}
              <div>
                {%- if w_family != blank -%}
                  <div class="eyebrow">{{ w_family }}</div>
                {%- endif -%}
                <h3 class="h-display pc-neighbour__name">{{ w_name }}</h3>
                {%- if w_tagline != blank -%}
                  <p class="pc-neighbour__tag">{{ w_tagline }}</p>
                {%- endif -%}
              </div>
            </a>
            {%- assign shown = shown | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  <section class="pc-world-refill">
    <div class="container pc-world-refill__inner">
      <h3 class="h-display pc-world-refill__title">Refill your {{ world_name }} in store.</h3>
      <a class="btn btn--ink" href="/pages/flagship">Visit our Orchard flagship &rarr;</a>
    </div>
  </section>

</div>
{%- else -%}
<section class="section">
  <div class="container">
    <div class="eyebrow">Missing world</div>
    <p>This page isn&rsquo;t linked to a world metaobject yet. In admin, edit this page and set the &ldquo;World&rdquo; metafield.</p>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "World page",
  "settings": [],
  "presets": [{ "name": "World page" }]
}
{% endschema %}
