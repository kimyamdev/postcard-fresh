{%- comment -%}
  Renders a list of worlds from shop.metaobjects.world.values. Filtered by
  tier (matches world.tier.value, which the world metaobject's "Tier" field
  enforces from a fixed choice list). Designed to be used multiple times on
  the worlds index page — once per tier.

  Tier "" (any) skips the filter; useful when admin wants all worlds in
  one rail, or for the legacy positional behavior via start_index + count.
{%- endcomment -%}

{%- liquid
  assign all_worlds = shop.metaobjects.world.values
  assign worlds_total = all_worlds.size
  assign size = section.settings.size | default: 'md'
  assign tier_filter = section.settings.tier
  assign start_index = section.settings.start_index | default: 1
  assign count = section.settings.count | default: 24
  assign show_meta = section.settings.show_meta
  if show_meta == nil
    assign show_meta = true
  endif
  assign hide_if_empty = section.settings.hide_if_empty
  if hide_if_empty == nil
    assign hide_if_empty = true
  endif

  assign skip = start_index | minus: 1
  if skip < 0
    assign skip = 0
  endif
  assign emitted = 0
  assign passed = 0
-%}

{%- capture cards -%}
  {%- for w in all_worlds -%}
    {%- if emitted >= count -%}{%- break -%}{%- endif -%}
    {%- if tier_filter != blank and tier_filter != 'any' -%}
      {%- assign w_tier = w.tier.value -%}
      {%- if w_tier != tier_filter -%}{%- continue -%}{%- endif -%}
    {%- endif -%}
    {%- if passed < skip -%}
      {%- assign passed = passed | plus: 1 -%}
      {%- continue -%}
    {%- endif -%}
    {%- assign w_slug = w.slug.value | default: w.handle -%}
    {%- assign w_color = w.accent_color.value | default: '#E8C36A' -%}
    {%- assign w_name = w.name.value -%}
    {%- assign w_family = w.family.value -%}
    {%- assign w_tagline = w.tagline.value -%}
    {%- if show_meta -%}
      <a class="pc-worlds-index__card" href="/pages/{{ w_slug }}">
        {% render 'stamp', name: w_name, family: w_family, color: w_color, size: size %}
        <div>
          {%- if w_family != blank -%}
            <div class="eyebrow">{{ w_family }}</div>
          {%- endif -%}
          <h3 class="h-display pc-worlds-index__card-name">{{ w_name }}</h3>
          {%- if w_tagline != blank -%}
            <p class="pc-worlds-index__card-tag">{{ w_tagline }}</p>
          {%- endif -%}
        </div>
      </a>
    {%- else -%}
      <a class="pc-worlds-index__stamp-link" href="/pages/{{ w_slug }}">
        {% render 'stamp', name: w_name, family: w_family, color: w_color, size: size %}
      </a>
    {%- endif -%}
    {%- assign emitted = emitted | plus: 1 -%}
  {%- endfor -%}
{%- endcapture -%}

{%- if emitted > 0 or hide_if_empty == false -%}
  <section class="section pc-worlds-list">
    <div class="container">
      {%- if section.settings.eyebrow != blank -%}
        <div class="eyebrow" style="margin-bottom: 16px;">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      {%- if show_meta -%}
        <div class="pc-worlds-index__core">{{ cards }}</div>
      {%- else -%}
        <div class="pc-worlds-index__minor">{{ cards }}</div>
      {%- endif -%}
      {%- if emitted == 0 -%}
        <p class="pc-ritual__empty-text">No worlds found in this range. Adjust “Start at” / “Count”, or add more world entries under Custom data → Metaobjects → World.</p>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Worlds index · List",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow / heading", "default": "Six core fragrance worlds" },
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "size", "label": "Stamp size", "default": "md",
      "options": [
        { "value": "lg", "label": "Large" },
        { "value": "md", "label": "Medium" },
        { "value": "sm", "label": "Small" }
      ]
    },
    { "type": "checkbox", "id": "show_meta", "label": "Show family + tagline next to each stamp", "default": true, "info": "Off → just stamps in a row, useful for the secondary worlds strip." },
    { "type": "header", "content": "Tier filter" },
    { "type": "select", "id": "tier", "label": "Tier", "default": "Core",
      "options": [
        { "value": "any",         "label": "Any (all worlds)" },
        { "value": "Core",        "label": "Core" },
        { "value": "Skin & body", "label": "Skin & body" },
        { "value": "Wellness",    "label": "Wellness" },
        { "value": "Speciality",  "label": "Speciality" }
      ],
      "info": "Filters by the World metaobject's Tier field. Add new options in admin → Custom data → Metaobjects → World → Tier validations."
    },
    { "type": "header", "content": "Range (within filtered tier)" },
    { "type": "range", "id": "start_index", "label": "Start at #", "min": 1, "max": 30, "step": 1, "default": 1, "info": "1-based position in the filtered list." },
    { "type": "range", "id": "count",       "label": "How many",   "min": 1, "max": 24, "step": 1, "default": 24, "info": "Cap on rendered worlds; defaults to all in the tier." },
    { "type": "checkbox", "id": "hide_if_empty", "label": "Hide section if no worlds in range", "default": true }
  ],
  "presets": [{ "name": "Worlds index · List" }]
}
{% endschema %}
