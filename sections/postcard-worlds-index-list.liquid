{%- comment -%}
  Renders a list of worlds from shop.metaobjects.world.values, filtered by
  tier. Designed to be used multiple times on the worlds index page — once
  per tier (Core, Skin & body, Wellness, Speciality, …).

  Each card shows: stamp + family eyebrow + name + tagline + featured
  products preview row. Featured products come from
  world.featured_products.value (list.product_reference); admin curates 2–4
  per world in admin → Custom data → Metaobjects → World → Featured products.
  When the list is empty the row is skipped — no clutter.

  Tier "any" disables the filter (useful for a single combined rail).
{%- endcomment -%}

{%- liquid
  assign all_worlds = shop.metaobjects.world.values
  assign size = section.settings.size | default: 'md'
  assign tier_filter = section.settings.tier
  assign start_index = section.settings.start_index | default: 1
  assign count = section.settings.count | default: 24
  assign preview_mode = section.settings.preview_mode | default: 'categories'
  assign hide_if_empty = section.settings.hide_if_empty
  if hide_if_empty == nil
    assign hide_if_empty = true
  endif

  assign skip = start_index | minus: 1
  if skip < 0
    assign skip = 0
  endif
  assign emitted = 0
  assign passed = 0
  assign type_limit = section.settings.type_limit | default: 4
-%}

{%- capture cards -%}
  {%- for w in all_worlds -%}
    {%- if emitted >= count -%}{%- break -%}{%- endif -%}
    {%- if tier_filter != blank and tier_filter != 'any' -%}
      {%- assign w_tier = w.tier.value -%}
      {%- if w_tier != tier_filter -%}{%- continue -%}{%- endif -%}
    {%- endif -%}
    {%- if passed < skip -%}
      {%- assign passed = passed | plus: 1 -%}
      {%- continue -%}
    {%- endif -%}
    {%- assign w_slug = w.slug.value | default: w.handle -%}
    {%- assign w_color = w.accent_color.value | default: '#E8C36A' -%}
    {%- assign w_name = w.name.value -%}
    {%- assign w_family = w.family.value -%}
    {%- assign w_tagline = w.tagline.value -%}
    {%- assign w_featured = w.featured_products.value -%}

    {%- comment -%} Build preview text based on mode {%- endcomment -%}
    {%- assign preview_html = '' -%}
    {%- if preview_mode == 'product_types' -%}
      {%- assign w_collection_handle = w_slug | append: '-collection' -%}
      {%- assign w_collection = collections[w_collection_handle] -%}
      {%- assign types_present = '' -%}
      {%- assign types_count = 0 -%}
      {%- if w_collection.id -%}
        {%- for p in w_collection.products limit: 50 -%}
          {%- if types_count >= type_limit -%}{%- break -%}{%- endif -%}
          {%- assign t = p.type -%}
          {%- if t == blank -%}{%- continue -%}{%- endif -%}
          {%- assign t_marker = '|' | append: t | append: '|' -%}
          {%- unless types_present contains t_marker -%}
            {%- if types_present == blank -%}
              {%- assign types_present = t_marker -%}
            {%- else -%}
              {%- assign types_present = types_present | append: t | append: '|' -%}
            {%- endif -%}
            {%- assign types_count = types_count | plus: 1 -%}
          {%- endunless -%}
        {%- endfor -%}
      {%- endif -%}
      {%- if types_present != blank -%}
        {%- assign type_arr = types_present | split: '|' -%}
        {%- capture preview_html -%}
          <div class="pc-worlds-index__chips-block">
            <div class="eyebrow pc-worlds-index__chips-label">Available in</div>
            <div class="pc-worlds-index__chips" style="--world-color: {{ w_color }};">
              {%- for label in type_arr -%}
                {%- if label == blank -%}{%- continue -%}{%- endif -%}
                <span class="pc-worlds-index__chip">{{ label }}</span>
              {%- endfor -%}
            </div>
          </div>
        {%- endcapture -%}
      {%- endif -%}
    {%- elsif preview_mode == 'products' -%}
      {%- if w_featured.size > 0 -%}
        {%- capture preview_html -%}
          <div class="pc-worlds-index__chips-block">
            <div class="eyebrow pc-worlds-index__chips-label">Featured</div>
            <div class="pc-worlds-index__chips" style="--world-color: {{ w_color }};">
              {%- for fp in w_featured -%}
                <span class="pc-worlds-index__chip">{{ fp.title }}</span>
              {%- endfor -%}
            </div>
          </div>
        {%- endcapture -%}
      {%- endif -%}
    {%- endif -%}

    {%- assign w_video = w.hero_video.value -%}
    <a class="pc-worlds-index__card" href="/pages/{{ w_slug }}"
       x-data
       @mouseenter="$el.querySelector('.pc-stamp__hover-vid')?.play()"
       @mouseleave="$el.querySelector('.pc-stamp__hover-vid')?.pause()">
      {% render 'stamp', name: w_name, family: w_family, color: w_color, size: size, video: w_video %}
      <div>
        {%- if w_family != blank -%}
          <div class="eyebrow">{{ w_family }}</div>
        {%- endif -%}
        <h3 class="h-display pc-worlds-index__card-name">{{ w_name }}</h3>
        {%- if w_tagline != blank -%}
          <p class="pc-worlds-index__card-tag">{{ w_tagline }}</p>
        {%- endif -%}
        {{ preview_html }}
      </div>
    </a>
    {%- assign emitted = emitted | plus: 1 -%}
  {%- endfor -%}
{%- endcapture -%}

{%- if emitted > 0 or hide_if_empty == false -%}
  <section class="section pc-worlds-list">
    <div class="container">
      {%- if section.settings.eyebrow != blank -%}
        <div class="eyebrow" style="margin-bottom: 16px;">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      <div class="pc-worlds-index__core">{{ cards }}</div>
      {%- if emitted == 0 -%}
        <p class="pc-ritual__empty-text">No worlds in this tier yet. Set the <strong>Tier</strong> field on the world metaobject to <code>{{ tier_filter }}</code>.</p>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Worlds index · List",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow / heading", "default": "Core fragrance worlds" },
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "size", "label": "Stamp size", "default": "md",
      "options": [
        { "value": "lg", "label": "Large" },
        { "value": "md", "label": "Medium" },
        { "value": "sm", "label": "Small" }
      ]
    },
    { "type": "select", "id": "preview_mode", "label": "Preview row", "default": "product_types",
      "options": [
        { "value": "product_types", "label": "Product types (auto: from Shopify product type)" },
        { "value": "products",      "label": "Featured product titles (manually picked)" },
        { "value": "none",          "label": "None" }
      ],
      "info": "Product types are pulled from each product's Shopify Product type field, deduped per world. Featured products read world.featured_products."
    },
    { "type": "range", "id": "type_limit", "label": "Max product types per card", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "header", "content": "Tier filter" },
    { "type": "select", "id": "tier", "label": "Tier", "default": "World",
      "options": [
        { "value": "any",       "label": "Any (all entries)" },
        { "value": "World",     "label": "Worlds" },
        { "value": "Non-world", "label": "Non-worlds" }
      ]
    },
    { "type": "header", "content": "Range (within filtered tier)" },
    { "type": "range", "id": "start_index", "label": "Start at #", "min": 1, "max": 30, "step": 1, "default": 1 },
    { "type": "range", "id": "count",       "label": "How many",   "min": 1, "max": 24, "step": 1, "default": 24 },
    { "type": "checkbox", "id": "hide_if_empty", "label": "Hide section if no worlds in range", "default": true }
  ],
  "presets": [{ "name": "Worlds index · List" }]
}
{% endschema %}
