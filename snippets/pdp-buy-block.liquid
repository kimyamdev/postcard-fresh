{%- comment -%}
  Renders one block of the PDP buy box. Caller passes:
    block             section block
    product           Shopify product
    world_color       hex
    world_name        e.g. "Hotel Lobby"
    ribbon_subline    e.g. "Hand & Body Wash" — used when block.settings.subline is blank
    current           selected_or_first_available_variant
    discount_pct      subscribe & save percent (defaults to 10)
{%- endcomment -%}

{%- liquid
  assign world_color = world_color | default: '#5C6688'
  assign world_name = world_name | default: 'Postcard'
  assign ribbon_subline = ribbon_subline | default: 'Hand & Body Wash'
  assign discount_pct = discount_pct | default: 10
  assign refillable = product.metafields.custom.refillable.value | default: false
  assign current = current | default: product.selected_or_first_available_variant
-%}

{%- case block.type -%}

{%- when 'ribbon' -%}
  {%- assign world_linked = product.metafields.postcard.world.value | default: product.metafields.custom.world.value -%}
  {%- if world_linked and world_name != blank -%}
    {%- assign mf_ribbon = product.metafields.pdp.ribbon_subline.value -%}
    {%- assign subline = block.settings.subline_override | default: mf_ribbon | default: ribbon_subline -%}
    <div class="pc-pdp-buy__ribbon" {{ block.shopify_attributes }}>
      <span class="pc-pdp-buy__chip" style="background: {{ world_color }};"></span>
      <span class="eyebrow">{{ world_name }} &middot; {{ subline }}</span>
    </div>
  {%- endif -%}

{%- when 'title' -%}
  <h1 class="h-typewriter pc-pdp-buy__title" {{ block.shopify_attributes }}>{{ product.title }}</h1>

{%- when 'description' -%}
  {%- if product.description != blank -%}
    {%- assign limit = block.settings.word_limit | default: 30 -%}
    <p class="pc-pdp-buy__sub" {{ block.shopify_attributes }}>{{ product.description | strip_html | truncatewords: limit }}</p>
  {%- endif -%}

{%- when 'rating' -%}
  {%- liquid
    assign sp_count = product.metafields.stamped.reviews_count.value | plus: 0
    assign sp_avg_raw = product.metafields.stamped.reviews_average.value | default: 0
    assign sp_tenths = sp_avg_raw | times: 10 | round
    assign sp_int = sp_tenths | divided_by: 10
    assign sp_dec = sp_tenths | modulo: 10
    assign sp_filled = sp_avg_raw | round
  -%}
  {%- if sp_count > 0 -%}
    <div class="pc-pdp-buy__rating" {{ block.shopify_attributes }}>
      <span class="pc-pdp-buy__stars" aria-label="Rated {{ sp_int }}.{{ sp_dec }} out of 5">
        {%- for i in (1..5) -%}
          {%- if i <= sp_filled -%}&#9733;{%- else -%}&#9734;{%- endif -%}
        {%- endfor -%}
      </span>
      <span class="pc-pdp-buy__rating-text">
        <span class="pc-pdp-buy__rating-score">{{ sp_int }}.{{ sp_dec }}</span>
        &middot;
        <a class="pc-pdp-buy__rating-link" href="#pc-stamped-reviews">{{ sp_count }} review{% if sp_count != 1 %}s{% endif %}</a>
      </span>
    </div>
  {%- endif -%}

{%- when 'sizes' -%}
  {%- if product.has_only_default_variant -%}
    <input type="hidden" name="id" value="{{ current.id }}" {{ block.shopify_attributes }}>
  {%- elsif product.options_with_values.size > 1 -%}
    <input type="hidden" name="id" :value="variantId" value="{{ current.id }}" {{ block.shopify_attributes }}>
    {%- for option in product.options_with_values -%}
      {%- assign opt_idx = forloop.index0 -%}
      <div class="pc-pdp-buy__option">
        <div class="eyebrow pc-pdp-buy__option-label">{{ option.name }}</div>
        <div class="pc-pdp-buy__sizes">
          {%- for value in option.values -%}
            {%- assign value_js = value | replace: '\', '\\' | replace: "'", "\'" -%}
            <label class="pc-pdp-buy__size-radio" x-show="valueAvailable({{ opt_idx }}, '{{ value_js }}')">
              <input type="radio"
                     name="pc_opt_{{ opt_idx }}"
                     value="{{ value | escape }}"
                     {% if value == option.selected_value %}checked{% endif %}
                     x-model="selectedOptions[{{ opt_idx }}]"
                     @change="pickOption({{ opt_idx }})">
              <span class="pc-pdp-buy__size">{{ value }}</span>
            </label>
          {%- endfor -%}
        </div>
      </div>
    {%- endfor -%}
  {%- else -%}
    {%- assign option_label = product.options.first | default: 'Size' -%}
    {%- assign size_label = block.settings.label -%}
    {%- if size_label == blank or size_label == 'Size' -%}
      {%- assign size_label = option_label -%}
    {%- endif -%}
    <div class="pc-pdp-buy__option" {{ block.shopify_attributes }}>
      <div class="eyebrow pc-pdp-buy__option-label">{{ size_label }}</div>
      <div class="pc-pdp-buy__sizes">
        {%- for v in product.variants -%}
          <label class="pc-pdp-buy__size-radio">
            <input type="radio" name="id" value="{{ v.id }}" {% if v == current %}checked{% endif %} @change="variantId = $event.target.value">
            <span class="pc-pdp-buy__size">{{ v.title }}</span>
          </label>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

{%- when 'purchase_options' -%}
  {%- liquid
    assign first_group = product.selling_plan_groups.first
    assign has_plans = false
    if first_group and first_group.selling_plans.size > 0
      assign has_plans = true
    endif
    assign sp_discount_pct = 0
    assign sub_label = block.settings.subscribe_label | default: 'Subscribe & save'
    if has_plans
      assign first_plan = first_group.selling_plans.first
      assign first_adj = first_plan.price_adjustments.first
      if first_adj.value_type == 'percentage'
        assign sp_discount_pct = first_adj.value
      endif
      if sp_discount_pct > 0
        assign sub_label = sub_label | append: ' ' | append: sp_discount_pct | append: '%'
      endif
      assign cadence_eyebrow = first_group.options.first | default: 'Deliver every'
    endif
  -%}
  <div class="pc-pdp-buy__option" {{ block.shopify_attributes }}>
    <div class="eyebrow pc-pdp-buy__option-label">{{ block.settings.label | default: 'Purchase options' }}</div>

    {%- if has_plans -%}
      <input type="hidden" name="selling_plan" :value="mode === 'sub' ? cadence : ''">
    {%- endif -%}

    <div class="pc-pdp-buy__po-box">
      <label class="pc-pdp-buy__po" :class="{ 'pc-pdp-buy__po--active': mode === 'once' }" @click="mode = 'once'">
        <span class="pc-pdp-buy__po-radio"><span class="pc-pdp-buy__po-dot" x-show="mode === 'once'"></span></span>
        <input type="radio" name="purchase_mode" value="once" x-model="mode" class="pc-pdp-buy__po-input">
        <span class="pc-pdp-buy__po-label">{{ block.settings.once_label | default: 'One-time purchase' }}</span>
        <span class="pc-pdp-buy__po-price" x-text="prices[variantId]">{{ current.price | money }}</span>
      </label>

      {%- if has_plans -%}
        <label class="pc-pdp-buy__po" :class="{ 'pc-pdp-buy__po--active': mode === 'sub' }" @click="mode = 'sub'">
          <span class="pc-pdp-buy__po-radio"><span class="pc-pdp-buy__po-dot" x-show="mode === 'sub'"></span></span>
          <input type="radio" name="purchase_mode" value="sub" x-model="mode" class="pc-pdp-buy__po-input">
          <span class="pc-pdp-buy__po-label">{{ sub_label }}</span>
          <span class="pc-pdp-buy__po-price" x-text="(window.PCSubPrices && window.PCSubPrices[variantId] && window.PCSubPrices[variantId][cadence]) || ''"></span>
        </label>
        <div x-show="mode === 'sub'" x-cloak class="pc-pdp-buy__cadence">
          <div class="eyebrow pc-pdp-buy__cadence-label">{{ cadence_eyebrow }}</div>
          <div class="pc-pdp-buy__cadence-pills">
            {%- for plan in first_group.selling_plans -%}
              {%- assign plan_label = plan.options.first.value | default: plan.name -%}
              <button type="button" class="pc-pdp-buy__cadence-pill" :class="{ 'pc-pdp-buy__cadence-pill--active': cadence === '{{ plan.id }}' }" @click.prevent="cadence = '{{ plan.id }}'">{{ plan_label }}</button>
            {%- endfor -%}
          </div>
          <p class="pc-pdp-buy__cadence-note">{{ block.settings.cadence_note | default: 'Skip, swap world, or cancel anytime — no postcards held hostage.' }}</p>
        </div>
      {%- endif -%}
    </div>

    {%- if has_plans -%}
      <button type="button" class="pc-pdp-buy__about" @click="subOpen = !subOpen">
        <span class="pc-pdp-buy__about-arrow" :class="{ 'pc-pdp-buy__about-arrow--open': subOpen }">&#9662;</span>
        {{ block.settings.about_label | default: 'About subscriptions' }}
      </button>
      <div x-show="subOpen" x-cloak class="pc-pdp-buy__about-info">
        {%- if block.settings.about_body != blank -%}
          {{ block.settings.about_body }}
        {%- else -%}
          Always {{ sp_discount_pct }}% off. Free shipping over S$60. Skip a delivery, swap to a different world, or cancel from your account in two clicks. Manage everything from your account in two clicks.
        {%- endif -%}
      </div>

      <script>
        window.PCSubPrices = window.PCSubPrices || {};
        {%- for v in product.variants -%}
          window.PCSubPrices["{{ v.id }}"] = {
            {%- for alloc in v.selling_plan_allocations -%}
              "{{ alloc.selling_plan.id }}": "{{ alloc.price | money }}"{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          };
        {%- endfor -%}
      </script>
    {%- endif -%}
  </div>

{%- when 'qty_and_cta' -%}
  <div class="pc-pdp-buy__qty-row" {{ block.shopify_attributes }}>
    <div class="pc-pdp-buy__qty">
      <button type="button" class="pc-pdp-buy__qty-btn" @click="if(qty>1)qty--">&minus;</button>
      <input type="number" name="quantity" min="1" :value="qty" x-model="qty" class="pc-pdp-buy__qty-input">
      <button type="button" class="pc-pdp-buy__qty-btn" @click="qty++">+</button>
    </div>
    <button type="submit" class="btn pc-pdp-buy__cta"{% unless current.available %} disabled{% endunless %}>
      {%- if current.available -%}
        {{ block.settings.cta_text | default: 'Add to bag' }} &middot; <span x-text="prices[variantId]">{{ current.price | money }}</span>
      {%- else -%}
        {{ block.settings.sold_out_text | default: 'Sold out' }}
      {%- endif -%}
    </button>
  </div>

{%- when 'refill_link' -%}
  {%- if refillable or block.settings.always_show -%}
    <a class="tlink pc-pdp-buy__refill-link" href="{{ block.settings.link | default: '/pages/refill' }}" {{ block.shopify_attributes }}>{{ block.settings.text | default: 'Or refill in store →' }}</a>
  {%- endif -%}

{%- when 'stock_indicator' -%}
  {%- if current.available -%}
    <div class="pc-pdp-buy__stock" {{ block.shopify_attributes }}>{{ block.settings.text | default: '• In stock · Ships in 1-2 days' }}</div>
  {%- endif -%}

{%- when 'trust_circles' -%}
  <div class="pc-pdp-buy__trust" {{ block.shopify_attributes }}>
    <div class="pc-pdp-buy__trust-item">
      <span class="pc-pdp-buy__trust-disc"></span>
      <span class="pc-pdp-buy__trust-label">{{ block.settings.label_1 | default: 'Made in SG' }}</span>
    </div>
    {%- if refillable or block.settings.always_show_refillable -%}
      <div class="pc-pdp-buy__trust-item">
        <span class="pc-pdp-buy__trust-disc"></span>
        <span class="pc-pdp-buy__trust-label">{{ block.settings.label_2 | default: 'Refillable' }}</span>
      </div>
    {%- endif -%}
    <div class="pc-pdp-buy__trust-item">
      <span class="pc-pdp-buy__trust-disc"></span>
      <span class="pc-pdp-buy__trust-label">{{ block.settings.label_3 | default: 'Cruelty-free' }}</span>
    </div>
    <div class="pc-pdp-buy__trust-item">
      <span class="pc-pdp-buy__trust-disc"></span>
      <span class="pc-pdp-buy__trust-label">{{ block.settings.label_4 | default: 'Vegan' }}</span>
    </div>
  </div>

{%- when 'tags_band' -%}
  {%- liquid
    assign has_refill = false
    if product.metafields.custom.refillable.value == true or product.tags contains 'Refillable' or product.tags contains 'refillable' or product.tags contains 'Refill'
      assign has_refill = true
    endif
    assign has_sub = false
    if product.metafields.custom.subscribable.value == true or product.selling_plan_groups.size > 0 or product.tags contains 'Subscribable' or product.tags contains 'subscribable'
      assign has_sub = true
    endif
    assign has_vegan = false
    if product.metafields.custom.vegan.value == true or product.tags contains 'Vegan' or product.tags contains 'vegan'
      assign has_vegan = true
    endif
    assign has_clean = false
    if product.metafields.custom.clean.value == true or product.tags contains 'Sulphate-free' or product.tags contains 'sulphate-free' or product.tags contains 'Clean'
      assign has_clean = true
    endif
  -%}
  {%- if has_refill or has_sub or has_vegan or has_clean -%}
    <div class="pc-pdp-tags">
      {%- if has_refill -%}<span class="pc-pdp-tag pc-pdp-tag--refill">{{ block.settings.refill_label | default: 'Refillable' }}</span>{%- endif -%}
      {%- if has_sub -%}<span class="pc-pdp-tag pc-pdp-tag--sub">{{ block.settings.sub_label | default: 'Subscribable' }}</span>{%- endif -%}
      {%- if has_vegan -%}<span class="pc-pdp-tag">{{ block.settings.vegan_label | default: 'Vegan' }}</span>{%- endif -%}
      {%- if has_clean -%}<span class="pc-pdp-tag">{{ block.settings.clean_label | default: 'Clean' }}</span>{%- endif -%}
    </div>
  {%- endif -%}

{%- when 'ingredients' -%}
  {%- assign ing = product.metafields.custom.ingredients -%}
  {%- if ing != blank -%}
    <details class="pc-pdp-collapse"{% if block.settings.open_by_default %} open{% endif %}>
      <summary class="pc-pdp-collapse__summary">{{ block.settings.heading | default: 'Ingredients' }}</summary>
      <div class="pc-pdp-collapse__body rte">{{ ing | metafield_tag }}</div>
    </details>
  {%- endif -%}

{%- when 'benefits' -%}
  {%- assign ben = product.metafields.custom.benefits -%}
  {%- if ben != blank -%}
    <details class="pc-pdp-collapse"{% if block.settings.open_by_default %} open{% endif %}>
      <summary class="pc-pdp-collapse__summary">{{ block.settings.heading | default: 'Benefits' }}</summary>
      <div class="pc-pdp-collapse__body rte">{{ ben | metafield_tag }}</div>
    </details>
  {%- endif -%}

{%- when 'use_cases' -%}
  {%- assign uc = product.metafields.custom.use_cases -%}
  {%- if uc != blank -%}
    <details class="pc-pdp-collapse"{% if block.settings.open_by_default %} open{% endif %}>
      <summary class="pc-pdp-collapse__summary">{{ block.settings.heading | default: 'Use case(s)' }}</summary>
      <div class="pc-pdp-collapse__body rte">{{ uc | metafield_tag }}</div>
    </details>
  {%- endif -%}

{%- endcase -%}
