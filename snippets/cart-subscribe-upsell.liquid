{%- comment -%}
  Inline "switch to subscription" upsell for a single cart line.

  Renders a compact "Refill & save" card under a one-off line whose
  product has selling plans, showing the dynamic per-delivery savings and
  letting the customer convert the line to a subscription (a "refill plan")
  at a chosen frequency without leaving the cart. When the line has qty > 1,
  a stepper lets them pick HOW MANY units to put on refill; the rest stay one-off.
  PostcardCart.upgradeLineToPlan adds the chosen quantity as a new selling-plan
  line and reduces the one-off line, then the cart re-renders.

  Renders NOTHING when:
    - the line is already on a selling plan (item.selling_plan_allocation), or
    - the product has no selling plan groups (not subscribable).
  So it stays fully dormant until selling plans are configured in admin.

  Accepts:
    item     cart line item (required)
    layout   'drawer' to span the full grid row (thumbnail-left to price-right);
             omit on the /cart page where it sits within the details column.
{%- endcomment -%}

{%- liquid
  assign sp_groups = item.product.selling_plan_groups
  assign already_sub = false
  if item.selling_plan_allocation
    assign already_sub = true
  endif
-%}

{%- if already_sub == false and sp_groups.size > 0 -%}
  {%- liquid
    assign sp_group = sp_groups.first
    assign sp_plans = sp_group.selling_plans
    assign first_plan = sp_plans.first
    assign first_adj = first_plan.price_adjustments.first
    assign sp_pct = 0
    if first_adj.value_type == 'percentage'
      assign sp_pct = first_adj.value
    endif
    assign cadence_eyebrow = 'Deliver every'
    assign default_plan = first_plan.id
  -%}
  {%- comment -%}
    Per-frequency savings = one-off line price minus the subscription line price
    (allocation per-unit price x quantity). Exposed to Alpine as a {planId: money}
    map so the subline figure updates when a cadence pill is picked. default_save
    drives the server-rendered (no-JS) subline for the default/first plan.
  {%- endcomment -%}
  {%- assign default_save = 0 -%}
  {%- capture savings_map -%}{ {% for plan in sp_plans %}{% assign psave = 0 %}{% for a in item.variant.selling_plan_allocations %}{% if a.selling_plan.id == plan.id %}{% assign sub_line = a.price | times: item.quantity %}{% assign psave = item.original_line_price | minus: sub_line %}{% endif %}{% endfor %}{% if forloop.first %}{% assign default_save = psave %}{% endif %}'{{ plan.id }}': '{% if psave > 0 %}{{ psave | money }}{% endif %}'{% unless forloop.last %},{% endunless %}{% endfor %} }{%- endcapture -%}
  <div
    class="pc-cart-sub{% if layout == 'drawer' %} pc-cart-sub--row{% endif %}"
    x-data="{
      open: false,
      plan: '{{ default_plan }}',
      savings: {{ savings_map }},
      subQty: {{ item.quantity }},
      busy: false,
      err: '',
      subscribe() {
        if (this.busy || !window.PostcardCart) return;
        this.busy = true; this.err = '';
        window.PostcardCart.upgradeLineToPlan({
          lineKey: '{{ item.key }}',
          variantId: {{ item.variant.id }},
          totalQty: {{ item.quantity }},
          subQty: this.subQty,
          planId: this.plan
        }).catch((e) => { this.busy = false; this.err = (e && e.message) || 'Could not upgrade'; });
      }
    }"
  >
    <button type="button" class="pc-cart-sub__toggle" @click="open = !open" :aria-expanded="open">
      <span class="pc-cart-sub__badge-icon" aria-hidden="true">&#8635;</span>
      <span class="pc-cart-sub__head">
        <span class="pc-cart-sub__head-row">
          <span class="pc-cart-sub__toggle-text">Subscribe &amp; save</span>
          {%- if sp_pct > 0 -%}
            <span class="pc-cart-sub__toggle-badge">&minus;{{ sp_pct }}%</span>
          {%- endif -%}
          <span class="pc-refill-info" role="button" tabindex="0" aria-label="View subscription plan terms" data-refill-pct="{{ sp_pct }}" onclick="event.stopPropagation();if(window.PostcardRefillTerms)window.PostcardRefillTerms.open(this);" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();event.stopPropagation();if(window.PostcardRefillTerms)window.PostcardRefillTerms.open(this);}"><span aria-hidden="true">i</span></span>
        </span>
        <span
          class="pc-cart-sub__subline"
          x-text="(savings[plan] ? ('Save ' + savings[plan] + ' on every delivery') : 'Save on every order') + '. Skip, pause or cancel anytime.'"
        >{%- if default_save > 0 -%}Save {{ default_save | money }} on every delivery. Skip, pause or cancel anytime.{%- else -%}Save on every order. Skip, pause or cancel anytime.{%- endif -%}</span>
      </span>
      <span class="pc-cart-sub__toggle-arrow" :class="{ 'pc-cart-sub__toggle-arrow--open': open }" aria-hidden="true">&#9662;</span>
    </button>

    <div x-show="open" x-cloak class="pc-cart-sub__panel">
      <p class="pc-cart-sub__emote">Your self-care, on repeat.</p>
      <p class="pc-cart-sub__support">Save {{ sp_pct }}% on every order, delivered at your rhythm.</p>
      <div class="eyebrow pc-cart-sub__cadence-label">{{ cadence_eyebrow }}</div>
      <div class="pc-cart-sub__pills">
        {%- for plan in sp_plans -%}
          {%- assign plan_raw = plan.options.first.value | default: plan.name -%}
          {%- assign plan_lead = plan_raw | slice: 0, 2 -%}
          {%- if plan_lead == '1 ' -%}{%- assign plan_raw = plan_raw | remove_first: '1 ' -%}{%- endif -%}
          {%- assign plan_label = 'Every ' | append: plan_raw -%}
          <button
            type="button"
            class="pc-cart-sub__pill"
            :class="{ 'pc-cart-sub__pill--active': plan === '{{ plan.id }}' }"
            @click="plan = '{{ plan.id }}'"
          >{{ plan_label }}</button>
        {%- endfor -%}
      </div>
      {%- if item.quantity > 1 -%}
        <div class="pc-cart-sub__qty">
          <span class="pc-cart-sub__qty-label">How many of {{ item.quantity }}?</span>
          <div class="pc-cart-sub__stepper">
            <button type="button" class="pc-cart-sub__stepper-btn" aria-label="Fewer on subscription" @click="if (subQty > 1) subQty--">&minus;</button>
            <span class="pc-cart-sub__stepper-value" x-text="subQty">{{ item.quantity }}</span>
            <button type="button" class="pc-cart-sub__stepper-btn" aria-label="More on subscription" @click="if (subQty < {{ item.quantity }}) subQty++">+</button>
          </div>
        </div>
      {%- endif -%}
      <button
        type="button"
        class="pc-cart-sub__apply"
        @click="subscribe()"
        :disabled="busy"
        x-text="busy ? 'Starting…' : ({% if item.quantity > 1 %}'Start subscription plan · ' + subQty + ' of {{ item.quantity }}'{% else %}'Start subscription plan'{% endif %})"
      >Start subscription plan</button>
      <p class="pc-cart-sub__err" x-show="err" x-cloak x-text="err"></p>
    </div>
  </div>
{%- endif -%}
