{%- comment -%}
  Inline "switch to subscription" upsell for a single cart line.

  Renders a compact "Upgrade to autoship" card under a one-off line whose
  product has selling plans, showing the dynamic per-delivery savings and
  letting the customer convert that line to a subscription at a chosen
  frequency without leaving the cart. The switch goes
  through /cart/change.js (identified by `line` + `selling_plan`) via
  PostcardCart.setLinePlan, then the cart re-renders.

  Renders NOTHING when:
    - the line is already on a selling plan (item.selling_plan_allocation), or
    - the product has no selling plan groups (not subscribable).
  So it stays fully dormant until selling plans are configured in admin.

  Accepts:
    item   cart line item (required)
{%- endcomment -%}

{%- liquid
  assign sp_groups = item.product.selling_plan_groups
  assign already_sub = false
  if item.selling_plan_allocation
    assign already_sub = true
  endif
-%}

{%- if already_sub == false and sp_groups.size > 0 -%}
  {%- liquid
    assign sp_group = sp_groups.first
    assign sp_plans = sp_group.selling_plans
    assign first_plan = sp_plans.first
    assign first_adj = first_plan.price_adjustments.first
    assign sp_pct = 0
    if first_adj.value_type == 'percentage'
      assign sp_pct = first_adj.value
    endif
    assign cadence_eyebrow = sp_group.options.first.name | default: 'Deliver every'
    assign line_index = item.index | plus: 1
    assign default_plan = first_plan.id
  -%}
  {%- comment -%}
    Per-frequency savings = one-off line price minus the subscription line price
    (allocation per-unit price x quantity). Exposed to Alpine as a {planId: money}
    map so the subline figure updates when a cadence pill is picked. default_save
    drives the server-rendered (no-JS) subline for the default/first plan.
  {%- endcomment -%}
  {%- assign default_save = 0 -%}
  {%- capture savings_map -%}{ {% for plan in sp_plans %}{% assign psave = 0 %}{% for a in item.variant.selling_plan_allocations %}{% if a.selling_plan.id == plan.id %}{% assign sub_line = a.price | times: item.quantity %}{% assign psave = item.original_line_price | minus: sub_line %}{% endif %}{% endfor %}{% if forloop.first %}{% assign default_save = psave %}{% endif %}'{{ plan.id }}': '{% if psave > 0 %}{{ psave | money }}{% endif %}'{% unless forloop.last %},{% endunless %}{% endfor %} }{%- endcapture -%}
  <div
    class="pc-cart-sub"
    x-data="{
      open: false,
      plan: '{{ default_plan }}',
      savings: {{ savings_map }},
      busy: false,
      err: '',
      subscribe() {
        if (this.busy || !window.PostcardCart) return;
        this.busy = true; this.err = '';
        window.PostcardCart.setLinePlan({{ line_index }}, {{ item.quantity }}, this.plan)
          .catch((e) => { this.busy = false; this.err = (e && e.message) || 'Could not switch'; });
      }
    }"
  >
    <button type="button" class="pc-cart-sub__toggle" @click="open = !open" :aria-expanded="open">
      <span class="pc-cart-sub__badge-icon" aria-hidden="true">&#8635;</span>
      <span class="pc-cart-sub__head">
        <span class="pc-cart-sub__head-row">
          <span class="pc-cart-sub__toggle-text">Upgrade to autoship</span>
          {%- if sp_pct > 0 -%}
            <span class="pc-cart-sub__toggle-badge">&minus;{{ sp_pct }}%</span>
          {%- endif -%}
        </span>
        <span
          class="pc-cart-sub__subline"
          x-text="(savings[plan] ? ('Save ' + savings[plan] + ' on every delivery') : 'Deliver on repeat') + ' · skip or cancel anytime'"
        >{%- if default_save > 0 -%}Save {{ default_save | money }} on every delivery &middot; skip or cancel anytime{%- else -%}Deliver on repeat &middot; skip or cancel anytime{%- endif -%}</span>
      </span>
      <span class="pc-cart-sub__toggle-arrow" :class="{ 'pc-cart-sub__toggle-arrow--open': open }" aria-hidden="true">&#9662;</span>
    </button>

    <div x-show="open" x-cloak class="pc-cart-sub__panel">
      <div class="eyebrow pc-cart-sub__cadence-label">{{ cadence_eyebrow }}</div>
      <div class="pc-cart-sub__pills">
        {%- for plan in sp_plans -%}
          {%- assign plan_label = plan.options.first.value | default: plan.name -%}
          <button
            type="button"
            class="pc-cart-sub__pill"
            :class="{ 'pc-cart-sub__pill--active': plan === '{{ plan.id }}' }"
            @click="plan = '{{ plan.id }}'"
          >{{ plan_label }}</button>
        {%- endfor -%}
      </div>
      <button
        type="button"
        class="pc-cart-sub__apply"
        @click="subscribe()"
        :disabled="busy"
        x-text="busy ? 'Switching…' : 'Upgrade to autoship'"
      >Upgrade to autoship</button>
      <p class="pc-cart-sub__err" x-show="err" x-cloak x-text="err"></p>
    </div>
  </div>
{%- endif -%}
