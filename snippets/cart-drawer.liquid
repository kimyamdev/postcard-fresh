{%- comment -%}
  Postcard cart drawer — Variant A (editorial). Replaces Dawn's default cart
  drawer markup. Keeps the <cart-drawer> element so theme cart-drawer.js still
  handles open/close/focus-trap/escape.

  Sections refreshed on cart change: cart-drawer (this file via section
  rendering) + bag count via [data-pc-cart-count].
{%- endcomment -%}

<script src="{{ 'postcard-cart.js' | asset_url }}" defer="defer"></script>
{{ 'postcard-components.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign threshold_cents = 6000
  assign remaining_cents = threshold_cents | minus: cart.total_price
  if remaining_cents < 0
    assign remaining_cents = 0
  endif
  assign pct = 0
  if threshold_cents > 0
    assign pct = cart.total_price | times: 100 | divided_by: threshold_cents
  endif
  if pct > 100
    assign pct = 100
  endif
  comment
    Total savings = original (pre-discount) minus final. Split out the
    Mix & Match bundle portion: bundle lines carry a `_bundle` property
    (set by the mix-and-match section), so their line-level discount
    allocations are the bundle discount. Whatever remains is subscription /
    other savings and keeps the existing label.
  endcomment
  assign total_savings_cents = cart.original_total_price | minus: cart.total_price
  assign mm_savings_cents = 0
  assign bundle_name = ''
  for item in cart.items
    if item.properties._bundle_id != blank
      assign bundle_name_raw = item.properties.Bundle | default: item.properties._bundle | default: 'Mix & Match'
      assign bundle_name = bundle_name_raw | split: ' (' | first
      for alloc in item.line_level_discount_allocations
        assign mm_savings_cents = mm_savings_cents | plus: alloc.amount
      endfor
    endif
  endfor
  assign sub_savings_cents = total_savings_cents | minus: mm_savings_cents

  comment
    Smile VIP tier integration. Customer's tier name is read from
    customer.metafields.smile.vip_tier_name (single-line text). The "Villa"
    tier is the free-shipping tier — the tier badge always paints when set,
    and the free-ship bar flips to "unlocked" mode for Villa customers.
    PostcardConfig.villaShippingCode (set in window) optionally lets
    postcard-cart.js auto-apply a discount code; leave blank if the merchant
    has set up an automatic discount in Shopify Admin tied to the Smile
    customer segment.
  endcomment
  assign vip_tier = customer.metafields.smile.vip_tier_name.value
  assign is_villa = false
  if vip_tier != blank
    assign vip_tier_lower = vip_tier | downcase | strip
    if vip_tier_lower == 'villa'
      assign is_villa = true
    endif
  endif
  if is_villa
    assign remaining_cents = 0
    assign pct = 100
  endif
-%}

{%- if customer -%}
  <script>
    window.PostcardCustomer = {
      tier: {{ vip_tier | default: '' | json }},
      isVilla: {{ is_villa | json }},
      villaShippingCode: window.PostcardConfig && window.PostcardConfig.villaShippingCode || ""
    };
  </script>
{%- endif -%}

<cart-drawer class="pc-cart-drawer drawer{% if cart == empty %} is-empty{% endif %}">
  <div id="CartDrawer-Overlay" class="pc-cart-drawer__overlay" onclick="this.closest('cart-drawer').close()"></div>
  <div
    id="CartDrawer"
    class="drawer__inner pc-cart-drawer__panel"
    role="dialog"
    aria-modal="true"
    aria-label="Your bag"
    tabindex="-1"
    x-data="{ justAdded: null, showBanner: false, _t: null }"
    @pc-just-added.window="
      justAdded = $event.detail;
      showBanner = true;
      clearTimeout(_t);
      _t = setTimeout(() => { showBanner = false; }, 6000);
    "
  >
    <div class="pc-cart-drawer__just-added" x-show="showBanner" x-cloak x-transition.opacity>
      <div class="pc-cart-drawer__just-added-tick">&#10003;</div>
      <div class="pc-cart-drawer__just-added-text">
        <div class="eyebrow pc-cart-drawer__just-added-eyebrow">JUST ADDED</div>
        <div class="pc-cart-drawer__just-added-name" x-text="(justAdded && justAdded.product_title) || ''"></div>
      </div>
    </div>

    <div class="pc-cart-drawer__header">
      <div>
        <div class="eyebrow pc-cart-drawer__header-sub">
          {%- if cart.item_count > 0 -%}
            {{ cart.item_count }} {% if cart.item_count == 1 %}item{% else %}items{% endif %} &middot; ready to send
          {%- else -%}
            empty &middot; pick a postcard
          {%- endif -%}
        </div>
        <div class="h-display pc-cart-drawer__header-title">YOUR BAG</div>
        {%- if vip_tier != blank -%}
          <div class="pc-cart-drawer__tier{% if is_villa %} pc-cart-drawer__tier--villa{% endif %}" title="Smile VIP tier">
            <span class="pc-cart-drawer__tier-dot"></span>
            <span>{{ vip_tier | upcase }} TIER</span>
          </div>
        {%- endif -%}
      </div>
      <button class="pc-cart-drawer__close" type="button" onclick="this.closest('cart-drawer').close()" aria-label="Close">&times;</button>
    </div>

    {%- if cart != empty -%}
      <div class="pc-cart-drawer__ship{% if remaining_cents <= 0 %} pc-cart-drawer__ship--done{% endif %}">
        <div class="pc-cart-drawer__ship-row">
          <span>
            {%- if is_villa -%}
              &#10003; Free shipping &middot; Villa tier perk
            {%- elsif remaining_cents <= 0 -%}
              &#10003; Free shipping unlocked
            {%- else -%}
              {{ remaining_cents | money }} from free shipping
            {%- endif -%}
          </span>
          <span class="pc-cart-drawer__ship-pct">{{ pct }}%</span>
        </div>
        <div class="pc-cart-drawer__ship-track">
          <div class="pc-cart-drawer__ship-fill" style="width: {{ pct }}%;"></div>
          <div class="pc-cart-drawer__ship-tick" style="left: 25%;"></div>
          <div class="pc-cart-drawer__ship-tick" style="left: 50%;"></div>
          <div class="pc-cart-drawer__ship-tick" style="left: 75%;"></div>
        </div>
      </div>

      <div class="pc-cart-drawer__body">
        {%- assign rendered_bundles = '' -%}
        {%- for item in cart.items -%}
          {%- assign bundle_id = item.properties._bundle_id -%}

          {%- comment -%} Mix & Match bundle: 3 lines sharing a _bundle_id render as one locked group. {%- endcomment -%}
          {%- if bundle_id != blank -%}
            {%- assign bid_token = bundle_id | append: '|||' -%}
            {%- unless rendered_bundles contains bid_token -%}
              {%- assign rendered_bundles = rendered_bundles | append: bid_token -%}
              {%- liquid
                assign b_label_raw = item.properties.Bundle | default: item.properties._bundle | default: 'Mix & Match'
                assign b_label = b_label_raw | split: ' (' | first
                assign b_keys = ''
                assign b_qty = 0
                assign b_final = 0
                assign b_orig = 0
                for it in cart.items
                  if it.properties._bundle_id == bundle_id
                    assign b_keys = b_keys | append: it.key | append: ','
                    assign b_qty = it.quantity
                    assign b_final = b_final | plus: it.final_line_price
                    assign b_orig = b_orig | plus: it.original_line_price
                  endif
                endfor
              -%}
              <div class="pc-cart-bundle" data-bundle-id="{{ bundle_id | escape }}">
                <div class="pc-cart-bundle__head">
                  <span class="pc-cart-line__badge pc-cart-line__badge--bundle">&#10022; {{ b_label }} bundle</span>
                  <div class="pc-cart-bundle__price">
                    <span class="h-display pc-cart-line__price-now">{{ b_final | money }}</span>
                    {%- if b_orig > b_final -%}
                      <span class="pc-cart-line__price-was">{{ b_orig | money }}</span>
                    {%- endif -%}
                  </div>
                </div>
                <div class="pc-cart-bundle__items">
                  {%- for it in cart.items -%}
                    {%- if it.properties._bundle_id == bundle_id -%}
                      {%- liquid
                        assign it_size = it.variant.title
                        if it_size == 'Default Title'
                          assign it_size = ''
                        endif
                      -%}
                      <div class="pc-cart-bundle__item">
                        <span class="pc-cart-bundle__thumb">
                          {%- if it.image -%}
                            <img src="{{ it.image | image_url: width: 120 }}" alt="" loading="lazy" width="40" height="48">
                          {%- endif -%}
                        </span>
                        <span class="pc-cart-bundle__item-text">
                          {%- liquid
                            assign it_slot = it.properties._bundle_slot
                            if it_slot == blank and it.properties._bundle_pos != blank
                              assign it_slot = 'Item ' | append: it.properties._bundle_pos
                            endif
                          -%}
                          {%- if it_slot != blank -%}
                            <span class="pc-cart-bundle__item-slot">{{ it_slot }}</span>
                          {%- endif -%}
                          <span class="pc-cart-bundle__item-title">{{ it.product.title }}</span>
                          {%- if it_size != blank -%}
                            <span class="pc-cart-bundle__item-size">{{ it_size }}</span>
                          {%- endif -%}
                        </span>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
                <div class="pc-cart-line__qty-row">
                  <div class="pc-cart-line__qty">
                    <button type="button" class="pc-cart-line__qty-btn" aria-label="Decrease bundle quantity"
                      {% if b_qty <= 1 %}disabled{% endif %}
                      onclick="window.PostcardCart && window.PostcardCart.updateBundle('{{ b_keys }}', {{ b_qty | minus: 1 }})">&minus;</button>
                    <span class="pc-cart-line__qty-value" data-cart-qty>{{ b_qty }}</span>
                    <button type="button" class="pc-cart-line__qty-btn" aria-label="Increase bundle quantity"
                      onclick="window.PostcardCart && window.PostcardCart.updateBundle('{{ b_keys }}', {{ b_qty | plus: 1 }})">+</button>
                  </div>
                  <button type="button" class="pc-cart-line__remove tlink"
                    onclick="window.PostcardCart && window.PostcardCart.updateBundle('{{ b_keys }}', 0)">Remove bundle</button>
                </div>
              </div>
            {%- endunless -%}

          {%- else -%}
          {%- liquid
            assign world = item.product.metafields.postcard.world.value
            assign world_color = '#E8C36A'
            assign world_name = ''
            if world
              assign w_color = world.accent_color.value
              if w_color != blank
                assign world_color = w_color
              endif
              assign w_name = world.name.value
              if w_name != blank
                assign world_name = w_name
              endif
            endif
            assign size_label = item.variant.title
            if size_label == 'Default Title'
              assign size_label = ''
            endif
            assign refillable = item.product.metafields.custom.refillable.value
            assign cadence_label = ''
            if item.selling_plan_allocation
              assign cadence_label = item.selling_plan_allocation.selling_plan.name
            endif
            assign world_first_word = world_name | split: ' ' | first
          -%}
          <div class="pc-cart-line" data-line-key="{{ item.key }}">
            <a class="pc-cart-line__thumb ph ph--world" href="{{ item.url }}" style="--world-color: {{ world_color }};" aria-hidden="true" tabindex="-1">
              {%- if item.image -%}
                <img src="{{ item.image | image_url: width: 200 }}" alt="" class="pc-cart-line__thumb-img" loading="lazy" width="64" height="76">
              {%- else -%}
                <span class="pc-cart-line__thumb-fallback">{{ world_first_word }}</span>
              {%- endif -%}
            </a>
            <div class="pc-cart-line__main">
              {%- if world_name != blank -%}
                <div class="eyebrow pc-cart-line__world">{{ world_name }}</div>
              {%- endif -%}
              <div class="h-typewriter pc-cart-line__title">
                <a href="{{ item.url }}">{{ item.product.title }}</a>
              </div>
              {%- if size_label != blank or refillable -%}
                <div class="pc-cart-line__size">
                  {{ size_label }}{% if size_label != blank and refillable %} &middot; {% endif %}{% if refillable %}refillable{% endif %}
                </div>
              {%- endif -%}

              {%- if cadence_label != blank -%}
                <div class="pc-cart-line__badge pc-cart-line__badge--sub">
                  <span class="pc-cart-line__badge-dot"></span>
                  SUBSCRIBE &middot; {{ cadence_label }}
                </div>
              {%- endif -%}

              {%- if item.properties._gift_message != blank -%}
                <div class="pc-cart-line__badge pc-cart-line__badge--gift">&#127873; GIFT &middot; note attached</div>
              {%- endif -%}

              {%- assign legacy_bundle = item.properties.Bundle | default: item.properties._bundle | split: ' (' | first -%}
              {%- if legacy_bundle != blank -%}
                <div class="pc-cart-line__badge pc-cart-line__badge--bundle">&#10022; {{ legacy_bundle }} bundle</div>
              {%- endif -%}

              <div class="pc-cart-line__qty-row">
                <div class="pc-cart-line__qty">
                  <button type="button" class="pc-cart-line__qty-btn" aria-label="Decrease quantity"
                    onclick="window.PostcardCart && window.PostcardCart.updateLine('{{ item.key }}', {{ item.quantity | minus: 1 }})">&minus;</button>
                  <span class="pc-cart-line__qty-value" data-cart-qty>{{ item.quantity }}</span>
                  <button type="button" class="pc-cart-line__qty-btn" aria-label="Increase quantity"
                    onclick="window.PostcardCart && window.PostcardCart.updateLine('{{ item.key }}', {{ item.quantity | plus: 1 }})">+</button>
                </div>
                <button type="button" class="pc-cart-line__remove tlink"
                  onclick="window.PostcardCart && window.PostcardCart.updateLine('{{ item.key }}', 0)">Remove</button>
              </div>
            </div>
            <div class="pc-cart-line__price">
              <div class="h-display pc-cart-line__price-now">{{ item.final_line_price | money }}</div>
              {%- if item.original_line_price > item.final_line_price -%}
                <div class="pc-cart-line__price-was">{{ item.original_line_price | money }}</div>
              {%- endif -%}
            </div>

            {%- render 'cart-subscribe-upsell', item: item, layout: 'drawer' -%}
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <form action="{{ routes.cart_url }}" method="post" id="CartDrawer-Form" class="pc-cart-drawer__footer" novalidate>
        <div class="pc-cart-drawer__footer-inner">
          <div class="pc-cart-drawer__totals">
            <div class="pc-cart-drawer__total-row"><span>Subtotal</span><span>{{ cart.original_total_price | money }}</span></div>
            {%- if sub_savings_cents > 0 -%}
              <div class="pc-cart-drawer__total-row pc-cart-drawer__total-row--savings"><span>Subscription savings</span><span>&minus;{{ sub_savings_cents | money }}</span></div>
            {%- endif -%}
            {%- if mm_savings_cents > 0 -%}
              <div class="pc-cart-drawer__total-row pc-cart-drawer__total-row--savings"><span>{{ bundle_name | default: 'Mix & Match' }} savings</span><span>&minus;{{ mm_savings_cents | money }}</span></div>
            {%- endif -%}
            <div class="pc-cart-drawer__total-row"><span>Shipping</span><span>
              {%- if is_villa -%}Free &middot; Villa tier
              {%- elsif cart.total_price >= threshold_cents -%}Free
              {%- else -%}Calc. at checkout
              {%- endif -%}
            </span></div>
          </div>
          <div class="pc-cart-drawer__grand">
            <span class="h-display pc-cart-drawer__grand-label">TOTAL</span>
            <span class="h-display pc-cart-drawer__grand-value">{{ cart.total_price | money }}</span>
          </div>
          <button type="submit" name="checkout" class="btn pc-cart-drawer__cta">POST MY ORDER &rarr;</button>
          <div class="pc-cart-drawer__fineprint">
            Free returns &middot; ships in 24h &middot; paper-only packaging
          </div>
        </div>
      </form>
    {%- else -%}
      <div class="pc-cart-drawer__empty">
        <div class="h-display pc-cart-drawer__empty-title">YOUR BAG IS EMPTY</div>
        <p class="pc-cart-drawer__empty-body">Pick a postcard and we&rsquo;ll dispatch it to your skin.</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn">START WRITING &rarr;</a>
      </div>
    {%- endif -%}
  </div>
</cart-drawer>
