{%- comment -%}
  Wraps captured rec cells with the heading, shuffle button (when the pool is
  bigger than the visible window), and grid. Shared by the rec engines.

  Accepts:
    cards     captured cell HTML (required)
    heading   panel heading
    blurb     optional sub-line
    count     number of cells in the pool
    limit     cells shown at once
    columns   desktop grid columns
    compact   true for the narrow cart-drawer layout
{%- endcomment -%}
{%- assign shell_clean = cards | strip -%}
{%- if shell_clean != blank -%}
  <div class="pc-world-recs{% if compact %} pc-world-recs--compact{% endif %}" style="--pc-recs-cols: {{ columns | default: 4 }};" data-recs-step="{{ limit | default: 4 }}" data-recs-start="0">
    <div class="pc-world-recs__head">
      <div class="pc-world-recs__head-text">
        <h2 class="pc-world-recs__title">{{ heading }}</h2>
        {%- if blurb != blank -%}<p class="pc-world-recs__blurb">{{ blurb }}</p>{%- endif -%}
      </div>
      {%- if count > limit -%}
        <button type="button" class="pc-world-recs__shuffle" onclick="window.pcShuffleRecs(this)" aria-label="Show other products">&#8635; Shuffle</button>
      {%- endif -%}
    </div>
    <div class="pc-world-recs__grid">{{ cards }}</div>
  </div>
{%- endif -%}
