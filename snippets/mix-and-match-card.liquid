{%- comment -%}
  Renders one selectable Mix & Match card.

  Accepts:
  - product: {Object} Shopify product (required)
  - variant: {Object} a specific variant (optional). When set, the card represents
      exactly that variant — no dropdown — and the title includes the variant name.
      When omitted, the card represents the whole product with a variant dropdown.
{%- endcomment -%}

{%- liquid
  if variant
    assign current = variant
    assign show_dropdown = false
    assign is_available = variant.available
    assign sub_label = variant.title
    if sub_label == 'Default Title'
      assign sub_label = ''
    endif
    assign card_img = variant.featured_image | default: product.featured_image
    assign display_title = product.title
    if sub_label != blank
      assign cart_title = product.title | append: ' — ' | append: sub_label
    else
      assign cart_title = product.title
    endif
  else
    assign current = product.selected_or_first_available_variant
    assign show_dropdown = false
    if product.variants.size > 1
      assign show_dropdown = true
    endif
    assign is_available = product.available
    assign sub_label = ''
    assign card_img = product.featured_image
    assign display_title = product.title
    assign cart_title = product.title
  endif

  # World stamp — image from the linked World metaobject when available.
  assign world = product.metafields.postcard.world.value | default: product.metafields.product.world.value | default: product.metafields.custom.world.value
  assign world_name = ''
  assign world_color = '#E8C36A'
  assign world_stamp = blank
  assign world_family = ''
  assign world_handle = ''
  if world
    assign wn = world.name.value | default: world.name
    if wn != blank
      assign world_name = wn
    endif
    assign wh = world.slug.value | default: world.handle
    if wh != blank
      assign world_handle = wh
    endif
    assign wc = world.accent_color.value | default: world.accent_color
    if wc != blank
      assign world_color = wc
    endif
    assign wf = world.family.value | default: world.family
    if wf != blank
      assign world_family = wf
    endif
    assign world_stamp = world.world_stamp.value | default: world.world_stamp | default: world.stamp_image.value | default: world.stamp_image | default: world.stamp.value | default: world.stamp
  endif

  if world_name == blank or world_stamp == blank
    assign world_text = product.metafields.postcard.world | default: product.metafields.product.world | default: product.metafields.custom.world
    assign world_key = world_handle | default: world_text.value | default: world_text
    assign world_key_handle = world_key | handle
    assign world_lookup = shop.metaobjects.world[world_key_handle]
    if world_lookup
      assign world_name = world_lookup.name.value | default: world_lookup.name | default: world_name
      assign wc = world_lookup.accent_color.value | default: world_lookup.accent_color
      if wc != blank
        assign world_color = wc
      endif
      assign wf = world_lookup.family.value | default: world_lookup.family
      if wf != blank
        assign world_family = wf
      endif
      assign world_stamp = world_lookup.world_stamp.value | default: world_lookup.world_stamp | default: world_lookup.stamp_image.value | default: world_lookup.stamp_image | default: world_lookup.stamp.value | default: world_lookup.stamp | default: world_stamp
    endif
  endif
  assign world_family = world_family | default: product.metafields.postcard.family.value | default: product.metafields.custom.family.value | default: product.metafields.custom.scent_family.value
  assign stamp_mod = product.id | modulo: 7
  assign stamp_rot = -4
  case stamp_mod
    when 0
      assign stamp_rot = -7
    when 1
      assign stamp_rot = 5
    when 2
      assign stamp_rot = -3
    when 3
      assign stamp_rot = 7
    when 4
      assign stamp_rot = -5
    when 5
      assign stamp_rot = 3
  endcase
  assign world_initials = ''
  if world_name != blank
    assign world_words = world_name | split: ' '
    for ww in world_words limit: 2
      assign letter = ww | slice: 0, 1 | upcase
      assign world_initials = world_initials | append: letter
    endfor
  endif
-%}

<article
  class="mm-card{% unless is_available %} mm-card--soldout{% endunless %}"
  data-mm-card
  data-product-id="{{ product.id }}"
  data-product-title="{{ cart_title | escape }}"
  data-product-url="{{ product.url }}"
  data-variant-id="{{ current.id }}"
  data-world-name="{{ world_name | escape }}"
  data-world-stamp="{% if world_stamp != blank %}true{% else %}false{% endif %}"
  data-world-family="{{ world_family | escape }}"
  data-price="{{ current.price }}"
  data-available="{% if is_available %}true{% else %}false{% endif %}"
  {% unless is_available %}aria-disabled="true"{% endunless %}
  tabindex="0"
  role="button"
  aria-pressed="false"
>
  <div class="mm-card__media" style="--world-c: {{ world_color }};">
    {%- if card_img -%}
      {{
        card_img
        | image_url: width: 360
        | image_tag:
          loading: 'lazy',
          widths: '180, 360, 540',
          sizes: '(min-width: 750px) 220px, 45vw',
          alt: card_img.alt | default: product.title
      }}
    {%- else -%}
      {{ 'product-apparel-1' | placeholder_svg_tag: 'mm-card__placeholder' }}
    {%- endif -%}
    {%- if world_family != blank -%}
      <span class="mm-card__family" style="--world-c: {{ world_color }};" title="{{ world_family | escape }}">{{ world_family }}</span>
    {%- endif -%}
    <span class="mm-card__check" aria-hidden="true">
      <svg viewBox="0 0 16 16" width="16" height="16" focusable="false"><path d="M13.5 4.5 6 12 2.5 8.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </span>
    {%- if world_stamp != blank -%}
      {%- assign ws_alt = world_name | append: ' stamp' | escape -%}
      <span class="mm-card__world mm-card__world--img" title="{{ world_name | escape }}" style="--stamp-rot: {{ stamp_rot }}deg;">
        {{ world_stamp | image_url: width: 180 | image_tag: alt: ws_alt, loading: 'lazy', class: 'mm-card__world-img', widths: '90, 180, 270' }}
      </span>
    {%- elsif world_name != blank -%}
      <span class="mm-card__world" style="--world-c: {{ world_color }};" title="{{ world_name | escape }}" aria-label="World: {{ world_name | escape }}">{{ world_initials }}</span>
    {%- endif -%}
    {%- unless is_available -%}
      <span class="mm-card__soldout">Sold out</span>
    {%- endunless -%}
  </div>

  <div class="mm-card__body">
    <h3 class="mm-card__title">{{ display_title }}</h3>
    {%- if sub_label != blank -%}
      <p class="mm-card__variant-label">{{ sub_label }}</p>
    {%- endif -%}
    <p class="mm-card__price" data-mm-card-price>
      <span class="mm-card__price-now" data-mm-price-now></span>
      <span class="mm-card__price-was" data-mm-price-was hidden></span>
    </p>

    {%- if show_dropdown -%}
      <label class="mm-card__variant">
        <span class="visually-hidden">Choose an option for {{ product.title }}</span>
        <select data-mm-variant-select>
          {%- for v in product.variants -%}
            {%- assign v_img = v.featured_image | default: product.featured_image -%}
            <option
              value="{{ v.id }}"
              data-price="{{ v.price }}"
              data-available="{% if v.available %}true{% else %}false{% endif %}"
              data-image="{% if v_img %}{{ v_img | image_url: width: 600 }}{% endif %}"
              {% if v == current %}selected{% endif %}
              {% unless v.available %}disabled{% endunless %}
            >
              {{ v.title }}{% unless v.available %} — Sold out{% endunless %}
            </option>
          {%- endfor -%}
        </select>
      </label>
    {%- endif -%}

    <span class="mm-card__select" data-mm-select-label>Select</span>
  </div>
</article>
