{%- comment -%}
  "From your fav worlds" — same-world cross-sell from the logged-in customer's
  order history. Reads the worlds they've bought into, then suggests products
  from those worlds (the world's collection; falls back to featured_products)
  that they don't already own. Pool + shuffle via customer-rec-shell.

  Renders NOTHING when logged out, no orders, or no fresh suggestions exist.

  Accepts: heading, blurb, limit, columns, exclude_id, compact
{%- endcomment -%}
{%- if customer -%}
  {%- liquid
    assign rec_limit = limit | default: 4
    assign rec_cols = columns | default: 4
    assign rec_heading = heading | default: 'From your fav worlds'
    assign pool_limit = rec_limit | times: 3
    if pool_limit > 12
      assign pool_limit = 12
    endif

    comment
      Pass 1 — every owned product id, so we never suggest something already bought.
    endcomment
    assign owned_ids = ','
    for order in customer.orders
      for line in order.line_items
        if line.product
          assign owned_ids = owned_ids | append: line.product.id | append: ','
        endif
      endfor
    endfor
  -%}

  {%- comment -%}
    Pass 2 — walk orders newest-first; the first time each world is seen, render
    its fresh products (not owned, not shown), up to pool_limit. Most recently
    purchased world leads.
  {%- endcomment -%}
  {%- capture rec_cards -%}
    {%- assign rec_count = 0 -%}
    {%- assign rendered_ids = ',' -%}
    {%- assign done_worlds = '|' -%}
    {%- for order in customer.orders -%}
      {%- if rec_count >= pool_limit -%}{%- break -%}{%- endif -%}
      {%- for line in order.line_items -%}
        {%- if rec_count >= pool_limit -%}{%- break -%}{%- endif -%}
        {%- assign lp = line.product -%}
        {%- if lp == blank -%}{%- continue -%}{%- endif -%}
        {%- assign lw = lp.metafields.postcard.world.value | default: lp.metafields.custom.world.value -%}
        {%- if lw == blank -%}{%- continue -%}{%- endif -%}
        {%- assign wtok = '|' | append: lw.system.handle | append: '|' -%}
        {%- if done_worlds contains wtok -%}{%- continue -%}{%- endif -%}
        {%- assign done_worlds = done_worlds | append: lw.system.handle | append: '|' -%}
        {%- assign wslug = lw.slug.value | default: lw.system.handle -%}
        {%- assign wcandidates = collections[wslug].products -%}
        {%- if wcandidates == blank or wcandidates.size == 0 -%}
          {%- assign wcandidates = lw.featured_products.value -%}
        {%- endif -%}
        {%- for fp in wcandidates -%}
          {%- if rec_count >= pool_limit -%}{%- break -%}{%- endif -%}
          {%- unless fp.available -%}{%- continue -%}{%- endunless -%}
          {%- if fp.title contains 'Mini' -%}{%- continue -%}{%- endif -%}
          {%- assign idtok = ',' | append: fp.id | append: ',' -%}
          {%- if owned_ids contains idtok -%}{%- continue -%}{%- endif -%}
          {%- if rendered_ids contains idtok -%}{%- continue -%}{%- endif -%}
          {%- if exclude_id and fp.id == exclude_id -%}{%- continue -%}{%- endif -%}
          {%- assign rendered_ids = rendered_ids | append: fp.id | append: ',' -%}
          {%- assign rec_count = rec_count | plus: 1 -%}
          {%- assign rec_hidden = false -%}
          {%- if rec_count > rec_limit -%}{%- assign rec_hidden = true -%}{%- endif -%}
          {%- render 'customer-rec-card', product: fp, hidden: rec_hidden -%}
        {%- endfor -%}
      {%- endfor -%}
    {%- endfor -%}
  {%- endcapture -%}

  {%- render 'customer-rec-shell', cards: rec_cards, heading: rec_heading, blurb: blurb, count: rec_count, limit: rec_limit, columns: rec_cols, compact: compact -%}
{%- endif -%}
