{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: shop.name

  comment
    Bundle-only products are sold only through the Mix & Match page, so keep
    search engines from indexing their standalone product pages.
  endcomment
  assign bundle_only = false
  if request.page_type == 'product' and product.tags contains 'bundle-only'
    assign bundle_only = true
  endif

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif

  comment
    Link-preview (og:image) source, in priority order:
      1. A per-resource custom image metafield (custom.social_image) on the
         product / page — lets each page set its own share image in admin.
      2. The page's natural image (product featured / collection / article)
         via page_image.
      3. The global default set in Theme settings > Social media.
  endcomment
  assign og_image = page_image
  if request.page_type == 'product' and product.metafields.custom.social_image.value != blank
    assign og_image = product.metafields.custom.social_image.value
  elsif request.page_type == 'collection' and collection.metafields.custom.social_image.value != blank
    assign og_image = collection.metafields.custom.social_image.value
  elsif request.page_type == 'page' and page.metafields.custom.social_image.value != blank
    assign og_image = page.metafields.custom.social_image.value
  endif
  if og_image == blank and settings.social_share_image != blank
    assign og_image = settings.social_share_image
  endif
%}

{%- if bundle_only -%}
  <meta name="robots" content="noindex, nofollow">
{%- endif -%}

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | escape }}">

{%- if og_image != blank -%}
  <meta property="og:image" content="http:{{ og_image | image_url: width: 1200 }}">
  <meta property="og:image:secure_url" content="https:{{ og_image | image_url: width: 1200 }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="{{ 1200 | divided_by: og_image.aspect_ratio | round }}">
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta property="og:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
  <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta name="twitter:site" content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}">
{%- endif -%}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | escape }}">
{%- if og_image != blank -%}
  <meta name="twitter:image" content="https:{{ og_image | image_url: width: 1200 }}">
{%- endif -%}
