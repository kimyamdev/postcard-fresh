{%- comment -%}
  Renders one totals row per delivery frequency = autoship savings for the
  current cart. Saving per line = (one-off unit price - plan unit price) x qty,
  grouped by clean cadence. NOTE: for a line already on a selling plan,
  original_line_price already equals the plan price, so the baseline must be
  item.variant.price (the regular one-off price), not original_line_price.
  Two passes: collect distinct cadences, then sum each. Renders nothing when no
  line is on a selling plan.

  Accepts:
    variant   'drawer' (default) or 'cart' — picks the row markup/classes.
{%- endcomment -%}
{%- assign sub_cadences = '' -%}
{%- for item in cart.items -%}
  {%- if item.selling_plan_allocation -%}
    {%- assign sp = item.selling_plan_allocation.selling_plan -%}
    {%- assign cad = sp.options.first.value | default: sp.name -%}
    {%- assign cad_lead = cad | slice: 0, 2 -%}
    {%- if cad_lead == '1 ' -%}{%- assign cad = cad | remove_first: '1 ' -%}{%- endif -%}
    {%- assign tok = cad | append: '|||' -%}
    {%- unless sub_cadences contains tok -%}{%- assign sub_cadences = sub_cadences | append: tok -%}{%- endunless -%}
  {%- endif -%}
{%- endfor -%}
{%- assign cadence_list = sub_cadences | split: '|||' -%}
{%- for cad in cadence_list -%}
  {%- assign cad_savings = 0 -%}
  {%- for item in cart.items -%}
    {%- if item.selling_plan_allocation -%}
      {%- assign isp = item.selling_plan_allocation.selling_plan -%}
      {%- assign icad = isp.options.first.value | default: isp.name -%}
      {%- assign icad_lead = icad | slice: 0, 2 -%}
      {%- if icad_lead == '1 ' -%}{%- assign icad = icad | remove_first: '1 ' -%}{%- endif -%}
      {%- if icad == cad -%}
        {%- assign line_saving = item.variant.price | minus: item.selling_plan_allocation.price | times: item.quantity -%}
        {%- assign cad_savings = cad_savings | plus: line_saving -%}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
  {%- if cad_savings > 0 -%}
    {%- if variant == 'cart' -%}
      <div class="pc-cart-total-row pc-cart-total-row--savings"><span>Autoship savings &middot; every {{ cad }}</span><span>&minus;{{ cad_savings | money }}</span></div>
    {%- else -%}
      <div class="pc-cart-drawer__total-row pc-cart-drawer__total-row--savings"><span>Autoship savings &middot; every {{ cad }}</span><span>&minus;{{ cad_savings | money }}</span></div>
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}
