{%- liquid
  assign card_compare_at = ''
  if product
    assign card_name = product.title
    assign card_url = product.url
    if product.price_varies
      assign card_price = product.price_min | money | prepend: 'From '
    else
      assign card_price = product.price | money
    endif
    if product.compare_at_price > product.price
      assign card_compare_at = product.compare_at_price | money
    endif
    assign world_obj = product.metafields.postcard.world.value | default: product.metafields.custom.world.value
    if world_obj
      assign card_world = world_obj.name
      assign card_world_color = world_obj.accent_color
      assign card_world_stamp = world_obj.world_stamp.value
    endif
  endif

  assign card_name = name | default: card_name
  assign card_url = href | default: card_url | default: '#'
  assign card_price = price | default: card_price
  assign card_compare_at = compare_at | default: card_compare_at
  assign card_world = world | default: card_world | default: ''
  assign card_world_color = world_color | default: card_world_color | default: '#E8C36A'
  assign card_world_stamp = world_stamp | default: card_world_stamp
  assign card_badge = badge

  assign world_words = card_world | split: ' '
  assign world_initials = ''
  for word in world_words limit: 2
    assign first_letter = word | slice: 0, 1 | upcase
    assign world_initials = world_initials | append: first_letter
  endfor
-%}
<a class="pc-product-card" href="{{ card_url }}">
  <div class="ph ph--world pc-product-card__media" style="--world-color: {{ card_world_color }};">
    {%- if product.featured_image -%}
      {%- assign card_alt = product.featured_image.alt | default: product.title -%}
      {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: card_alt, class: 'pc-product-card__img' }}
    {%- else -%}
      <span style="opacity: 0.55;">product · {{ card_world }}</span>
    {%- endif -%}
    {%- if card_badge != blank -%}
      <div class="pc-product-card__badge">{{ card_badge }}</div>
    {%- endif -%}
    {%- if card_world != blank -%}
      <div class="pc-product-card__chip" style="background: {{ card_world_color }};">{{ world_initials }}</div>
    {%- endif -%}
    {%- if card_world_stamp != blank -%}
      {%- assign ws_alt = card_world | append: ' stamp' | escape -%}
      <div class="pc-product-card__world-stamp">
        {{ card_world_stamp | image_url: width: 240 | image_tag: alt: ws_alt, loading: 'lazy', class: 'pc-product-card__world-stamp-img' }}
      </div>
    {%- endif -%}
  </div>
  <div>
    <div class="pc-product-card__world">{{ card_world }}</div>
    <h3 class="pc-product-card__name">{{ card_name }}</h3>
    <div class="pc-product-card__row">
      <span class="pc-product-card__price">
        {{ card_price }}
        {%- if card_compare_at != blank -%}
          <s class="pc-product-card__compare-at">{{ card_compare_at }}</s>
        {%- endif -%}
      </span>
      <span class="tlink">Add &rarr;</span>
    </div>
  </div>
</a>
