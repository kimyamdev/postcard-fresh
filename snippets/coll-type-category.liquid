{%- comment -%}
  Maps a product_type label to a high-level category for the collection filter UI.
  First match wins (order matters). Outputs only the category name.
  Param: label (the product_type string)
{%- endcomment -%}
{%- liquid
  assign lbl = label | downcase
  assign vcat = 'Accessories'
  if lbl contains 'pet' or lbl contains 'paw'
    assign vcat = 'Pets'
  elsif lbl contains 'bundle'
    assign vcat = 'Bundles'
  elsif lbl contains 'gift' or lbl contains 'postcard'
    assign vcat = 'Gifts'
  elsif lbl contains 'travel'
    assign vcat = 'Travel'
  elsif lbl contains 'shampoo' or lbl contains 'conditioner' or lbl contains 'hair'
    assign vcat = 'Hair'
  elsif lbl contains 'sleep'
    assign vcat = 'Home'
  elsif lbl contains 'facial' or lbl contains 'serum' or lbl contains 'mask' or lbl contains 'makeup' or lbl contains 'make up' or lbl contains 'sun care' or lbl contains 'beauty'
    assign vcat = 'Face'
  elsif lbl contains 'diffuser' or lbl contains 'home' or lbl contains 'fragrance' or lbl contains 'scent' or lbl contains 'essential oil' or lbl contains 'cleaning'
    assign vcat = 'Home'
  elsif lbl contains 'body' or lbl contains 'soap' or lbl contains 'hand' or lbl contains 'lip' or lbl contains 'deodorant' or lbl contains 'cleansing' or lbl contains 'powder wash' or lbl contains 'lotion' or lbl contains 'balm' or lbl contains 'reparative' or lbl contains 'refillable' or lbl contains 'nail'
    assign vcat = 'Body'
  endif
  echo vcat
-%}
